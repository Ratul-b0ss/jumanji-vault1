---
import '../styles/global.css';

interface Props {
  title?: string;
}

const defaultTitle = 'BRICK RUSH - Premium Minifigures';
const { title = defaultTitle } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#080808" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
    <script src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js"></script>
    <title>{title || defaultTitle}</title>
  </head>
  <body>
    <!-- ── Premium Page Loader/Splash Screen ── -->
    <div id="pageLoader" class="page-loader">
      <div class="loader-content">
        <div class="loader-brick-wrapper">
          <div class="loader-brick bg-cyan"></div>
          <div class="loader-brick bg-white"></div>
          <div class="loader-brick bg-cyan"></div>
        </div>
        <div class="loader-logo">
          <span class="logo-b">B</span>
          <span class="logo-text">BRICK<span class="text-cyan">RUSH</span></span>
        </div>
        <div class="loader-bar">
          <div class="loader-bar-fill"></div>
        </div>
        <div class="loader-status caption-mono text-[9px]">CONNECTING TO VAULT...</div>
      </div>
    </div>

    <!-- ── Toast Container ── -->
    <div id="toastContainer" style="position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:9999;display:flex;flex-direction:column;gap:8px;pointer-events:none;width:auto;max-width:90vw;"></div>

    <header class="nav-bar">
      <div class="container flex items-center justify-between w-full h-full">
        <a href="/" class="flex items-center gap-3 group">
          <img src="/images/IMG_20260618_130458.jpg.jpeg" alt="BRICK RUSH logo" class="h-10 w-auto rounded-md object-contain" />
          <span class="caption-mono text-white font-bold tracking-tighter hidden sm:inline">BRICK RUSH</span>
        </a>
        <div class="flex items-center gap-2 sm:gap-3">
          <button id="navCartBtn" class="nav-link flex items-center gap-2" type="button">
            <span class="hidden sm:inline">Cart</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="sm:hidden">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0" />
            </svg>
            <span id="navCartCount" class="text-cyan font-bold">(0)</span>
          </button>
        </div>
      </div>
    </header>

    <button id="stickyCart" class="sticky-cart" type="button">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0" />
      </svg>
      <span id="cartBadge" class="cart-badge hidden">0</span>
    </button>

    <div id="cartOverlay" class="drawer-overlay hidden opacity-0 transition-opacity duration-300"></div>
    <div id="cartDrawer" class="drawer translate-x-full">
      <div class="flex flex-col h-full">
        <div class="p-6 border-b border-accents-2 flex items-center justify-between bg-ds-background-200">
          <h2 class="display-sm">Your Cart</h2>
          <button id="closeDrawer" class="text-3xl text-accents-5 hover:text-white transition-colors">&times;</button>
        </div>
        <div id="drawerContent" class="flex-1 overflow-y-auto p-6 scroll-smooth"></div>
        <div id="drawerFooter" class="p-6 border-t border-accents-2 bg-ds-background-200 hidden">
          <div id="drawerSummary" class="mb-4"></div>
          <div class="flex items-center justify-between mb-6">
            <span class="text-accents-5 font-medium">Subtotal</span>
            <span id="drawerTotal" class="display-sm text-cyan"></span>
          </div>
          <button id="checkoutBtn" class="btn-primary w-full">Proceed to Checkout</button>
        </div>
      </div>
    </div>

    <div id="checkoutModal" class="modal-overlay hidden opacity-0 transition-opacity duration-300">
      <div class="modal-content card max-w-lg w-full relative">
        <button id="closeCheckout" class="absolute top-6 right-6 text-3xl text-accents-5 hover:text-white">&times;</button>
        
        <h2 class="display-md mb-2">Checkout</h2>
        <p class="body-sm text-accents-5 mb-6">Review your order and complete details below.</p>

        <form id="checkoutForm" class="space-y-6">
          <div class="p-4 bg-accents-1 border border-accents-2 rounded-lg">
            <h3 class="caption-mono text-[10px] text-cyan font-bold tracking-wider mb-3">Order Summary</h3>
            <div id="checkoutItems" class="space-y-2 mb-3"></div>
            <div id="checkoutSubtotal" class="flex items-center justify-between text-xs text-accents-5 pt-3 border-t border-accents-2">
              <span>Subtotal</span>
              <span id="checkoutSubtotalVal" class="text-white font-bold"></span>
            </div>
            <div id="checkoutDeliveryRow" class="flex items-center justify-between text-xs text-accents-5 mt-2">
              <span>Delivery Fee</span>
              <span id="checkoutDeliveryVal" class="text-white font-bold">Select zone</span>
            </div>
            <div id="checkoutDiscountRow" class="flex items-center justify-between text-xs text-accents-5 mt-2 hidden">
              <span>Coupon Discount</span>
              <span id="checkoutDiscountVal" class="text-green-400 font-bold"></span>
            </div>
            <div class="flex items-center justify-between text-sm mt-3 pt-3 border-t border-accents-2">
              <span class="font-bold text-white">Total</span>
              <span id="checkoutTotalVal" class="text-cyan font-bold"></span>
            </div>

            <div id="couponSection" class="mt-3 pt-3 border-t border-accents-2">
              <div class="flex gap-2">
                <input type="text" id="couponInput" class="form-input !h-9 !text-xs uppercase" placeholder="Coupon code" />
                <button type="button" id="applyCouponBtn" class="btn-sm cyan" style="background:var(--cyan-soft);min-width:70px;">Apply</button>
              </div>
              <div id="couponStatus" class="mt-1.5 text-[10px] text-accents-4"></div>
            </div>
          </div>

          <div>
            <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Delivery Zone</label>
            <input type="hidden" id="deliveryZone" value="" />
            <div class="flex gap-2">
              <button type="button" class="zone-btn flex-1" data-zone="ctg">
                <span class="zone-btn-icon">📍</span>
                <span class="zone-btn-text">Inside<br class="sm:hidden" /> CTG</span>
              </button>
              <button type="button" class="zone-btn flex-1" data-zone="outside">
                <span class="zone-btn-icon">🌍</span>
                <span class="zone-btn-text">Outside<br class="sm:hidden" /> CTG</span>
              </button>
            </div>
            <div id="zoneInfo" class="mt-2 text-[11px] text-accents-4 hidden"></div>
          </div>

          <div>
            <h3 class="caption-mono text-[10px] text-white font-bold tracking-wider mb-3">Customer Information</h3>
            <div class="grid grid-cols-1 gap-3">
              <input type="text" id="custName" class="form-input" required placeholder="Full Name" />
              <input type="tel" id="custPhone" class="form-input" required placeholder="Phone Number" />
              <textarea id="custAddress" class="form-textarea" required placeholder="Delivery Address"></textarea>
            </div>
          </div>

          <div id="outsidePayment" class="hidden">
            <h3 class="caption-mono text-[10px] text-white font-bold tracking-wider mb-3">Payment Method (Advance)</h3>
            <div class="space-y-3">
              <div id="payInstructions" class="p-3 bg-cyan/5 border border-cyan/20 rounded-sm text-xs text-accents-6"></div>
              <input type="hidden" id="payMethod" value="" />
              <div class="flex gap-2">
                <button type="button" class="pay-btn flex-1" data-method="bkash">
                  <span class="pay-btn-text">Bkash</span>
                </button>
                <button type="button" class="pay-btn flex-1" data-method="nagad">
                  <span class="pay-btn-text">Nagad</span>
                </button>
              </div>
              <input type="text" id="trxId" class="form-input" placeholder="Transaction ID (TrxID)" />
            </div>
          </div>

          <div id="insideCOD" class="hidden p-3 bg-green-500/5 border border-green-500/20 rounded-sm">
            <p class="text-xs text-accents-6">✅ <strong class="text-white">Cash on Delivery</strong></p>
          </div>

          <button type="submit" class="btn-primary w-full mt-2">Place Order Now</button>
        </form>
      </div>
    </div>

    <main><slot /></main>

    <style>
      /* ── Page Loader Styles ── */
      .page-loader {
        position: fixed;
        inset: 0;
        z-index: 99999;
        background-color: #080808;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.4s;
      }
      .page-loader.fade-out {
        opacity: 0;
        visibility: hidden;
      }
      .loader-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
      }
      /* Animated Lego Brick Grid */
      .loader-brick-wrapper {
        display: flex;
        gap: 6px;
        margin-bottom: 4px;
      }
      .loader-brick {
        width: 14px;
        height: 14px;
        border-radius: 2px;
        position: relative;
        animation: brickPulse 1.2s infinite ease-in-out;
      }
      .loader-brick::after {
        content: '';
        position: absolute;
        top: -3px;
        left: 2px;
        width: 4px;
        height: 3px;
        background: inherit;
        border-radius: 1px 1px 0 0;
        box-shadow: 6px 0 0 inherit;
      }
      .loader-brick:nth-child(1) { animation-delay: 0s; }
      .loader-brick:nth-child(2) { animation-delay: 0.2s; }
      .loader-brick:nth-child(3) { animation-delay: 0.4s; }

      @keyframes brickPulse {
        0%, 100% { transform: scale(1); opacity: 0.25; filter: drop-shadow(0 0 0px var(--cyan)); }
        50% { transform: scale(1.15); opacity: 1; filter: drop-shadow(0 0 6px var(--cyan)); }
      }
      .loader-logo {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .loader-logo .logo-b {
        width: 28px;
        height: 28px;
        background: var(--cyan);
        color: #000;
        font-weight: 800;
        font-size: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        box-shadow: 0 0 15px rgba(80, 227, 194, 0.3);
      }
      .loader-logo .logo-text {
        font-family: 'JetBrains Mono', monospace;
        font-weight: 700;
        font-size: 15px;
        letter-spacing: -0.05em;
        color: #fff;
      }
      .loader-bar {
        width: 140px;
        height: 2px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 1px;
        overflow: hidden;
        position: relative;
      }
      .loader-bar-fill {
        height: 100%;
        width: 30%;
        background: var(--cyan);
        border-radius: 1px;
        position: absolute;
        left: 0;
        animation: fillProgress 1.6s infinite cubic-bezier(0.65, 0.05, 0.36, 1);
        box-shadow: 0 0 6px var(--cyan);
      }
      @keyframes fillProgress {
        0% { left: -30%; width: 30%; }
        50% { width: 40%; }
        100% { left: 100%; width: 30%; }
      }
      .loader-status {
        color: var(--accents-4);
        letter-spacing: 0.15em;
        margin-top: 2px;
        animation: pulseText 1.5s infinite ease-in-out;
      }
      @keyframes pulseText {
        0%, 100% { opacity: 0.4; }
        50% { opacity: 0.8; }
      }

      /* ── Toast Styles ── */
      .toast {
        pointer-events: auto;
        padding: 14px 24px;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 500;
        text-align: center;
        animation: toastIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.05);
        backdrop-filter: blur(12px);
        max-width: 400px;
        min-width: 200px;
      }
      .toast.success { background: rgba(34,197,94,0.15); color: #22c55e; border: 1px solid rgba(34,197,94,0.3); }
      .toast.error { background: rgba(239,68,68,0.15); color: #ef4444; border: 1px solid rgba(239,68,68,0.3); }
      .toast.info { background: rgba(80,227,194,0.15); color: #50e3c2; border: 1px solid rgba(80,227,194,0.3); }
      .toast.warning { background: rgba(245,166,35,0.15); color: #f5a623; border: 1px solid rgba(245,166,35,0.3); }
      @keyframes toastIn {
        from { opacity: 0; transform: translateY(20px) scale(0.95); }
        to { opacity: 1; transform: translateY(0) scale(1); }
      }
      @keyframes toastOut {
        from { opacity: 1; transform: translateY(0) scale(1); }
        to { opacity: 0; transform: translateY(-10px) scale(0.95); }
      }
      @keyframes badgePop {
        0% { transform: scale(1); }
        50% { transform: scale(1.4); }
        100% { transform: scale(1); }
      }
      .cart-badge.pop { animation: badgePop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1); }
      .pay-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 12px 16px;
        border-radius: 8px;
        border: 1px solid var(--accents-2);
        background: var(--ds-background-200);
        color: var(--accents-5);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        min-height: 44px;
        -webkit-tap-highlight-color: transparent;
      }
      .pay-btn:hover {
        border-color: var(--accents-3);
        color: var(--accents-6);
      }
      .pay-btn.on {
        border-color: var(--cyan);
        background: var(--cyan-soft);
        color: var(--cyan);
        box-shadow: 0 0 0 1px rgba(80,227,194,0.2);
      }
      .pay-btn.on .pay-btn-text::before {
        content: '✓ ';
      }
      .pay-btn:active {
        transform: scale(0.97);
      }
      .zone-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 12px;
        border-radius: 10px;
        border: 1px solid var(--accents-2);
        background: var(--ds-background-200);
        color: var(--accents-5);
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        min-height: 52px;
        -webkit-tap-highlight-color: transparent;
        line-height: 1.2;
      }
      .zone-btn:hover {
        border-color: var(--accents-3);
        color: var(--accents-6);
      }
      .zone-btn.on {
        border-color: var(--cyan);
        background: var(--cyan-soft);
        color: var(--cyan);
        box-shadow: 0 0 0 1px rgba(80,227,194,0.2);
      }
      .zone-btn.on .zone-btn-text::before {
        content: '✓ ';
      }
      .zone-btn .zone-btn-icon {
        font-size: 16px;
      }
      .zone-btn:active {
        transform: scale(0.97);
      }
    </style>

    <script is:inline>
      // ─── Page Loader Dismissal ───
      window.dismissLoader = function() {
        var loader = document.getElementById('pageLoader');
        if (loader) {
          loader.classList.add('fade-out');
          setTimeout(function() {
            if (loader.parentNode) loader.parentNode.removeChild(loader);
          }, 500);
        }
      };

      // Auto-dismiss safety timer (3.5 seconds)
      setTimeout(function() {
        if (window.dismissLoader) window.dismissLoader();
      }, 3500);

      // ─── Global Toast System ───
      window.showToast = function(message, type) {
        type = type || 'info';
        var container = document.getElementById('toastContainer');
        if (!container) return;
        var el = document.createElement('div');
        el.className = 'toast ' + type;
        el.textContent = message;
        container.appendChild(el);
        setTimeout(function() {
          el.style.animation = 'toastOut 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards';
          setTimeout(function() { if (el.parentNode) el.parentNode.removeChild(el); }, 250);
        }, 2500);
      };

      // ─── Supabase Config ───
      var SUPABASE_URL = 'https://bpgdniisgxzgrrcqlnwp.supabase.co';
      var SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJwZ2RuaWlzZ3h6Z3JyY3FsbndwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE3NjU2ODIsImV4cCI6MjA5NzM0MTY4Mn0.krm-gAAveC4y8bBIwEMFTggXSDzn4Ypj_r5UjoJ5uuk';

      function supabaseFetch(path, options) {
        return fetch(SUPABASE_URL + '/rest/v1/' + path, {
          headers: {
            'apikey': SUPABASE_ANON_KEY,
            'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
            'Content-Type': 'application/json',
            ...(options && options.headers ? options.headers : {})
          },
          ...(options ? { method: options.method, body: options.body } : {})
        });
      }

      // ─── Global State & Storage ───
      window.cart = [];
      try { window.cart = JSON.parse(localStorage.getItem('jv_cart') || '[]'); } catch (e) {}

      // ─── Product Image Cache Helper ───
      var productImageCache = {};
      window.getProductImage = function(name) {
        if (!name) return 'https://placehold.co/400x533/111/50e3c2?text=Unit&font=inter';
        if (productImageCache[name]) return productImageCache[name];

        // 1. Try window.allProducts
        if (window.allProducts && Array.isArray(window.allProducts)) {
          var found = window.allProducts.find(function(p) { return p.name === name; });
          if (found && found.image) {
            productImageCache[name] = found.image;
            return found.image;
          }
        }

        // 2. Try localStorage cached products
        try {
          var cached = localStorage.getItem('jv_supabase_products');
          if (cached) {
            var products = JSON.parse(cached);
            if (Array.isArray(products)) {
              var found = products.find(function(p) { return p.name === name; });
              if (found && found.image) {
                productImageCache[name] = found.image;
                return found.image;
              }
            }
          }
        } catch (e) {}

        return 'https://placehold.co/400x533/111/50e3c2?text=Unit&font=inter';
      };

      window.saveCart = function() {
        try {
          // Clean cart data before saving to localStorage to prevent QuotaExceededError from base64 images
          var cleanCart = window.cart.map(function(item) {
            var clone = { ...item };
            delete clone.image;
            return clone;
          });
          localStorage.setItem('jv_cart', JSON.stringify(cleanCart));
        } catch (e) {
          console.error('Failed to save cart to localStorage:', e);
          try {
            localStorage.removeItem('jv_settings_cache');
            localStorage.setItem('jv_cart', JSON.stringify(cleanCart));
          } catch(e2) {
            console.error('Clear failed to resolve quota:', e2);
          }
        }
        window.updateUI();
      };

      window.updateUI = function() {
        var count = window.cart.reduce(function(s, i) { return s + (i.qty || 0); }, 0);
        var navCount = document.getElementById('navCartCount');
        if (navCount) navCount.textContent = '(' + count + ')';
        var badge = document.getElementById('cartBadge');
        if (badge) {
          if (count > 0) { 
            badge.textContent = count; 
            badge.classList.remove('hidden');
            badge.classList.remove('pop');
            void badge.offsetWidth; // reflow
            badge.classList.add('pop');
            setTimeout(function() { badge.classList.remove('pop'); }, 400);
          }
          else { badge.classList.add('hidden'); }
        }
      };

      window.addToCart = function(product) {
        if (!product || !product.name) return;

        // Cache image reference in memory if it was passed
        if (product.image) {
          productImageCache[product.name] = product.image;
        }

        var existing = window.cart.find(function(i) { return i.name === product.name; });
        if (existing) {
          existing.qty++;
        } else {
          var cartItem = { ...product };
          delete cartItem.image; // Do not store base64 image in cart memory/storage
          cartItem.qty = 1;
          window.cart.push(cartItem);
        }
        window.saveCart();
        window.showToast(product.name + ' added to cart!', 'success');
      };

      function toggleClass(id, cls, force) {
        var el = document.getElementById(id);
        if (el) el.classList.toggle(cls, force);
      }

      // ─── Drawer ───
      window.openDrawer = function() {
        renderDrawer();
        toggleClass('cartOverlay', 'hidden', false);
        setTimeout(function() { toggleClass('cartOverlay', 'opacity-0', false); }, 10);
        toggleClass('cartDrawer', 'translate-x-full', false);
        document.body.classList.add('modal-open');
      };

      window.closeDrawer = function() {
        toggleClass('cartDrawer', 'translate-x-full', true);
        toggleClass('cartOverlay', 'opacity-0', true);
        setTimeout(function() {
          toggleClass('cartOverlay', 'hidden', true);
          document.body.classList.remove('modal-open');
        }, 400);
      };

      function renderDrawer() {
        var content = document.getElementById('drawerContent');
        var footer = document.getElementById('drawerFooter');
        if (!content) return;
        if (window.cart.length === 0) {
          content.innerHTML = '<div class="text-center py-20 text-accents-4">Your cart is empty</div>';
          if (footer) footer.classList.add('hidden');
          return;
        }
        if (footer) footer.classList.remove('hidden');

        var total = 0;
        content.innerHTML = window.cart.map(function(item, i) {
          var p = parseInt(item.price.replace(/[^0-9]/g, '')) || 0;
          total += p * item.qty;
          var itemImg = item.image || window.getProductImage(item.name);
          return '<div class="flex flex-col gap-4 mb-6 border-b border-accents-2 pb-4 last:border-b-0 last:pb-0">' +
            '<div class="flex items-start gap-4">' +
              '<img src="' + itemImg + '" class="w-16 h-16 object-contain bg-accents-1 rounded" />' +
              '<div class="flex-1"><p class="text-xs font-medium text-white">' + item.name + '</p><p class="text-[10px] text-accents-5">' + item.price + ' each</p></div>' +
              '<button onclick="window.removeItem(' + i + ')" class="text-error text-[10px]">Remove</button>' +
            '</div>' +
            '<div class="flex items-center justify-between gap-3 text-[10px] text-accents-5">' +
              '<div class="flex items-center gap-2">' +
                '<button onclick="window.changeQty(' + i + ', -1)" class="px-2 py-1 bg-accents-1 rounded text-white">-</button>' +
                '<span class="font-bold text-white">' + item.qty + '</span>' +
                '<button onclick="window.changeQty(' + i + ', 1)" class="px-2 py-1 bg-accents-1 rounded text-white">+</button>' +
              '</div>' +
              '<span class="font-medium text-white">Tk ' + (p * item.qty).toLocaleString() + '</span>' +
            '</div></div>';
        }).join('');

        var dt = document.getElementById('drawerTotal');
        if (dt) dt.textContent = 'Tk ' + total.toLocaleString();

        var summary = document.getElementById('drawerSummary');
        if (summary) {
          summary.innerHTML = '<div class="flex items-center justify-between text-[11px] text-accents-5"><span>Items total</span><span>Tk ' + total.toLocaleString() + '</span></div>';
        }
      }

      window.changeQty = function(i, delta) {
        if (!window.cart[i]) return;
        window.cart[i].qty = Math.max(0, (window.cart[i].qty || 1) + delta);
        if (window.cart[i].qty === 0) window.cart.splice(i, 1);
        window.saveCart();
        renderDrawer();
      };

      window.removeItem = function(i) {
        window.cart.splice(i, 1);
        window.saveCart();
        renderDrawer();
      };

      document.getElementById('navCartBtn').onclick = window.openDrawer;
      document.getElementById('stickyCart').onclick = window.openDrawer;
      document.getElementById('closeDrawer').onclick = window.closeDrawer;
      document.getElementById('cartOverlay').onclick = window.closeDrawer;

      // ─── Coupon State ───
      var _appliedCoupon = null; // { code, discount_type, discount_value, discount_amount }

      // ─── Settings (loaded from Supabase) ───
      var _settings = { fee_ctg: 70, fee_outside: 130, contact: '', bkash: '', nagad: '' };

      try {
        var cached = localStorage.getItem('jv_settings_cache');
        if (cached) _settings = JSON.parse(cached);
      } catch(e) {}

      supabaseFetch('settings?select=*&limit=1')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data && data.length > 0) {
            _settings = data[0];
            localStorage.setItem('jv_settings_cache', JSON.stringify(_settings));
          }
        })
        .catch(function() {});

      function getDeliveryFee(zone) {
        if (zone === 'ctg') return Number(_settings.fee_ctg) || 70;
        if (zone === 'outside') return Number(_settings.fee_outside) || 130;
        return 0;
      }

      // ─── Checkout UI Logic ───
      function renderCheckoutSummary() {
        var itemsEl = document.getElementById('checkoutItems');
        var subEl = document.getElementById('checkoutSubtotalVal');
        if (!itemsEl) return;
        var total = 0;
        itemsEl.innerHTML = window.cart.map(function(item) {
          var p = parseInt(item.price.replace(/[^0-9]/g, '')) || 0;
          total += p * item.qty;
          return '<div class="flex items-center justify-between text-xs"><span class="text-accents-5">' + item.name + ' <span class="text-accents-4">x' + item.qty + '</span></span><span class="text-white font-medium">Tk ' + (p * item.qty).toLocaleString() + '</span></div>';
        }).join('');
        if (subEl) subEl.textContent = 'Tk ' + total.toLocaleString();
        updateCheckoutTotal();
      }

      function getCouponDiscountAmount() {
        if (!_appliedCoupon) return 0;
        var subtotal = window.cart.reduce(function(s, i) { return s + (parseInt(i.price.replace(/[^0-9]/g, '')) * i.qty); }, 0);
        if (_appliedCoupon.discount_type === 'percentage') {
          return Math.round(subtotal * _appliedCoupon.discount_value / 100);
        } else {
          return Math.min(_appliedCoupon.discount_value, subtotal);
        }
      }

      function updateCheckoutTotal() {
        var zone = document.getElementById('deliveryZone').value;
        var subtotal = window.cart.reduce(function(s, i) { return s + (parseInt(i.price.replace(/[^0-9]/g, '')) * i.qty); }, 0);
        var discountAmt = getCouponDiscountAmount();
        var discountedSubtotal = subtotal - discountAmt;
        var deliveryFee = getDeliveryFee(zone);
        
        var delVal = document.getElementById('checkoutDeliveryVal');
        var totalEl = document.getElementById('checkoutTotalVal');
        var discRow = document.getElementById('checkoutDiscountRow');
        var discVal = document.getElementById('checkoutDiscountVal');
        
        // Show/hide discount row
        if (_appliedCoupon && discountAmt > 0) {
          discRow.classList.remove('hidden');
          discVal.textContent = '-Tk ' + discountAmt.toLocaleString();
        } else {
          discRow.classList.add('hidden');
        }
        
        if (zone) {
          delVal.textContent = 'Tk ' + deliveryFee;
          if (totalEl) totalEl.textContent = 'Tk ' + (discountedSubtotal + deliveryFee).toLocaleString();
        } else {
          delVal.textContent = 'Select zone';
          if (totalEl) totalEl.textContent = 'Tk ' + discountedSubtotal.toLocaleString();
        }

        var zoneInfo = document.getElementById('zoneInfo');
        var feeCtg = getDeliveryFee('ctg');
        var feeOut = getDeliveryFee('outside');
        if (zone === 'ctg') {
          zoneInfo.innerHTML = '📍 Inside Chittagong — <strong class="text-white">Tk ' + feeCtg + ' delivery fee</strong>. Pay full amount on delivery.';
          zoneInfo.classList.remove('hidden');
        } else if (zone === 'outside') {
          zoneInfo.innerHTML = '📍 Outside Chittagong — <strong class="text-white">Tk ' + feeOut + ' delivery fee</strong>. Advance payment required via Bkash or Nagad.';
          zoneInfo.classList.remove('hidden');
        } else {
          zoneInfo.classList.add('hidden');
        }

        var outsidePay = document.getElementById('outsidePayment');
        var insideCod = document.getElementById('insideCOD');
        if (zone === 'outside') {
          outsidePay.classList.remove('hidden');
          insideCod.classList.add('hidden');
          updatePayInstructions();
        } else if (zone === 'ctg') {
          outsidePay.classList.add('hidden');
          insideCod.classList.remove('hidden');
        } else {
          outsidePay.classList.add('hidden');
          insideCod.classList.add('hidden');
        }
      }

      function updatePayInstructions() {
        var method = document.getElementById('payMethod').value;
        var inst = document.getElementById('payInstructions');
        if (!inst) return;
        
        var subtotal = window.cart.reduce(function(s, i) { return s + (parseInt(i.price.replace(/[^0-9]/g, '')) * i.qty); }, 0);
        var discountAmt = getCouponDiscountAmount();
        var discountedSubtotal = subtotal - discountAmt;
        var feeOut = getDeliveryFee('outside');
        var totalAmount = discountedSubtotal + feeOut;

        if (method === 'bkash') {
          inst.innerHTML = 'Please send <strong class="text-white">Tk ' + totalAmount.toLocaleString() + '</strong> in advance to <strong>Bkash Merchant</strong>: <strong class="text-cyan">' + (_settings.bkash || 'Not set') + '</strong>. Then enter the Transaction ID below to confirm your order.';
        } else if (method === 'nagad') {
          inst.innerHTML = 'Please send <strong class="text-white">Tk ' + totalAmount.toLocaleString() + '</strong> in advance to <strong>Nagad Personal</strong>: <strong class="text-cyan">' + (_settings.nagad || 'Not set') + '</strong>. Then enter the Transaction ID below to confirm your order.';
        } else {
          inst.innerHTML = 'Select a payment method below to see payment instructions.';
        }
      }

      // ─── Payment Method Buttons ───
      document.addEventListener('click', function(e) {
        var btn = e.target.closest('.pay-btn');
        if (!btn) return;
        var method = btn.getAttribute('data-method');
        document.querySelectorAll('.pay-btn').forEach(function(b) { b.classList.remove('on'); });
        btn.classList.add('on');
        document.getElementById('payMethod').value = method;
        updatePayInstructions();
      });

      // ─── Coupon Apply Button ───
      document.getElementById('applyCouponBtn').onclick = async function() {
        var code = document.getElementById('couponInput').value.trim().toUpperCase();
        var statusEl = document.getElementById('couponStatus');
        if (!code) { statusEl.textContent = 'Enter a coupon code.'; statusEl.style.color = '#888'; return; }

        var btn = this;
        btn.textContent = '...';
        btn.disabled = true;

        try {
          var res = await supabaseFetch('coupons?code=eq.' + encodeURIComponent(code) + '&select=*');
          var data = await res.json();
          var coupon = Array.isArray(data) && data.length > 0 ? data[0] : null;

          if (!coupon) { statusEl.textContent = 'Invalid coupon code.'; statusEl.style.color = '#ef4444'; btn.textContent = 'Apply'; btn.disabled = false; return; }
          if (coupon.active === false) { statusEl.textContent = 'This coupon is no longer active.'; statusEl.style.color = '#ef4444'; btn.textContent = 'Apply'; btn.disabled = false; return; }
          if (coupon.expires_at && new Date(coupon.expires_at) < new Date()) { statusEl.textContent = 'This coupon has expired.'; statusEl.style.color = '#ef4444'; btn.textContent = 'Apply'; btn.disabled = false; return; }
          if (coupon.max_uses > 0 && (coupon.used_count || 0) >= coupon.max_uses) { statusEl.textContent = 'This coupon has reached its usage limit.'; statusEl.style.color = '#ef4444'; btn.textContent = 'Apply'; btn.disabled = false; return; }

          var subtotal = window.cart.reduce(function(s, i) { return s + (parseInt(i.price.replace(/[^0-9]/g, '')) * i.qty); }, 0);
          if (coupon.min_order > 0 && subtotal < coupon.min_order) {
            statusEl.textContent = 'Minimum order Tk ' + coupon.min_order + ' required for this coupon.';
            statusEl.style.color = '#ef4444'; btn.textContent = 'Apply'; btn.disabled = false; return;
          }

          // Calculate discount amount
          var discountAmt = 0;
          if (coupon.discount_type === 'percentage') {
            discountAmt = Math.round(subtotal * coupon.discount_value / 100);
          } else {
            discountAmt = Math.min(coupon.discount_value, subtotal);
          }

          _appliedCoupon = {
            code: coupon.code,
            discount_type: coupon.discount_type,
            discount_value: coupon.discount_value,
            discount_amount: discountAmt
          };

          statusEl.textContent = '✓ Coupon "' + coupon.code + '" applied! You save Tk ' + discountAmt.toLocaleString();
          statusEl.style.color = '#22c55e';
          document.getElementById('couponInput').value = coupon.code;
          document.getElementById('couponInput').disabled = true;
          btn.textContent = 'Applied';
          btn.disabled = true;
          updateCheckoutTotal();
        } catch(e) {
          statusEl.textContent = 'Error validating coupon.';
          statusEl.style.color = '#ef4444';
          btn.textContent = 'Apply';
          btn.disabled = false;
        }
      };

      // Allow removing applied coupon
      document.getElementById('couponInput').onclick = function() {
        if (_appliedCoupon) {
          _appliedCoupon = null;
          this.value = '';
          this.disabled = false;
          document.getElementById('applyCouponBtn').textContent = 'Apply';
          document.getElementById('applyCouponBtn').disabled = false;
          document.getElementById('couponStatus').textContent = '';
          updateCheckoutTotal();
        }
      };

      // ─── Delivery Zone Buttons ───
      document.addEventListener('click', function(e) {
        var btn = e.target.closest('.zone-btn');
        if (!btn) return;
        var zone = btn.getAttribute('data-zone');
        document.querySelectorAll('.zone-btn').forEach(function(b) { b.classList.remove('on'); });
        btn.classList.add('on');
        document.getElementById('deliveryZone').value = zone;
        updateCheckoutTotal();
      });

      document.getElementById('checkoutBtn').onclick = function() {
        window.closeDrawer();
        setTimeout(function() {
          renderCheckoutSummary();
          document.getElementById('deliveryZone').value = '';
          document.querySelectorAll('.zone-btn').forEach(function(b) { b.classList.remove('on'); });
          document.getElementById('payMethod').value = '';
          document.querySelectorAll('.pay-btn').forEach(function(b) { b.classList.remove('on'); });
          document.getElementById('trxId').value = '';
          // Reset coupon
          _appliedCoupon = null;
          document.getElementById('couponInput').value = '';
          document.getElementById('couponInput').disabled = false;
          document.getElementById('applyCouponBtn').textContent = 'Apply';
          document.getElementById('applyCouponBtn').disabled = false;
          document.getElementById('couponStatus').textContent = '';
          document.getElementById('checkoutDiscountRow').classList.add('hidden');
          document.getElementById('custName').value = '';
          document.getElementById('custPhone').value = '';
          document.getElementById('custAddress').value = '';
          document.getElementById('outsidePayment').classList.add('hidden');
          document.getElementById('insideCOD').classList.add('hidden');
          document.getElementById('zoneInfo').classList.add('hidden');
          toggleClass('checkoutModal', 'hidden', false);
          setTimeout(function() { toggleClass('checkoutModal', 'opacity-0', false); }, 10);
        }, 500);
      };

      document.getElementById('closeCheckout').onclick = function() {
        toggleClass('checkoutModal', 'opacity-0', true);
        setTimeout(function() { toggleClass('checkoutModal', 'hidden', true); }, 300);
      };

      // ─── Submit Order to Supabase ───
      document.getElementById('checkoutForm').onsubmit = async function(e) {
        e.preventDefault();
        var zone = document.getElementById('deliveryZone').value;
        if (!zone) { window.showToast('Please select a delivery zone first', 'warning'); return; }
        var payMethod = document.getElementById('payMethod').value;
        if (zone === 'outside' && !payMethod) { window.showToast('Please select a payment method', 'warning'); return; }
        var subtotal = window.cart.reduce(function(s, i) { return s + (parseInt(i.price.replace(/[^0-9]/g, '')) * i.qty); }, 0);
        var deliveryFee = getDeliveryFee(zone);
        var couponDiscount = getCouponDiscountAmount();
        var discountedSubtotal = subtotal - couponDiscount;
        var grandTotal = discountedSubtotal + deliveryFee;
        
        var paymentMethod = '';
        var trxId = '';
        if (zone === 'ctg') { paymentMethod = 'cod'; }
        else if (zone === 'outside') {
          paymentMethod = document.getElementById('payMethod').value;
          trxId = document.getElementById('trxId').value || 'N/A';
        }

        var orderId = Math.random().toString(36).slice(2, 9).toUpperCase();
        var order = {
          id: orderId,
          items_json: JSON.parse(JSON.stringify(window.cart)),
          subtotal: subtotal,
          delivery_fee: deliveryFee,
          coupon_code: _appliedCoupon ? _appliedCoupon.code : null,
          coupon_discount: couponDiscount || 0,
          total: grandTotal,
          zone: zone,
          customer_name: document.getElementById('custName').value,
          customer_phone: document.getElementById('custPhone').value,
          customer_address: document.getElementById('custAddress').value,
          payment_method: paymentMethod,
          payment_trxid: trxId,
          status: 'pending'
        };

        try {
          var res = await supabaseFetch('orders', {
            method: 'POST',
            headers: { 'Prefer': 'return=minimal' },
            body: JSON.stringify(order)
          });
          if (!res.ok) throw new Error('Failed');
        } catch(err) {
          var orders = JSON.parse(localStorage.getItem('jv_orders') || '[]');
          orders.unshift(order);
          localStorage.setItem('jv_orders', JSON.stringify(orders));
        }
        
        // Increment coupon usage count
        if (_appliedCoupon) {
          supabaseFetch('coupons?code=eq.' + encodeURIComponent(_appliedCoupon.code) + '&select=used_count')
            .then(function(r) { return r.json(); })
            .then(function(data) {
              if (data && data.length > 0) {
                var current = (data[0].used_count || 0) + 1;
                supabaseFetch('coupons?code=eq.' + encodeURIComponent(_appliedCoupon.code), {
                  method: 'PATCH',
                  headers: { 'Prefer': 'return=minimal' },
                  body: JSON.stringify({ used_count: current })
                }).catch(function() {});
              }
            }).catch(function() {});
        }

        window.cart = [];
        window.saveCart();
        window.showToast('Order Placed! ID: ' + orderId, 'success');
        setTimeout(function() { location.reload(); }, 1500);
      };

      window.updateUI();

      if (typeof Lenis !== 'undefined') {
        const lenis = new Lenis();
        function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
        requestAnimationFrame(raf);
      }
    </script>
  </body>
</html>
