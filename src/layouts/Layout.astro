---
import '../styles/global.css';

interface Props {
  title?: string;
}

const defaultTitle = 'BRICK RUSH - Premium Minifigures';
const { title = defaultTitle } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
    <script src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js"></script>
    <title>{title || defaultTitle}</title>
  </head>
  <body>
    <!-- ── Header Navigation ── -->
    <header class="nav-bar">
      <div class="container flex items-center justify-between w-full h-full">
        <a href="/" class="flex items-center gap-2 group">
          <span class="caption-mono text-cyan font-bold tracking-tighter">BRICK</span>
          <span class="caption-mono text-white font-bold tracking-tighter">RUSH</span>
        </a>
        
        <nav class="hidden md:flex items-center gap-1">
          <a href="/" class="nav-link active">Store</a>
          <a href="/" class="nav-link">Marvel</a>
          <a href="/" class="nav-link">DC</a>
          <a href="/" class="nav-link">Anime</a>
        </nav>

        <div class="flex items-center gap-2 sm:gap-3">
          <a href="/admin" class="nav-link hidden sm:block">Admin</a>
          <button id="navCartBtn" class="nav-link flex items-center gap-2" type="button">
            <span class="hidden sm:inline">Cart</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="sm:hidden">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0" />
            </svg>
            <span id="navCartCount" class="text-cyan font-bold">(0)</span>
          </button>
          <button id="mobileMenuToggle" class="nav-link md:hidden flex items-center justify-center p-2" type="button">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 12h18M3 6h18M3 18h18" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- ── Mobile Menu Overlay ── -->
    <div id="mobileMenu" class="fixed inset-0 z-[1500] bg-black translate-x-full transition-transform duration-500 ease-expo flex flex-col p-8 md:hidden">
      <div class="flex items-center justify-between mb-12">
        <span class="caption-mono text-cyan font-bold">Menu</span>
        <button id="closeMobileMenu" class="text-3xl text-accents-5">&times;</button>
      </div>
      <nav class="flex flex-col gap-8">
        <a href="/" class="display-lg text-white no-underline">Store</a>
        <a href="/" class="display-lg text-white no-underline">Marvel</a>
        <a href="/" class="display-lg text-white no-underline">DC</a>
        <a href="/" class="display-lg text-white no-underline">Anime</a>
        <a href="/admin" class="display-lg text-cyan no-underline">Admin Dashboard</a>
      </nav>
    </div>

    <!-- ── Sticky Cart Trigger ── -->
    <button id="stickyCart" class="sticky-cart" type="button">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0" />
      </svg>
      <span id="cartBadge" class="cart-badge hidden">0</span>
    </button>

    <!-- ── Cart Drawer ── -->
    <div id="cartOverlay" class="drawer-overlay hidden opacity-0 transition-opacity duration-300"></div>
    <div id="cartDrawer" class="drawer translate-x-full">
      <div class="flex flex-col h-full">
        <div class="p-6 border-b border-accents-2 flex items-center justify-between bg-ds-background-200">
          <h2 class="display-sm">Your Cart</h2>
          <button id="closeDrawer" class="text-3xl text-accents-5 hover:text-white transition-colors">&times;</button>
        </div>
        <div id="drawerContent" class="flex-1 overflow-y-auto p-6 scroll-smooth"></div>
        <div id="drawerFooter" class="p-6 border-t border-accents-2 bg-ds-background-200 hidden">
          <div class="flex items-center justify-between mb-6">
            <span class="text-accents-5 font-medium">Estimated Total</span>
            <span id="drawerTotal" class="display-sm text-cyan"></span>
          </div>
          <button id="checkoutBtn" class="btn-primary w-full">Proceed to Checkout</button>
        </div>
      </div>
    </div>

    <!-- ── Checkout Modal ── -->
    <div id="checkoutModal" class="modal-overlay hidden opacity-0 transition-opacity duration-300">
      <div class="modal-content card max-w-lg w-full relative">
        <button id="closeCheckout" class="absolute top-6 right-6 text-3xl text-accents-5 hover:text-white">&times;</button>
        <div class="mb-8">
          <h2 class="display-md mb-2">Checkout</h2>
          <p class="body-sm text-accents-5">Complete your order details below.</p>
        </div>
        <form id="checkoutForm" class="space-y-6">
          <div id="paymentInstructions" class="p-4 bg-cyan/5 border border-cyan/20 rounded-sm mb-6">
            <h3 class="caption-mono text-cyan text-[10px] uppercase mb-3 tracking-wider">Payment Instructions</h3>
            <div class="space-y-2">
              <div class="flex justify-between items-center">
                <span class="text-[10px] text-accents-5 uppercase">Bkash (Merchant)</span>
                <span id="dispBkash" class="text-xs font-bold text-white">Not Set</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-[10px] text-accents-5 uppercase">Nagad (Personal)</span>
                <span id="dispNagad" class="text-xs font-bold text-white">Not Set</span>
              </div>
              <div class="flex justify-between items-center border-t border-cyan/10 pt-2 mt-2">
                <span class="text-[10px] text-accents-5 uppercase">Support</span>
                <span id="dispContact" class="text-xs font-bold text-cyan">Not Set</span>
              </div>
            </div>
          </div>
          <div class="grid grid-cols-1 gap-4">
            <input type="text" id="custName" class="form-input" required placeholder="Full Name" />
            <input type="tel" id="custPhone" class="form-input" required placeholder="Phone Number" />
            <textarea id="custAddress" class="form-textarea" required placeholder="Delivery Address"></textarea>
          </div>
          <button type="submit" class="btn-primary w-full mt-4">Place Order Now</button>
        </form>
      </div>
    </div>

    <main><slot /></main>

    <script is:inline>
      // ─── Global State & Storage ───
      window.cart = [];
      try {
        window.cart = JSON.parse(localStorage.getItem('jv_cart') || '[]');
      } catch (e) { window.cart = []; }

      window.saveCart = function() {
        localStorage.setItem('jv_cart', JSON.stringify(window.cart));
        window.updateUI();
      };

      window.updateUI = function() {
        var count = window.cart.reduce((s, i) => s + (i.qty || 0), 0);
        var navCount = document.getElementById('navCartCount');
        if (navCount) navCount.textContent = '(' + count + ')';
        var badge = document.getElementById('cartBadge');
        if (badge) {
          if (count > 0) {
            badge.textContent = count;
            badge.classList.remove('hidden');
          } else {
            badge.classList.add('hidden');
          }
        }
      };

      window.addToCart = function(product) {
        if (!product || !product.name) return;
        var existing = window.cart.find(i => i.name === product.name);
        if (existing) existing.qty++;
        else window.cart.push({ ...product, qty: 1 });
        window.saveCart();
      };

      // ─── UI Helpers ───
      function toggleClass(id, cls, force) {
        var el = document.getElementById(id);
        if (el) el.classList.toggle(cls, force);
      }

      // ─── Drawer & Modal Logic ───
      window.openDrawer = function() {
        renderDrawer();
        toggleClass('cartOverlay', 'hidden', false);
        setTimeout(() => toggleClass('cartOverlay', 'opacity-0', false), 10);
        toggleClass('cartDrawer', 'translate-x-full', false);
        document.body.classList.add('modal-open');
      };

      window.closeDrawer = function() {
        toggleClass('cartDrawer', 'translate-x-full', true);
        toggleClass('cartOverlay', 'opacity-0', true);
        setTimeout(() => {
          toggleClass('cartOverlay', 'hidden', true);
          document.body.classList.remove('modal-open');
        }, 400);
      };

      function renderDrawer() {
        var content = document.getElementById('drawerContent');
        var footer = document.getElementById('drawerFooter');
        if (!content) return;
        if (window.cart.length === 0) {
          content.innerHTML = '<div class="text-center py-20 text-accents-4">Your cart is empty</div>';
          if (footer) footer.classList.add('hidden');
          return;
        }
        if (footer) footer.classList.remove('hidden');
        var total = 0;
        content.innerHTML = window.cart.map((item, i) => {
          var p = parseInt(item.price.replace(/[^0-9]/g, '')) || 0;
          total += p * item.qty;
          return `<div class="flex items-center gap-4 mb-6">
            <img src="${item.image}" class="w-16 h-16 object-contain bg-accents-1 rounded" />
            <div class="flex-1">
              <p class="text-xs font-medium text-white">${item.name}</p>
              <p class="text-[10px] text-accents-5">${item.price} x ${item.qty}</p>
            </div>
            <button onclick="window.removeItem(${i})" class="text-error text-[10px]">Remove</button>
          </div>`;
        }).join('');
        var dt = document.getElementById('drawerTotal');
        if (dt) dt.textContent = 'Tk ' + total.toLocaleString();
      }

      window.removeItem = function(i) {
        window.cart.splice(i, 1);
        window.saveCart();
        renderDrawer();
      };

      // ─── Events ───
      document.getElementById('navCartBtn').onclick = window.openDrawer;
      document.getElementById('stickyCart').onclick = window.openDrawer;
      document.getElementById('closeDrawer').onclick = window.closeDrawer;
      document.getElementById('cartOverlay').onclick = window.closeDrawer;

      document.getElementById('checkoutBtn').onclick = () => {
        window.closeDrawer();
        setTimeout(() => {
          try {
            const s = JSON.parse(localStorage.getItem('jv_settings') || '{}');
            document.getElementById('dispBkash').textContent = s.bkash || 'Not Set';
            document.getElementById('dispNagad').textContent = s.nagad || 'Not Set';
            document.getElementById('dispContact').textContent = s.contact || 'Not Set';
          } catch(e) {}
          toggleClass('checkoutModal', 'hidden', false);
          setTimeout(() => toggleClass('checkoutModal', 'opacity-0', false), 10);
        }, 500);
      };

      document.getElementById('closeCheckout').onclick = () => {
        toggleClass('checkoutModal', 'opacity-0', true);
        setTimeout(() => toggleClass('checkoutModal', 'hidden', true), 300);
      };

      document.getElementById('checkoutForm').onsubmit = (e) => {
        e.preventDefault();
        var total = window.cart.reduce((s, i) => s + (parseInt(i.price.replace(/[^0-9]/g, '')) * i.qty), 0);
        var order = {
          id: Math.random().toString(36).slice(2, 9).toUpperCase(),
          items: [...window.cart],
          total: total,
          customer: {
            name: document.getElementById('custName').value,
            phone: document.getElementById('custPhone').value,
            address: document.getElementById('custAddress').value,
          },
          status: 'pending',
          date: new Date().toISOString()
        };
        var orders = JSON.parse(localStorage.getItem('jv_orders') || '[]');
        orders.unshift(order);
        localStorage.setItem('jv_orders', JSON.stringify(orders));
        window.cart = [];
        window.saveCart();
        location.reload();
        alert('Order Placed! ID: ' + order.id);
      };

      // ─── Mobile Menu ───
      document.getElementById('mobileMenuToggle').onclick = () => toggleClass('mobileMenu', 'translate-x-full', false);
      document.getElementById('closeMobileMenu').onclick = () => toggleClass('mobileMenu', 'translate-x-full', true);

      window.updateUI();

      if (typeof Lenis !== 'undefined') {
        const lenis = new Lenis();
        function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
        requestAnimationFrame(raf);
      }
    </script>
  </body>
</html>
