---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - BRICK RUSH</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />        <style is:global>
      :root { --sidebar-width: 260px; --header-height: 60px; }
      .modal-overlay { transition: opacity 0.2s ease; }
      body { opacity: 0; transition: opacity 0.3s ease; background: var(--ds-background-100); color: var(--ds-gray-900); margin: 0; font-family: 'Inter', system-ui, -apple-system, sans-serif; }
      body.loaded { opacity: 1; }
      body.no-scroll { overflow: hidden; }
      .login-screen { position: fixed; inset: 0; z-index: 9999; display: flex; align-items: center; justify-content: center; background: var(--ds-background-100); padding: 20px; }
      .login-card { width: 100%; max-width: 400px; }
      .shell { display: flex; min-height: 100vh; }
      .sb { position: fixed; left: 0; top: 0; bottom: 0; width: var(--sidebar-width); background: #0a0a0a; border-right: 1px solid #222; z-index: 1000; display: flex; flex-direction: column; transition: transform 0.3s ease; }
      @media (max-width: 1024px) { .sb { transform: translateX(-100%); } .sb.open { transform: translateX(0); } }
      .sb-hd { height: var(--header-height); display: flex; align-items: center; padding: 0 20px; gap: 12px; border-bottom: 1px solid #222; }
      .sb-nav { flex: 1; padding: 20px 10px; display: flex; flex-direction: column; gap: 2px; }
      .sb-lk { display: flex; align-items: center; gap: 12px; padding: 10px 14px; color: #888; border-radius: 8px; transition: all 0.2s ease; font-size: 14px; font-weight: 500; border: none; background: transparent; cursor: pointer; width: 100%; text-align: left; }
      .sb-lk:hover { background: #111; color: #fff; }          .sb-lk.on { color: #50e3c2; background: rgba(80,227,194,0.1); }
          .sb-ft { padding: 14px; border-top: 1px solid #222; }
          .toast { pointer-events: auto; padding: 14px 24px; border-radius: 12px; font-size: 14px; font-weight: 500; text-align: center; animation: toastIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards; box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.05); backdrop-filter: blur(12px); max-width: 400px; min-width: 200px; }
          .toast.success { background: rgba(34,197,94,0.15); color: #22c55e; border: 1px solid rgba(34,197,94,0.3); }
          .toast.error { background: rgba(239,68,68,0.15); color: #ef4444; border: 1px solid rgba(239,68,68,0.3); }
          .toast.info { background: rgba(80,227,194,0.15); color: #50e3c2; border: 1px solid rgba(80,227,194,0.3); }
          .toast.warning { background: rgba(245,166,35,0.15); color: #f5a623; border: 1px solid rgba(245,166,35,0.3); }
          @keyframes toastIn { from { opacity: 0; transform: translateY(20px) scale(0.95); } to { opacity: 1; transform: translateY(0) scale(1); } }
          @keyframes toastOut { from { opacity: 1; transform: translateY(0) scale(1); } to { opacity: 0; transform: translateY(-10px) scale(0.95); } }
      .mw { flex: 1; display: flex; flex-direction: column; }
      @media (min-width: 1025px) { .mw { padding-left: var(--sidebar-width); } .ham { display: none; } }
      .tb { height: var(--header-height); background: #000; border-bottom: 1px solid #222; display: flex; align-items: center; justify-content: space-between; padding: 0 12px; position: sticky; top: 0; z-index: 900; }
      @media (min-width: 640px) { .tb { padding: 0 20px; } }
      .mc { padding: 16px; max-width: 960px; margin: 0 auto; width: 100%; }
      @media (min-width: 640px) { .mc { padding: 24px 28px; } }
      @media (min-width: 1025px) { .mc { padding: 28px 20px; } }
      .ham { background: transparent; border: none; color: #fff; cursor: pointer; padding: 10px; border-radius: 6px; display: flex; min-width: 44px; min-height: 44px; align-items: center; justify-content: center; }
      .ham:hover { background: #111; }
      .ham svg { width: 20px; height: 20px; }
      .ol { position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 999; display: none; }
      .ol.on { display: block; }
      .stats { display: grid; grid-template-columns: 1fr; gap: 10px; margin-bottom: 20px; }
      @media (min-width: 480px) { .stats { grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 24px; } }
      .stat { background: #0a0a0a; border: 1px solid #222; border-radius: 14px; padding: 16px; display: flex; align-items: center; gap: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.3); }
      @media (min-width: 640px) { .stat { padding: 22px; gap: 16px; } }
      .stat-i { width: 44px; height: 44px; border-radius: 12px; background: rgba(80,227,194,0.08); border: 1px solid rgba(80,227,194,0.12); display: flex; align-items: center; justify-content: center; color: #50e3c2; flex-shrink: 0; }
      .stat-l { font-size: 10px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.1em; color: #888; margin-bottom: 4px; }
      .stat-v { font-size: 22px; font-weight: 700; color: #fff; }
      .cl { display: flex; flex-direction: column; gap: 10px; }
      @media (min-width: 640px) { .cl { gap: 12px; } }
      .oc { background: #0a0a0a; border: 1px solid #1a1a1a; border-radius: 12px; padding: 14px; display: flex; flex-direction: column; gap: 12px; transition: all 0.25s ease; box-shadow: 0 2px 12px rgba(0,0,0,0.2); }
      @media (min-width: 640px) { .oc { padding: 20px 22px; border-radius: 14px; gap: 14px; } }
      .oc:hover { border-color: #333; box-shadow: 0 8px 30px rgba(0,0,0,0.4); transform: translateY(-1px); }
      .oc-top { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
      .oc-id { font-family: 'JetBrains Mono', monospace; font-size: 12px; font-weight: 700; color: #fff; letter-spacing: -0.02em; }
      @media (min-width: 640px) { .oc-id { font-size: 13px; } }
      .oc-body { display: grid; grid-template-columns: 1fr; gap: 12px; }
      @media (min-width: 640px) { .oc-body { grid-template-columns: 1fr 1fr; gap: 16px; } }
      .oc-f { display: flex; flex-direction: column; gap: 3px; }
      .oc-fl { font-size: 9px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.1em; color: #666; }
      .oc-fv { font-size: 13px; color: #eaeaea; font-weight: 500; }
      .oc-fv.m { color: #50e3c2; font-weight: 700; font-size: 15px; }
      .oc-btm { display: flex; align-items: center; justify-content: space-between; gap: 8px; padding-top: 12px; border-top: 1px solid #1a1a1a; flex-wrap: wrap; }
      @media (min-width: 640px) { .oc-btm { gap: 12px; padding-top: 14px; flex-wrap: nowrap; } }
      .sbad { display: inline-flex; align-items: center; gap: 5px; padding: 4px 12px 4px 8px; border-radius: 100px; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; white-space: nowrap; }
      @media (min-width: 640px) { .sbad { padding: 4px 14px 4px 10px; font-size: 10px; gap: 6px; } }
      .sbad::before { content: ''; width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
      .sbad.pending { background: rgba(245,166,35,0.12); color: #f5a623; box-shadow: inset 0 0 0 1px rgba(245,166,35,0.15); }
      .sbad.pending::before { background: #f5a623; }
      .sbad.process { background: rgba(80,227,194,0.12); color: #50e3c2; box-shadow: inset 0 0 0 1px rgba(80,227,194,0.15); }
      .sbad.process::before { background: #50e3c2; }
      .sbad.done { background: rgba(34,197,94,0.12); color: #22c55e; box-shadow: inset 0 0 0 1px rgba(34,197,94,0.15); }
      .sbad.done::before { background: #22c55e; }
      .sbad.cancelled { background: rgba(239,68,68,0.12); color: #ef4444; box-shadow: inset 0 0 0 1px rgba(239,68,68,0.15); }
      .sbad.cancelled::before { background: #ef4444; }
      .pc { background: #0a0a0a; border: 1px solid #1a1a1a; border-radius: 12px; padding: 12px; display: grid; grid-template-columns: 56px 1fr; grid-template-areas: "img info" "price acts"; gap: 10px; align-items: center; transition: all 0.25s ease; box-shadow: 0 2px 12px rgba(0,0,0,0.2); }
      .pc:hover { border-color: #333; box-shadow: 0 8px 30px rgba(0,0,0,0.4); transform: translateY(-1px); }
      .pc-img { grid-area: img; width: 56px; height: 68px; border-radius: 8px; object-fit: contain; background: #111; border: 1px solid #222; flex-shrink: 0; }
      .pc-info { grid-area: info; min-width: 0; }
      .pc-name { font-size: 13px; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      @media (min-width: 640px) { .pc-name { font-size: 14px; } }
      .pc-cat { display: inline-flex; padding: 3px 8px; border-radius: 6px; font-size: 9px; font-weight: 600; background: #111; color: #888; border: 1px solid #222; margin-top: 4px; }
      @media (min-width: 640px) { .pc-cat { padding: 3px 10px; font-size: 10px; margin-top: 5px; } }
      .pc-price { grid-area: price; font-size: 14px; font-weight: 700; color: #50e3c2; white-space: nowrap; letter-spacing: -0.01em; justify-self: start; }
      @media (min-width: 640px) { .pc-price { font-size: 15px; } }
      .pc-price.sold { font-size: 12px; }
      @media (min-width: 640px) { .pc-price.sold { font-size: 13px; } }
      .pc-old { font-size: 10px; color: #666; text-decoration: line-through; margin-left: 6px; }
      @media (min-width: 640px) { .pc-old { font-size: 11px; margin-left: 8px; } }
      .pc-acts { grid-area: acts; display: flex; gap: 6px; flex-shrink: 0; justify-self: end; align-items: center; }
      @media (min-width: 640px) {
        .pc { display: flex; align-items: center; gap: 18px; padding: 18px 22px; border-radius: 14px; grid-template-columns: none; }
        .pc-img { width: 48px; height: 60px; }
        .pc-info { flex: 1; }
        .pc-price { justify-self: unset; }
        .pc-acts { justify-self: unset; }
      }
      .btn-sm { display: inline-flex; align-items: center; gap: 4px; padding: 8px 14px; border-radius: 8px; font-size: 11px; font-weight: 600; border: none; cursor: pointer; transition: all 0.15s ease; background: #111; color: #888; min-height: 32px; }
      @media (min-width: 640px) { .btn-sm { padding: 7px 16px; min-height: unset; } }
      .btn-sm:hover { background: #1a1a1a; color: #fff; }
      .btn-sm.danger { color: #ef4444; }
      .btn-sm.danger:hover { background: rgba(239,68,68,0.1); }
      .btn-sm.cyan { color: #50e3c2; }
      .btn-sm.cyan:hover { background: rgba(80,227,194,0.1); }
      .cc { background: #0a0a0a; border: 1px solid #1a1a1a; border-radius: 12px; padding: 14px 16px; display: flex; align-items: center; justify-content: space-between; transition: all 0.25s ease; box-shadow: 0 2px 12px rgba(0,0,0,0.2); }
      .cc:hover { border-color: #333; box-shadow: 0 8px 30px rgba(0,0,0,0.4); transform: translateY(-1px); }
      .cc-l { display: flex; align-items: center; gap: 12px; }
      @media (min-width: 640px) { .cc-l { gap: 14px; } }
      .cc-i { width: 36px; height: 36px; border-radius: 10px; background: rgba(80,227,194,0.08); border: 1px solid rgba(80,227,194,0.12); display: flex; align-items: center; justify-content: center; color: #50e3c2; font-size: 13px; font-weight: 700; flex-shrink: 0; }
      @media (min-width: 640px) { .cc-i { width: 38px; height: 38px; font-size: 14px; } }
      .cc-n { font-size: 13px; font-weight: 500; color: #eaeaea; }
      @media (min-width: 640px) { .cc-n { font-size: 14px; } }
      .empty { text-align: center; padding: 48px 16px; color: #666; }
      @media (min-width: 640px) { .empty { padding: 64px 20px; } }
      .empty-e { font-size: 28px; display: block; margin-bottom: 10px; opacity: 0.5; }
      @media (min-width: 640px) { .empty-e { font-size: 32px; margin-bottom: 12px; } }
      .empty-t { font-size: 12px; font-style: italic; }
      @media (min-width: 640px) { .empty-t { font-size: 14px; } }
      .cc-grid { display: grid; grid-template-columns: 1fr; gap: 10px; }
      @media (min-width: 540px) { .cc-grid { grid-template-columns: 1fr 1fr; gap: 12px; } }
      @media (min-width: 768px) { .cc-grid { grid-template-columns: 1fr 1fr 1fr; } }
      .set { background: #0a0a0a; border: 1px solid #222; border-radius: 12px; padding: 16px; max-width: 560px; box-shadow: 0 4px 20px rgba(0,0,0,0.3); }
      @media (min-width: 640px) { .set { padding: 28px; border-radius: 14px; } }
      .tab { display: none; }
      .tab.on { display: block; }
      .status-select { background: transparent; border: 1px solid #333; border-radius: 6px; color: #fff; padding: 6px 10px; font-size: 11px; cursor: pointer; outline: none; min-height: 32px; }
      @media (min-width: 640px) { .status-select { padding: 4px 10px; min-height: unset; } }
      .status-select:focus { border-color: #50e3c2; }
      /* ── Bottom Nav ── */
      .bn { display: none; }
      @media (max-width: 1024px) {
        .bn {
          display: flex;
          position: fixed;
          bottom: 0;
          left: 0;
          right: 0;
          z-index: 998;
          height: 56px;
          padding-bottom: env(safe-area-inset-bottom, 0);
          background: #0a0a0a;
          border-top: 1px solid #222;
          align-items: center;
          justify-content: space-around;
        }
        .bn-lk {
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          gap: 2px;
          padding: 4px 6px;
          min-width: 48px;
          min-height: 44px;
          border: none;
          background: transparent;
          color: #555;
          cursor: pointer;
          border-radius: 8px;
          transition: all 0.2s ease;
          -webkit-tap-highlight-color: transparent;
        }
        .bn-lk.on {
          color: #50e3c2;
        }
        .bn-lk:active {
          background: rgba(80,227,194,0.08);
        }
        .bn-lk svg {
          width: 20px;
          height: 20px;
        }
        .bn-lk span {
          font-size: 8px;
          font-weight: 600;
          text-transform: uppercase;
          letter-spacing: 0.08em;
        }
        /* Add padding to main content to account for bottom nav */
        .mc {
          padding-bottom: calc(56px + env(safe-area-inset-bottom, 0) + 16px);
        }
      }
      @media (max-width: 1024px) {
        /* Move toasts above bottom nav on mobile */
        #toastContainer {
          bottom: calc(64px + env(safe-area-inset-bottom, 0)) !important;
        }
      }
      .confirm-modal .confirm-icon {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        background: rgba(239,68,68,0.1);
        border: 1px solid rgba(239,68,68,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ef4444;
        flex-shrink: 0;
      }
      .btn-danger {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 0 24px;
        border-radius: 100px;
        font-size: 14px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: all 0.2s ease;
        background: #ef4444;
        color: #fff;
        white-space: nowrap;
      }
      .btn-danger:hover {
        background: #dc2626;
        box-shadow: 0 0 24px rgba(239,68,68,0.3);
      }
      .btn-danger:active {
        transform: scale(0.97);
      }
    </style>
  </head>
  <body>
    <div id="toastContainer" style="position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:9999;display:flex;flex-direction:column;gap:8px;pointer-events:none;width:auto;max-width:90vw;"></div>
    <div id="ol" class="ol"></div>
    <div id="loginScreen" class="login-screen">
      <div class="login-card card animate-fade-in">
        <div class="mb-8 text-center">
          <div class="flex items-center justify-center gap-2 mb-4">
             <span class="caption-mono text-cyan font-bold text-2xl">BRICK</span>
             <span class="caption-mono text-white font-bold text-2xl">RUSH</span>
          </div>
          <h1 class="display-sm">Command Center</h1>
          <p class="body-sm text-accents-5">Encrypted Access Only</p>
        </div>
        <form id="loginForm" class="space-y-4">
          <div><label class="caption-mono text-accents-5 mb-2 block text-[10px]">Security Identifier</label><input type="text" id="user" class="form-input" placeholder="admin" required /></div>
          <div><label class="caption-mono text-accents-5 mb-2 block text-[10px]">Access Key</label><input type="password" id="pass" class="form-input" placeholder="••••••••" required /></div>
          <button type="submit" class="btn-primary w-full mt-6">Authorize Protocol</button>
        </form>
      </div>
    </div>

    <div id="dash" class="shell" style="display:none;">
      <aside id="sb" class="sb">
        <div class="sb-hd">
          <div class="w-8 h-8 bg-cyan rounded-md flex items-center justify-center text-black font-bold text-lg shrink-0">B</div>
          <span class="font-bold text-lg tracking-tight">BRICK<span class="text-cyan">RUSH</span></span>
        </div>
        <nav class="sb-nav">
          <button class="sb-lk on" data-tab="ordersTab"><span>📦</span><span>Orders</span></button>
          <button class="sb-lk" data-tab="invTab"><span>🛡️</span><span>Products</span></button>
          <button class="sb-lk" data-tab="catTab"><span>🏷️</span><span>Categories</span></button>
          <button class="sb-lk" data-tab="couponTab"><span>🎟️</span><span>Coupons</span></button>
          <button class="sb-lk" data-tab="setTab"><span>⚙️</span><span>Settings</span></button>
          <a href="/" class="sb-lk" style="margin-top:16px;color:var(--cyan);">🏠 Back to Home</a>
        </nav>
        <div class="sb-ft"><button id="logoutBtn" class="sb-lk" style="color:#ef4444;">🚪 Logout</button></div>
      </aside>

      <div class="mw">
        <header class="tb">
          <div class="flex items-center gap-3">
            <button id="hamBtn" class="ham"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg></button>
            <h2 id="pgTitle" class="text-sm font-semibold text-accents-5 uppercase tracking-widest">Orders</h2>
          </div>
          <div class="flex items-center gap-2 px-3 py-1 bg-cyan-soft border border-cyan/20 rounded-full"><span class="w-2 h-2 bg-cyan rounded-full animate-pulse"></span><span class="text-[10px] font-bold text-cyan uppercase tracking-tighter">Live</span></div>
        </header>

        <main class="mc">
          <section id="ordersTab" class="tab on">
            <div class="flex items-center justify-between gap-4 mb-6">
              <div><h2 class="display-md mb-1">Order Pipeline</h2><p class="body-sm text-accents-5">Monitor incoming orders.</p></div>
              <button onclick="window.clearOrders()" class="btn-sm danger">Wipe All</button>
            </div>
            <div class="stats">
              <div class="stat">
                <div class="stat-i"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10M18 20V4M6 20v-4"/></svg></div>
                <div><div class="stat-l">Revenue</div><div id="statRev" class="stat-v">Tk 0</div></div>
              </div>
              <div class="stat">
                <div class="stat-i"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/></svg></div>
                <div><div class="stat-l">Orders</div><div id="statOrd" class="stat-v">0</div></div>
              </div>
            </div>
            <div class="cl" id="ordersBody"></div>
          </section>

          <section id="invTab" class="tab">
            <div class="flex items-center justify-between gap-4 mb-6 flex-wrap">
              <div><h2 class="display-md mb-1">Product Inventory</h2><p class="body-sm text-accents-5">Manage your collection.</p></div>
              <div class="flex gap-2">
                <button onclick="window.showProductModal()" class="btn-sm cyan" style="background:var(--cyan-soft);">+ Add Product</button>
              </div>
            </div>
            <div class="cl" id="invBody"></div>
          </section>

          <section id="catTab" class="tab">
            <div class="flex items-center justify-between gap-4 mb-6 flex-wrap">
              <div><h2 class="display-md mb-1">Categories</h2><p class="body-sm text-accents-5">Organize your store.</p></div>
              <form id="catForm" class="flex gap-2"><input type="text" id="catInp" class="form-input !h-9 !px-4 !text-xs" placeholder="New category..." required /><button type="submit" class="btn-sm cyan" style="background:var(--cyan-soft);">Add</button></form>
            </div>
            <div class="cc-grid" id="catList"></div>
          </section>

          <section id="couponTab" class="tab">
            <div class="flex items-center justify-between gap-4 mb-6 flex-wrap">
              <div><h2 class="display-md mb-1">Coupons</h2><p class="body-sm text-accents-5">Manage discount codes.</p></div>
              <button onclick="window.showCouponModal()" class="btn-sm cyan" style="background:var(--cyan-soft);">+ New Coupon</button>
            </div>
            <div id="couponList" class="cl"></div>
          </section>

          <section id="setTab" class="tab">
            <div class="mb-6"><h2 class="display-md mb-1">System Settings</h2><p class="body-sm text-accents-5">Configure store parameters.</p></div>
            <div class="set">
              <form id="setForm" class="space-y-6">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
