---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - BRICK RUSH</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
    <style is:global>
      :root { --sidebar-width: 260px; --header-height: 60px; }
      body { opacity: 0; transition: opacity 0.3s ease; background: var(--ds-background-100); color: var(--ds-gray-900); margin: 0; font-family: 'Inter', system-ui, -apple-system, sans-serif; }
      body.loaded { opacity: 1; }
      body.no-scroll { overflow: hidden; }
      .login-screen { position: fixed; inset: 0; z-index: 9999; display: flex; align-items: center; justify-content: center; background: var(--ds-background-100); padding: 20px; }
      .login-card { width: 100%; max-width: 400px; }
      .shell { display: flex; min-height: 100vh; }
      .sb { position: fixed; left: 0; top: 0; bottom: 0; width: var(--sidebar-width); background: #0a0a0a; border-right: 1px solid #222; z-index: 1000; display: flex; flex-direction: column; transition: transform 0.3s ease; }
      @media (max-width: 1024px) { .sb { transform: translateX(-100%); } .sb.open { transform: translateX(0); } }
      .sb-hd { height: var(--header-height); display: flex; align-items: center; padding: 0 20px; gap: 12px; border-bottom: 1px solid #222; }
      .sb-nav { flex: 1; padding: 20px 10px; display: flex; flex-direction: column; gap: 2px; }
      .sb-lk { display: flex; align-items: center; gap: 12px; padding: 10px 14px; color: #888; border-radius: 8px; transition: all 0.2s ease; font-size: 14px; font-weight: 500; border: none; background: transparent; cursor: pointer; width: 100%; text-align: left; }
      .sb-lk:hover { background: #111; color: #fff; }          .sb-lk.on { color: #50e3c2; background: rgba(80,227,194,0.1); }
          .sb-ft { padding: 14px; border-top: 1px solid #222; }
          .toast { pointer-events: auto; padding: 14px 24px; border-radius: 12px; font-size: 14px; font-weight: 500; text-align: center; animation: toastIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards; box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.05); backdrop-filter: blur(12px); max-width: 400px; min-width: 200px; }
          .toast.success { background: rgba(34,197,94,0.15); color: #22c55e; border: 1px solid rgba(34,197,94,0.3); }
          .toast.error { background: rgba(239,68,68,0.15); color: #ef4444; border: 1px solid rgba(239,68,68,0.3); }
          .toast.info { background: rgba(80,227,194,0.15); color: #50e3c2; border: 1px solid rgba(80,227,194,0.3); }
          .toast.warning { background: rgba(245,166,35,0.15); color: #f5a623; border: 1px solid rgba(245,166,35,0.3); }
          @keyframes toastIn { from { opacity: 0; transform: translateY(20px) scale(0.95); } to { opacity: 1; transform: translateY(0) scale(1); } }
          @keyframes toastOut { from { opacity: 1; transform: translateY(0) scale(1); } to { opacity: 0; transform: translateY(-10px) scale(0.95); } }
      .mw { flex: 1; display: flex; flex-direction: column; }
      @media (min-width: 1025px) { .mw { padding-left: var(--sidebar-width); } .ham { display: none; } }
      .tb { height: var(--header-height); background: #000; border-bottom: 1px solid #222; display: flex; align-items: center; justify-content: space-between; padding: 0 20px; position: sticky; top: 0; z-index: 900; }
      .mc { padding: 28px 20px; max-width: 960px; margin: 0 auto; width: 100%; }
      .ham { background: transparent; border: none; color: #fff; cursor: pointer; padding: 8px; border-radius: 6px; display: flex; }
      .ham:hover { background: #111; }
      .ol { position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 999; display: none; }
      .ol.on { display: block; }
      .stats { display: grid; grid-template-columns: 1fr; gap: 14px; margin-bottom: 24px; }
      @media (min-width: 480px) { .stats { grid-template-columns: 1fr 1fr; } }
      .stat { background: #0a0a0a; border: 1px solid #222; border-radius: 14px; padding: 22px; display: flex; align-items: center; gap: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.3); }
      .stat-i { width: 44px; height: 44px; border-radius: 12px; background: rgba(80,227,194,0.08); border: 1px solid rgba(80,227,194,0.12); display: flex; align-items: center; justify-content: center; color: #50e3c2; flex-shrink: 0; }
      .stat-l { font-size: 10px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.1em; color: #888; margin-bottom: 4px; }
      .stat-v { font-size: 22px; font-weight: 700; color: #fff; }
      .cl { display: flex; flex-direction: column; gap: 12px; }
      .oc { background: #0a0a0a; border: 1px solid #1a1a1a; border-radius: 14px; padding: 20px 22px; display: flex; flex-direction: column; gap: 14px; transition: all 0.25s ease; box-shadow: 0 2px 12px rgba(0,0,0,0.2); }
      .oc:hover { border-color: #333; box-shadow: 0 8px 30px rgba(0,0,0,0.4); transform: translateY(-1px); }
      .oc-top { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
      .oc-id { font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 700; color: #fff; letter-spacing: -0.02em; }
      .oc-body { display: grid; grid-template-columns: 1fr; gap: 16px; }
      @media (min-width: 640px) { .oc-body { grid-template-columns: 1fr 1fr; } }
      .oc-f { display: flex; flex-direction: column; gap: 3px; }
      .oc-fl { font-size: 9px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.1em; color: #666; }
      .oc-fv { font-size: 13px; color: #eaeaea; font-weight: 500; }
      .oc-fv.m { color: #50e3c2; font-weight: 700; font-size: 15px; }
      .oc-btm { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding-top: 14px; border-top: 1px solid #1a1a1a; }
      .sbad { display: inline-flex; align-items: center; gap: 6px; padding: 4px 14px 4px 10px; border-radius: 100px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; white-space: nowrap; }
      .sbad::before { content: ''; width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
      .sbad.pending { background: rgba(245,166,35,0.12); color: #f5a623; box-shadow: inset 0 0 0 1px rgba(245,166,35,0.15); }
      .sbad.pending::before { background: #f5a623; }
      .sbad.process { background: rgba(80,227,194,0.12); color: #50e3c2; box-shadow: inset 0 0 0 1px rgba(80,227,194,0.15); }
      .sbad.process::before { background: #50e3c2; }
      .sbad.done { background: rgba(34,197,94,0.12); color: #22c55e; box-shadow: inset 0 0 0 1px rgba(34,197,94,0.15); }
      .sbad.done::before { background: #22c55e; }
      .sbad.cancelled { background: rgba(239,68,68,0.12); color: #ef4444; box-shadow: inset 0 0 0 1px rgba(239,68,68,0.15); }
      .sbad.cancelled::before { background: #ef4444; }
      .pc { background: #0a0a0a; border: 1px solid #1a1a1a; border-radius: 14px; padding: 14px; display: grid; grid-template-columns: 48px 1fr; grid-template-areas: "img info" "price acts"; gap: 12px; align-items: center; transition: all 0.25s ease; box-shadow: 0 2px 12px rgba(0,0,0,0.2); }
      .pc:hover { border-color: #333; box-shadow: 0 8px 30px rgba(0,0,0,0.4); transform: translateY(-1px); }
      .pc-img { grid-area: img; width: 48px; height: 60px; border-radius: 8px; object-fit: contain; background: #111; border: 1px solid #222; flex-shrink: 0; }
      .pc-info { grid-area: info; min-width: 0; }
      .pc-name { font-size: 14px; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .pc-cat { display: inline-flex; padding: 3px 10px; border-radius: 6px; font-size: 10px; font-weight: 600; background: #111; color: #888; border: 1px solid #222; margin-top: 5px; }
      .pc-price { grid-area: price; font-size: 15px; font-weight: 700; color: #50e3c2; white-space: nowrap; letter-spacing: -0.01em; justify-self: start; }
      .pc-price.sold { font-size: 13px; }
      .pc-old { font-size: 11px; color: #666; text-decoration: line-through; margin-left: 8px; }
      .pc-acts { grid-area: acts; display: flex; gap: 6px; flex-shrink: 0; justify-self: end; }
      @media (min-width: 640px) {
        .pc { display: flex; align-items: center; gap: 18px; padding: 18px 22px; }
        .pc-info { flex: 1; }
        .pc-price { justify-self: unset; }
        .pc-acts { justify-self: unset; }
      }
      .btn-sm { display: inline-flex; align-items: center; gap: 4px; padding: 7px 16px; border-radius: 8px; font-size: 11px; font-weight: 600; border: none; cursor: pointer; transition: all 0.15s ease; background: #111; color: #888; }
      .btn-sm:hover { background: #1a1a1a; color: #fff; }
      .btn-sm.danger { color: #ef4444; }
      .btn-sm.danger:hover { background: rgba(239,68,68,0.1); }
      .btn-sm.cyan { color: #50e3c2; }
      .btn-sm.cyan:hover { background: rgba(80,227,194,0.1); }
      .cc { background: #0a0a0a; border: 1px solid #1a1a1a; border-radius: 14px; padding: 18px 20px; display: flex; align-items: center; justify-content: space-between; transition: all 0.25s ease; box-shadow: 0 2px 12px rgba(0,0,0,0.2); }
      .cc:hover { border-color: #333; box-shadow: 0 8px 30px rgba(0,0,0,0.4); transform: translateY(-1px); }
      .cc-l { display: flex; align-items: center; gap: 14px; }
      .cc-i { width: 38px; height: 38px; border-radius: 10px; background: rgba(80,227,194,0.08); border: 1px solid rgba(80,227,194,0.12); display: flex; align-items: center; justify-content: center; color: #50e3c2; font-size: 14px; font-weight: 700; flex-shrink: 0; }
      .cc-n { font-size: 14px; font-weight: 500; color: #eaeaea; }
      .empty { text-align: center; padding: 64px 20px; color: #666; }
      .empty-e { font-size: 32px; display: block; margin-bottom: 12px; opacity: 0.5; }
      .empty-t { font-size: 14px; font-style: italic; }
      .cc-grid { display: grid; grid-template-columns: 1fr; gap: 12px; }
      @media (min-width: 540px) { .cc-grid { grid-template-columns: 1fr 1fr; } }
      @media (min-width: 768px) { .cc-grid { grid-template-columns: 1fr 1fr 1fr; } }
      .set { background: #0a0a0a; border: 1px solid #222; border-radius: 14px; padding: 16px; max-width: 560px; box-shadow: 0 4px 20px rgba(0,0,0,0.3); }
      @media (min-width: 640px) { .set { padding: 28px; } }
      .tab { display: none; }
      .tab.on { display: block; }
      .status-select { background: transparent; border: 1px solid #333; border-radius: 6px; color: #fff; padding: 4px 10px; font-size: 11px; cursor: pointer; outline: none; }
      .status-select:focus { border-color: #50e3c2; }
      @keyframes dashSpin { to { transform: rotate(360deg); } }
    </style>
  </head>
  <body>
    <div id="toastContainer" style="position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:9999;display:flex;flex-direction:column;gap:8px;pointer-events:none;width:auto;max-width:90vw;"></div>
    <div id="ol" class="ol"></div>
    <div id="loginScreen" class="login-screen">
      <div class="login-card card animate-fade-in">
        <div class="mb-8 text-center">
          <div class="flex items-center justify-center gap-2 mb-4">
             <span class="caption-mono text-cyan font-bold text-2xl">BRICK</span>
             <span class="caption-mono text-white font-bold text-2xl">RUSH</span>
          </div>
          <h1 class="display-sm">Command Center</h1>
          <p class="body-sm text-accents-5">Encrypted Access Only</p>
        </div>
        <form id="loginForm" class="space-y-4">
          <div><label class="caption-mono text-accents-5 mb-2 block text-[10px]">Security Identifier</label><input type="text" id="user" class="form-input" placeholder="admin" required /></div>
          <div><label class="caption-mono text-accents-5 mb-2 block text-[10px]">Access Key</label><input type="password" id="pass" class="form-input" placeholder="••••••••" required /></div>
          <button type="submit" class="btn-primary w-full mt-6">Authorize Protocol</button>
        </form>
      </div>
    </div>

    <div id="dash" class="shell" style="display:none;">
      <aside id="sb" class="sb">
        <div class="sb-hd">
          <div class="w-8 h-8 bg-cyan rounded-md flex items-center justify-center text-black font-bold text-lg shrink-0">B</div>
          <span class="font-bold text-lg tracking-tight">BRICK<span class="text-cyan">RUSH</span></span>
        </div>
        <nav class="sb-nav">
          <button class="sb-lk on" data-tab="ordersTab"><span>📦</span><span>Orders</span></button>
          <button class="sb-lk" data-tab="invTab"><span>🛡️</span><span>Products</span></button>
          <button class="sb-lk" data-tab="catTab"><span>🏷️</span><span>Categories</span></button>
          <button class="sb-lk" data-tab="setTab"><span>⚙️</span><span>Settings</span></button>
          <a href="/" class="sb-lk" style="margin-top:16px;color:var(--cyan);">🏠 Back to Home</a>
        </nav>
        <div class="sb-ft"><button id="logoutBtn" class="sb-lk" style="color:#ef4444;">🚪 Logout</button></div>
      </aside>

      <div class="mw">
        <header class="tb">
          <div class="flex items-center gap-3">
            <button id="hamBtn" class="ham"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg></button>
            <h2 id="pgTitle" class="text-sm font-semibold text-accents-5 uppercase tracking-widest">Orders</h2>
          </div>
          <div class="flex items-center gap-2 px-3 py-1 bg-cyan-soft border border-cyan/20 rounded-full"><span class="w-2 h-2 bg-cyan rounded-full animate-pulse"></span><span class="text-[10px] font-bold text-cyan uppercase tracking-tighter">Live</span></div>
        </header>

        <main class="mc">
          <section id="ordersTab" class="tab on">
            <div class="flex items-center justify-between gap-4 mb-6">
              <div><h2 class="display-md mb-1">Order Pipeline</h2><p class="body-sm text-accents-5">Monitor incoming orders.</p></div>
              <button onclick="window.clearOrders()" class="btn-sm danger">Wipe All</button>
            </div>
            <div class="stats">
              <div class="stat">
                <div class="stat-i"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10M18 20V4M6 20v-4"/></svg></div>
                <div><div class="stat-l">Revenue</div><div id="statRev" class="stat-v">Tk 0</div></div>
              </div>
              <div class="stat">
                <div class="stat-i"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/></svg></div>
                <div><div class="stat-l">Orders</div><div id="statOrd" class="stat-v">0</div></div>
              </div>
            </div>
            <div class="cl" id="ordersBody"></div>
          </section>

          <section id="invTab" class="tab">
            <div class="flex items-center justify-between gap-4 mb-6 flex-wrap">
              <div><h2 class="display-md mb-1">Product Inventory</h2><p class="body-sm text-accents-5">Manage your collection.</p></div>
              <div class="flex gap-2">
                <button onclick="window.showProductModal()" class="btn-sm cyan" style="background:var(--cyan-soft);">+ Add Product</button>
              </div>
            </div>
            <div class="cl" id="invBody"></div>
          </section>

          <section id="catTab" class="tab">
            <div class="flex items-center justify-between gap-4 mb-6 flex-wrap">
              <div><h2 class="display-md mb-1">Categories</h2><p class="body-sm text-accents-5">Organize your store.</p></div>
              <form id="catForm" class="flex gap-2"><input type="text" id="catInp" class="form-input !h-9 !px-4 !text-xs" placeholder="New category..." required /><button type="submit" class="btn-sm cyan" style="background:var(--cyan-soft);">Add</button></form>
            </div>
            <div class="cc-grid" id="catList"></div>
          </section>

          <section id="setTab" class="tab">
            <div class="mb-6"><h2 class="display-md mb-1">System Settings</h2><p class="body-sm text-accents-5">Configure store parameters.</p></div>
            <div class="set">
              <form id="setForm" class="space-y-6">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                  <div><label class="caption-mono text-accents-5 mb-2 block text-[10px]">Support Contact</label><input type="text" id="fContact" class="form-input" placeholder="+8801XXXXXXXXX" /></div>
                  <div><label class="caption-mono text-accents-5 mb-2 block text-[10px]">Bkash Merchant</label><input type="text" id="fBkash" class="form-input" placeholder="01XXXXXXXXX" /></div>
                  <div><label class="caption-mono text-accents-5 mb-2 block text-[10px]">Nagad Personal</label><input type="text" id="fNagad" class="form-input" placeholder="01XXXXXXXXX" /></div>
                  <div><label class="caption-mono text-accents-5 mb-2 block text-[10px]">Facebook Page Link</label><input type="url" id="fFacebook" class="form-input" placeholder="https://facebook.com/yourpage" /></div>
                  <div><label class="caption-mono text-accents-5 mb-2 block text-[10px]">Instagram Link</label><input type="url" id="fInstagram" class="form-input" placeholder="https://instagram.com/yourpage" /></div>
                  <div><label class="caption-mono text-accents-5 mb-2 block text-[10px]">Delivery Fee — Inside CTG</label><input type="number" id="fFeeCtg" class="form-input" placeholder="70" min="0" /></div>
                  <div><label class="caption-mono text-accents-5 mb-2 block text-[10px]">Delivery Fee — Outside CTG</label><input type="number" id="fFeeOutside" class="form-input" placeholder="130" min="0" /></div>
                </div>
                <button type="submit" class="btn-primary !h-10 px-8 text-sm">Save</button>
              </form>
            </div>
          </section>
        </main>
      </div>
    </div>

    <div id="pModal" class="modal-overlay hidden">
      <div class="modal-content card max-w-2xl w-full">
        <div class="flex items-center justify-between mb-8 border-b border-accents-2 pb-6">
          <h3 id="pModalTitle" class="display-sm">Product</h3>
          <button onclick="window.closeProductModal()" class="text-accents-5 hover:text-white text-2xl transition-colors">&times;</button>
        </div>
        <form id="pForm" class="space-y-8">
          <input type="hidden" id="editIx" value="-1" />
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-6">
              <div><label class="caption-mono text-accents-5 mb-2 block text-[10px]">Name</label><input type="text" id="fName" class="form-input" placeholder="Minifigure name..." required /></div>
              <div><label class="caption-mono text-accents-5 mb-2 block text-[10px]">Category</label><select id="fCat" class="form-input"></select></div>
              <div class="grid grid-cols-2 gap-4">
                <div><label class="caption-mono text-accents-5 mb-2 block text-[10px]">Price</label><input type="number" id="fPrice" class="form-input" placeholder="0" required /></div>
                <div><label class="caption-mono text-accents-5 mb-2 block text-[10px]">Sale Price</label><input type="number" id="fDisc" class="form-input" placeholder="Optional" /></div>
              </div>
              <div class="flex items-center gap-2 pt-2">
                <input type="checkbox" id="fInStock" class="w-4 h-4 rounded border-accents-2 bg-accents-1 text-cyan focus:ring-cyan/50 focus:ring-offset-black accent-cyan cursor-pointer" checked />
                <label for="fInStock" class="caption-mono text-accents-5 text-[10px] select-none cursor-pointer">In Stock</label>
              </div>
            </div>
            <div class="space-y-6">
              <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Image</label>
              <div id="imgPrev" class="w-full aspect-square rounded-lg border border-accents-2 bg-accents-1 overflow-hidden flex items-center justify-center"><span class="text-xs text-accents-4">No image</span></div>
              <div class="space-y-3">
                <input type="text" id="fImg" class="form-input" placeholder="Image URL..." />
                <input type="file" id="fFile" class="hidden" accept="image/*" />
                <button type="button" onclick="document.getElementById('fFile').click()" class="btn-secondary !h-10 !px-4 !text-[11px] uppercase font-bold w-full">Upload</button>
              </div>
            </div>
          </div>
          <div class="flex gap-4 pt-6 border-t border-accents-2">
            <button type="button" onclick="window.closeProductModal()" class="btn-secondary flex-1 !h-12 text-sm">Cancel</button>
            <button type="submit" class="btn-primary flex-1 !h-12 text-sm">Save</button>
          </div>
        </form>
      </div>
    </div>

    <script is:inline>
      // ─── Toast System ───
      window.showToast = function(message, type) {
        type = type || 'info';
        var container = document.getElementById('toastContainer');
        if (!container) return;
        var el = document.createElement('div');
        el.className = 'toast ' + type;
        el.textContent = message;
        container.appendChild(el);
        setTimeout(function() {
          el.style.animation = 'toastOut 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards';
          setTimeout(function() { if (el.parentNode) el.parentNode.removeChild(el); }, 250);
        }, 2500);
      };

      // ─── Supabase Client ───
      var SUPABASE_URL = 'https://bpgdniisgxzgrrcqlnwp.supabase.co';
      var SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJwZ2RuaWlzZ3h6Z3JyY3FsbndwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE3NjU2ODIsImV4cCI6MjA5NzM0MTY4Mn0.krm-gAAveC4y8bBIwEMFTggXSDzn4Ypj_r5UjoJ5uuk';
      var ADMIN_USER = 'admin';
      var ADMIN_PASS = 'brickrush2024';

      // Simple helper to call Supabase REST API
      function supabaseRequest(method, path, body, headers) {
        var url = SUPABASE_URL + '/rest/v1/' + path;
        var token = getToken();
        var options = {
          method: method,
          headers: {
            'apikey': SUPABASE_ANON_KEY,
            'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
            'Content-Type': 'application/json',
            'Prefer': 'return=representation',
            ...(token ? { 'x-admin-token': token } : {}),
            ...(headers || {})
          }
        };
        if (body && method !== 'GET') options.body = JSON.stringify(body);
        return fetch(url, options).then(function(r) {
          if (!r.ok) throw new Error(r.statusText);
          // DELETE / PATCH with return=minimal can return empty body (204 or 200 with no content)
          // Read as text first, then parse conditionally to avoid JSON parse errors on empty bodies
          return r.text().then(function(text) {
            return text ? JSON.parse(text) : null;
          });
        });
      }

      function getToken() { return localStorage.getItem('jv_token'); }

      // ── Sidebar ──
      var sb = document.getElementById('sb'), ham = document.getElementById('hamBtn'), ol = document.getElementById('ol');
      ham.onclick = function() { if (window.innerWidth <= 1024) { sb.classList.toggle('open'); ol.classList.toggle('on'); } };
      ol.onclick = function() { sb.classList.remove('open'); ol.classList.remove('on'); };

      // ─── Auth ───
      document.getElementById('loginForm').onsubmit = async function(e) {
        e.preventDefault();
        var user = document.getElementById('user').value;
        var pass = document.getElementById('pass').value;
        if (user !== ADMIN_USER || pass !== ADMIN_PASS) { window.showToast('Access Denied', 'error'); return; }

        // Generate token and store in Supabase
        var chars = 'abcdefghijklmnopqrstuvwxyz0123456789';
        var token = '';
        for (var i = 0; i < 32; i++) token += chars[Math.floor(Math.random() * chars.length)];
        token += Date.now().toString(36);

        try {
          await supabaseRequest('POST', 'admin_sessions', { token: token });
          localStorage.setItem('jv_token', token);
          localStorage.setItem('jv_admin', 'true');
          document.body.classList.add('loaded');
          document.getElementById('loginScreen').style.display = 'none';
          document.getElementById('dash').style.display = 'flex';
          init();
        } catch(e) { window.showToast('Server error — check connection', 'error'); }
      };

      // Auto-login check
      (async function() {
        if (localStorage.getItem('jv_admin') && localStorage.getItem('jv_token')) {
          try {
            var sessions = await supabaseRequest('GET', 'admin_sessions?token=eq.' + localStorage.getItem('jv_token') + '&select=token');
            if (sessions && sessions.length > 0) {
              document.body.classList.add('loaded');
              document.getElementById('loginScreen').style.display = 'none';
              document.getElementById('dash').style.display = 'flex';
              setTimeout(init, 50);
              return;
            }
          } catch(e) {}
          localStorage.removeItem('jv_token');
          localStorage.removeItem('jv_admin');
        }
        document.body.classList.add('loaded');
      })();

      document.getElementById('logoutBtn').onclick = async function() {
        try {
          await supabaseRequest('DELETE', 'admin_sessions?token=eq.' + getToken(), null, { Prefer: 'return=minimal' });
        } catch(e) {}
        localStorage.removeItem('jv_token');
        localStorage.removeItem('jv_admin');
        location.reload();
      };

      // ─── Tab Navigation ───
      document.querySelectorAll('[data-tab]').forEach(function(btn) {
        btn.onclick = function() {
          document.querySelectorAll('[data-tab]').forEach(function(b) { b.classList.remove('on'); });
          btn.classList.add('on');
          document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('on'); });
          var target = document.getElementById(btn.getAttribute('data-tab'));
          if (target) target.classList.add('on');
          document.getElementById('pgTitle').textContent = btn.querySelector('span:last-child').textContent;
          if (window.innerWidth <= 1024) { sb.classList.remove('open'); ol.classList.remove('on'); }
        };
      });

      // ─── Data ───
      var orders = [], products = [], categories = [];
      var settings = { contact: '', bkash: '', nagad: '', facebook: '', instagram: '', fee_ctg: 70, fee_outside: 130 };

      async function load() {
        // Show glowing loader spinners inside dashboard tabs during Supabase fetching
        var spinner = '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px 20px;gap:12px;width:100%;grid-column:1/-1;">' +
          '<div style="width:24px;height:24px;border:2px solid rgba(80,227,194,0.08);border-top-color:var(--cyan);border-radius:50%;animation:dashSpin 0.8s linear infinite;box-shadow:0 0 10px rgba(80,227,194,0.15);"></div>' +
          '<span class="caption-mono text-accents-4 text-[9px] tracking-widest">CONNECTING TO VAULT...</span>' +
          '</div>';
        
        var ordersBody = document.getElementById('ordersBody');
        if (ordersBody) ordersBody.innerHTML = spinner;
        var invBody = document.getElementById('invBody');
        if (invBody) invBody.innerHTML = spinner;
        var catList = document.getElementById('catList');
        if (catList) catList.innerHTML = spinner;

        try {
          var [p, c, o, s] = await Promise.all([
            supabaseRequest('GET', 'products?order=id.asc').catch(function() { return []; }),
            supabaseRequest('GET', 'categories?order=name.asc').catch(function() { return []; }),
            supabaseRequest('GET', 'orders?order=created_at.desc').catch(function() { return []; }),
            supabaseRequest('GET', 'settings?select=*&limit=1').catch(function() { return []; })
          ]);
          products = Array.isArray(p) ? p : [];
          categories = Array.isArray(c) ? c : [];
          orders = Array.isArray(o) ? o : [];
          var sRow = Array.isArray(s) && s.length > 0 ? s[0] : {};
          settings = sRow;
 
          document.getElementById('fContact').value = settings.contact || '';
          document.getElementById('fBkash').value = settings.bkash || '';
          document.getElementById('fNagad').value = settings.nagad || '';
          document.getElementById('fFacebook').value = settings.facebook || '';
          document.getElementById('fInstagram').value = settings.instagram || '';
          document.getElementById('fFeeCtg').value = settings.fee_ctg || '70';
          document.getElementById('fFeeOutside').value = settings.fee_outside || '130';
 
          render();
        } catch(e) { console.error(e); }
      }

      function render() { renderStats(); renderOrders(); renderInv(); renderCats(); updCats(); }

      function renderStats() {
        var rev = orders.reduce(function(s, o) { return o.status !== 'cancelled' ? s + (Number(o.total)||0) : s; }, 0);
        document.getElementById('statRev').textContent = 'Tk ' + rev.toLocaleString();
        document.getElementById('statOrd').textContent = orders.length;
      }

      window.deleteOrder = async function(i) {
        if (!confirm('Delete order?')) return;
        var originalOrders = [...orders];
        var deletedOrder = orders[i];
        
        // Optimistic Update
        orders.splice(i, 1);
        render();
        window.showToast('Deleting order...', 'info');

        try {
          await supabaseRequest('DELETE', 'orders?id=eq.' + encodeURIComponent(deletedOrder.id), null, { Prefer: 'return=minimal' });
          window.showToast('Order deleted successfully', 'success');
        } catch(e) {
          orders = originalOrders;
          render();
          window.showToast('Failed to delete order', 'error');
        }
      };

      window.updateOrderStatus = async function(i, status) {
        var oldStatus = orders[i].status;

        // Optimistic Update
        orders[i].status = status;
        render();
        window.showToast('Updating status...', 'info');

        try {
          await supabaseRequest('PATCH', 'orders?id=eq.' + encodeURIComponent(orders[i].id), { status: status }, { Prefer: 'return=minimal' });
          window.showToast('Order status updated', 'success');
        } catch(e) {
          orders[i].status = oldStatus;
          render();
          window.showToast('Failed to update status', 'error');
        }
      };

      function renderOrders() {
        var body = document.getElementById('ordersBody');
        if (!body) return;
        if (!orders.length) { body.innerHTML = '<div class="empty"><span class="empty-e">📦</span><span class="empty-t">No orders yet.</span></div>'; return; }

        body.innerHTML = orders.map(function(o,i) {
          var st = (o.status || 'pending').toLowerCase();
          var stCls = st === 'pending' ? 'pending' : st === 'processing' ? 'process' : st === 'completed' ? 'done' : st === 'cancelled' ? 'cancelled' : 'pending';
          var zoneLabel = o.zone === 'ctg' ? 'Inside Chittagong' : o.zone === 'outside' ? 'Outside Chittagong' : 'Not set';
          var zoneFee = o.delivery_fee ? 'Tk ' + Number(o.delivery_fee).toLocaleString() : '';
          var items = typeof o.items_json === 'string' ? JSON.parse(o.items_json) : (o.items || []);
          var itemsHtml = items.map(function(it) {
            var ip = parseInt(it.price ? it.price.replace(/[^0-9]/g, '') : '0') || 0;
            return '<span style="display:flex;justify-content:space-between;gap:8px;font-size:12px;color:#eaeaea;"><span>' + it.name + ' <span style="color:#888;">x' + (it.qty || 1) + '</span></span><span style="color:#888;">Tk ' + (ip * (it.qty || 1)).toLocaleString() + '</span></span>';
          }).join('');

          return '<div class="oc">' +
            '<div class="oc-top"><span class="oc-id">#' + (o.id || '???') + '</span><span class="sbad ' + stCls + '">' + (o.status || 'pending') + '</span></div>' +
            '<div class="oc-body">' +
              '<div class="oc-f"><span class="oc-fl">Customer</span><span class="oc-fv">' + (o.customer_name || 'Unknown') + '</span><span style="font-size:11px;color:#888;">' + (o.customer_phone || '') + '</span><span style="font-size:10px;color:#666;">' + (o.customer_address || '') + '</span></div>' +
              '<div class="oc-f"><span class="oc-fl">Zone</span><span class="oc-fv" style="font-size:13px;">' + zoneLabel + '</span><span style="font-size:11px;color:#888;">' + zoneFee + '</span></div>' +
              '<div class="oc-f" style="grid-column:1/-1;"><span class="oc-fl" style="margin-bottom:4px;">Items</span>' + itemsHtml + '</div>' +
              '<div class="oc-f"><span class="oc-fl">Payment</span><span class="oc-fv" style="text-transform:uppercase;font-size:12px;">' + (o.payment_method || 'cod') + '</span><span style="font-size:10px;color:#888;">TrxID: ' + (o.payment_trxid || '—') + '</span></div>' +
              '<div class="oc-f"><span class="oc-fl">Total</span><span class="oc-fv m">Tk ' + (Number(o.total)||0).toLocaleString() + '</span></div>' +
            '</div>' +
            '<div class="oc-btm">' +
              '<span style="font-size:10px;color:#666;">' + (o.created_at ? new Date(o.created_at).toLocaleDateString() : '') + '</span>' +
              '<div style="display:flex;gap:6px;align-items:center;">' +
                '<select class="status-select" onchange="window.updateOrderStatus(' + i + ', this.value)">' +
                  '<option value="pending"' + (st === 'pending' ? ' selected' : '') + '>Pending</option>' +
                  '<option value="processing"' + (st === 'processing' ? ' selected' : '') + '>Processing</option>' +
                  '<option value="completed"' + (st === 'completed' ? ' selected' : '') + '>Completed</option>' +
                  '<option value="cancelled"' + (st === 'cancelled' ? ' selected' : '') + '>Cancelled</option>' +
                '</select>' +
                '<button onclick="window.deleteOrder(' + i + ')" class="btn-sm danger">Delete</button>' +
              '</div>' +
            '</div>' +
          '</div>';
        }).join('');
      }

      window.deleteProduct = async function(i) {
        if (!confirm('Delete product?')) return;
        var originalProducts = [...products];
        var deletedProduct = products[i];

        // Optimistic Update
        products.splice(i, 1);
        render();
        window.showToast('Deleting product...', 'info');

        try {
          await supabaseRequest('DELETE', 'products?id=eq.' + deletedProduct.id, null, { Prefer: 'return=minimal' });
          window.showToast('Product deleted successfully', 'success');
        } catch(e) {
          products = originalProducts;
          render();
          window.showToast('Failed to delete product', 'error');
        }
      };

      function renderInv() {
        var body = document.getElementById('invBody');
        if (!body) return;
        if (!products.length) { body.innerHTML = '<div class="empty"><span class="empty-e">🛡️</span><span class="empty-t">No products.</span></div>'; return; }
        body.innerHTML = products.map(function(p,i) {
          var hd = p.discount_price && p.discount_price !== p.price;
          var stockLabel = p.in_stock === false 
            ? '<span style="color:#ef4444;font-size:10px;font-weight:600;margin-left:8px;text-transform:uppercase;">(Out of Stock)</span>' 
            : '';
          return '<div class="pc">' +
            '<img src="' + p.image + '" class="pc-img" />' +
            '<div class="pc-info"><div class="pc-name">' + p.name + stockLabel + '</div><span class="pc-cat">' + p.category + '</span></div>' +
            (hd ? '<div class="pc-price sold">' + p.discount_price + '<span class="pc-old">' + p.price + '</span></div>' : '<div class="pc-price">' + p.price + '</div>') +
            '<div class="pc-acts">' +
              '<button onclick="editProd(' + i + ')" class="btn-sm cyan">Edit</button>' +
              '<button onclick="window.deleteProduct(' + i + ')" class="btn-sm danger">Del</button>' +
            '</div>' +
          '</div>';
        }).join('');
      }

      function editProd(i) {
        var p = products[i];
        document.getElementById('editIx').value = i;
        document.getElementById('fName').value = p.name;
        document.getElementById('fCat').value = p.category;
        document.getElementById('fPrice').value = p.price.replace('Tk ','');
        document.getElementById('fDisc').value = p.discount_price ? p.discount_price.replace('Tk ','') : '';
        document.getElementById('fImg').value = p.image.startsWith('data:') ? '' : p.image;
        document.getElementById('fInStock').checked = p.in_stock !== false;
        updatePrev(p.image);
        document.getElementById('pModal').classList.remove('hidden');
        document.body.classList.add('no-scroll');
      }

      window.deleteCategory = async function(i) {
        if (!confirm('Delete category?')) return;
        try { await supabaseRequest('DELETE', 'categories?id=eq.' + categories[i].id, null, { Prefer: 'return=minimal' }); categories.splice(i, 1); render(); window.showToast('Category deleted', 'success'); }
        catch(e) { window.showToast('Failed to delete', 'error'); }
      };

      function renderCats() {
        var list = document.getElementById('catList');
        if (!list) return;
        if (!categories.length) { list.innerHTML = '<div class="empty" style="grid-column:1/-1"><span class="empty-e">🏷️</span><span class="empty-t">No categories.</span></div>'; return; }
        list.innerHTML = categories.map(function(c,i) {
          return '<div class="cc"><div class="cc-l"><div class="cc-i">' + c.name.charAt(0) + '</div><span class="cc-n">' + c.name + '</span></div><button onclick="window.deleteCategory(' + i + ')" class="btn-sm danger">Remove</button></div>';
        }).join('');
      }

      function updCats() {
        var sel = document.getElementById('fCat');
        if (!sel) return;
        var cur = sel.value;
        sel.innerHTML = categories.map(function(c) { return '<option value="' + c.name + '">' + c.name + '</option>'; }).join('');
        if (categories.some(function(c) { return c.name === cur; })) sel.value = cur;
      }

      document.getElementById('catForm').onsubmit = async function(e) {
        e.preventDefault();
        var inp = document.getElementById('catInp');
        if (inp.value && !categories.some(function(c) { return c.name === inp.value; })) {
          try {
            var newCat = await supabaseRequest('POST', 'categories', { name: inp.value });
            if (newCat && newCat.length > 0) categories.push(newCat[0]);
            else categories.push({ id: Date.now(), name: inp.value });
            render();
            inp.value = '';
            window.showToast('Category added', 'success');
          } catch(err) { window.showToast('Failed to add category', 'error'); }
        }
      };

      document.getElementById('setForm').onsubmit = async function(e) {
        e.preventDefault();
        var body = {
          contact: document.getElementById('fContact').value,
          bkash: document.getElementById('fBkash').value,
          nagad: document.getElementById('fNagad').value,
          facebook: document.getElementById('fFacebook').value,
          instagram: document.getElementById('fInstagram').value,
          fee_ctg: Number(document.getElementById('fFeeCtg').value) || 70,
          fee_outside: Number(document.getElementById('fFeeOutside').value) || 130
        };
        try {
          await supabaseRequest('PATCH', 'settings?id=eq.1', body, { Prefer: 'return=minimal' });
          settings = body;
          window.showToast('Settings saved', 'success');
        } catch(err) { window.showToast('Failed to save', 'error'); }
      };

      window.clearOrders = async function() {
        if (!confirm('Clear all orders?')) return;
        try { await supabaseRequest('DELETE', 'orders?id=gt.0', null, { Prefer: 'return=minimal' }); orders = []; render(); window.showToast('All orders cleared', 'success'); }
        catch(e) { window.showToast('Failed to clear', 'error'); }
      };

      // ─── Product Modal ───
      var modal = document.getElementById('pModal');
      var pForm = document.getElementById('pForm');
      var pFile = document.getElementById('fFile');
      var pUrl = document.getElementById('fImg');
      var pPrev = document.getElementById('imgPrev');
      var imgData = '';

      function updatePrev(src) {
        if (src) { pPrev.innerHTML = '<img src="' + src + '" class="w-full h-full object-cover" />'; imgData = src; }
        else { pPrev.innerHTML = '<span class="text-xs text-accents-4">No image</span>'; imgData = ''; }
      }
      pUrl.oninput = function(e) { updatePrev(e.target.value); };

      // Upload image to Supabase Storage
      async function uploadImage(file) {
        var formData = new FormData();
        formData.append('file', file);
        var fileName = Date.now() + '-' + file.name.replace(/[^a-zA-Z0-9.]/g, '_');
        try {
          var res = await fetch(SUPABASE_URL + '/storage/v1/object/products/' + fileName, {
            method: 'POST',
            headers: {
              'apikey': SUPABASE_ANON_KEY,
              'Authorization': 'Bearer ' + SUPABASE_ANON_KEY
            },
            body: file
          });
          if (res.ok) return SUPABASE_URL + '/storage/v1/object/public/products/' + fileName;
          throw new Error('Upload failed');
        } catch(e) { throw e; }
      }

      pFile.onchange = async function(e) {
        var file = e.target.files[0];
        if (file) {
          if (file.size > 5 * 1024 * 1024) { window.showToast('Image too large (max 5MB)', 'warning'); return; }
          var reader = new FileReader();
          reader.onload = function(re) { updatePrev(re.target.result); };
          reader.readAsDataURL(file);
          pUrl.value = 'uploading...';
          try {
            var url = await uploadImage(file);
            pUrl.value = url;
            imgData = url;
            pUrl.style.color = '#50e3c2';
            window.showToast('Image uploaded', 'success');
          } catch(err) { window.showToast('Upload failed — use URL instead', 'error'); pUrl.value = ''; pUrl.style.color = ''; }
        }
      };

      window.showProductModal = function() {
        document.getElementById('editIx').value = '-1'; pForm.reset(); updatePrev(''); 
        document.getElementById('fInStock').checked = true;
        modal.classList.remove('hidden');
        document.body.classList.add('no-scroll');
      };
      window.closeProductModal = function() { modal.classList.add('hidden'); document.body.classList.remove('no-scroll'); };

      pForm.onsubmit = async function(e) {
        e.preventDefault();
        var ix = parseInt(document.getElementById('editIx').value);
        var finImg = pUrl.value || imgData;
        if (!finImg || finImg === 'uploading...') { window.showToast('Please add an image', 'warning'); return; }
        var disc = document.getElementById('fDisc').value;
        var prod = {
          name: document.getElementById('fName').value,
          category: document.getElementById('fCat').value,
          price: 'Tk ' + document.getElementById('fPrice').value,
          discount_price: disc ? 'Tk ' + disc : null,
          image: finImg,
          in_stock: document.getElementById('fInStock').checked
        };

        var submitBtn = pForm.querySelector('button[type="submit"]');
        var originalBtnText = submitBtn.textContent;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Saving...';

        try {
          if (ix === -1) {
            var created = await supabaseRequest('POST', 'products', prod);
            if (created && created.length > 0) products.push(created[0]);
            else products.push(prod);
          } else {
            // Optimistic edit
            var originalProd = { ...products[ix] };
            products[ix] = { ...products[ix], ...prod };
            render();
            window.closeProductModal();

            await supabaseRequest('PATCH', 'products?id=eq.' + products[ix].id, prod, { Prefer: 'return=minimal' });
          }
          
          if (ix === -1) {
            render();
            window.closeProductModal();
          }
          window.showToast('Product saved successfully', 'success');
        } catch(err) {
          window.showToast('Failed to save product', 'error');
          if (ix !== -1) {
            products[ix] = originalProd;
            render();
          }
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = originalBtnText;
        }
      };

      function init() { load(); }
    </script>
  </body>
</html>
