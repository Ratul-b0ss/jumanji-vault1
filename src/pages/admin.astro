---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Admin Dashboard - BRICK RUSH</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
    <style>
      :root {
        --sidebar-width: 260px;
        --sidebar-collapsed-width: 68px;
        --header-height: 60px;
        --transition-speed: 0.3s;
      }

      [v-cloak] { display: none; }
      body { opacity: 0; transition: opacity 0.3s ease; background: var(--ds-background-100); color: var(--ds-gray-900); }
      body.loaded { opacity: 1; }
      
      /* Login Screen */
      .login-screen {
        position: fixed; inset: 0; z-index: 9999;
        display: flex; align-items: center; justify-content: center;
        background: var(--ds-background-100);
        padding: 20px;
      }
      .login-card { width: 100%; max-width: 400px; }

      /* Dashboard Layout */
      .admin-layout {
        display: flex;
        min-height: 100vh;
        overflow-x: hidden;
      }

      /* Sidebar */
      .sidebar {
        position: fixed;
        left: 0; top: 0; bottom: 0;
        width: var(--sidebar-width);
        background: var(--ds-background-200);
        border-right: 1px solid var(--accents-2);
        z-index: 1000;
        transition: transform var(--transition-speed) ease, width var(--transition-speed) ease;
        display: flex;
        flex-direction: column;
      }

      @media (max-width: 1024px) {
        .sidebar {
          transform: translateX(-100%);
        }
        .sidebar.open {
          transform: translateX(0);
          width: 280px;
        }
      }

      @media (min-width: 1025px) {
        .sidebar.collapsed {
          width: var(--sidebar-collapsed-width);
        }
        .sidebar.collapsed .nav-text,
        .sidebar.collapsed .sidebar-header-text,
        .sidebar.collapsed .sidebar-footer-text {
          display: none;
        }
        .sidebar.collapsed .nav-link {
          justify-content: center;
          padding: 12px 0;
        }
        .sidebar.collapsed .sidebar-header {
          padding: 20px 0;
          justify-content: center;
        }
      }

      .sidebar-header {
        height: var(--header-height);
        display: flex;
        align-items: center;
        padding: 0 24px;
        border-bottom: 1px solid var(--accents-2);
        gap: 12px;
      }

      .nav-list {
        flex: 1;
        padding: 24px 12px;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .nav-link {
        display: flex;
        align-items: center;
        padding: 10px 12px;
        color: var(--accents-5);
        border-radius: var(--rounded-md);
        transition: all 0.2s ease;
        text-decoration: none;
        cursor: pointer;
        gap: 12px;
        font-size: 14px;
        font-weight: 500;
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
      }

      .nav-link:hover, .nav-link.active {
        background: var(--accents-1);
        color: var(--ds-gray-900);
      }

      .nav-link.active {
        color: var(--cyan);
        background: var(--cyan-soft);
      }

      .nav-icon {
        width: 20px;
        height: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .sidebar-footer {
        padding: 16px;
        border-top: 1px solid var(--accents-2);
      }

      /* Main Content */
      .main-wrapper {
        flex: 1;
        display: flex;
        flex-direction: column;
        transition: padding-left var(--transition-speed) ease;
      }

      @media (min-width: 1025px) {
        .main-wrapper {
          padding-left: var(--sidebar-width);
        }
        .sidebar.collapsed + .main-wrapper {
          padding-left: var(--sidebar-collapsed-width);
        }
      }

      .top-bar {
        height: var(--header-height);
        background: var(--ds-background-100);
        border-bottom: 1px solid var(--accents-2);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 24px;
        position: sticky;
        top: 0;
        z-index: 900;
      }

      .main-content {
        padding: 32px 24px;
        max-width: 1200px;
        margin: 0 auto;
        width: 100%;
      }

      /* Mobile Toggle */
      .menu-toggle {
        background: transparent;
        border: none;
        color: var(--ds-gray-900);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 8px;
        border-radius: var(--rounded-sm);
      }
      .menu-toggle:hover {
        background: var(--accents-1);
      }

      /* Overlay */
      .sidebar-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
        z-index: 999;
        display: none;
      }
      .sidebar-overlay.show {
        display: block;
      }

      /* ── Modern Minimal Tables ── */
      .table-wrap {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        border: 1px solid var(--accents-2);
        border-radius: 12px;
        background: var(--ds-background-200);
      }

      .table-wrap table {
        width: 100%;
        table-layout: fixed;
        border-collapse: collapse;
        min-width: 680px;
        font-size: 13px;
      }

      .table-wrap thead th {
        padding: 14px 16px;
        text-align: left;
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--accents-5);
        background: var(--ds-background-300);
        border-bottom: 1px solid var(--accents-2);
        white-space: nowrap;
      }

      .table-wrap tbody tr {
        transition: background 0.15s ease;
      }
      .table-wrap tbody tr:hover {
        background: rgba(255, 255, 255, 0.03);
      }
      .table-wrap tbody tr:last-child td {
        border-bottom: none;
      }

      .table-wrap tbody td {
        padding: 14px 16px;
        border-top: 1px solid var(--accents-2);
        vertical-align: middle;
        color: var(--accents-6);
        font-size: 13px;
        overflow: hidden;
        text-overflow: ellipsis;
        word-wrap: break-word;
      }

      /* Badge */
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 100px;
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .badge::before {
        content: '';
        width: 5px;
        height: 5px;
        border-radius: 50%;
        flex-shrink: 0;
      }
      .badge-pending { background: rgba(245, 166, 35, 0.1); color: #f5a623; }
      .badge-pending::before { background: #f5a623; }
      .badge-processing { background: rgba(80, 227, 194, 0.1); color: var(--cyan); }
      .badge-processing::before { background: var(--cyan); }
      .badge-completed { background: rgba(34, 197, 94, 0.1); color: #22c55e; }
      .badge-completed::before { background: #22c55e; }
      .badge-cancelled { background: rgba(239, 68, 68, 0.1); color: #ef4444; }
      .badge-cancelled::before { background: #ef4444; }
      .badge-default { background: var(--accents-1); color: var(--accents-5); }
      .badge-default::before { background: var(--accents-4); }

      /* Product thumb */
      .prod-thumb {
        width: 32px;
        height: 40px;
        border-radius: 4px;
        object-fit: contain;
        background: var(--accents-1);
        border: 1px solid var(--accents-2);
        flex-shrink: 0;
      }

      /* Actions */
      .act {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 10px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: all 0.15s ease;
        background: transparent;
        color: var(--accents-5);
      }
      .act:hover { background: var(--accents-1); color: var(--ds-gray-900); }
      .act.danger { color: #ef4444; }
      .act.danger:hover { background: rgba(239, 68, 68, 0.08); }
      .act.primary { color: var(--cyan); }
      .act.primary:hover { background: var(--cyan-soft); }

      /* Cat tag */
      .cat-tag {
        display: inline-flex;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 10px;
        font-weight: 600;
        background: var(--accents-1);
        color: var(--accents-5);
        border: 1px solid var(--accents-2);
      }

      /* Empty state */
      .tempty {
        padding: 48px 24px;
        text-align: center;
        color: var(--accents-4);
        font-style: italic;
        font-size: 13px;
      }
      .tempty span { font-size: 24px; display: block; margin-bottom: 8px; font-style: normal; }

      .tab-content { display: none; }
      .tab-content.active { display: block; }
    </style>
  </head>
  <body>
    <!-- Overlay for mobile sidebar -->
    <div id="sidebarOverlay" class="sidebar-overlay"></div>

    <!-- ── Login ── -->
    <div id="loginScreen" class="login-screen">
      <div class="login-card card animate-fade-in">
        <div class="mb-8 text-center">
          <div class="flex items-center justify-center gap-2 mb-4">
             <span class="caption-mono text-cyan font-bold text-2xl">BRICK</span>
             <span class="caption-mono text-white font-bold text-2xl">RUSH</span>
          </div>
          <h1 class="display-sm">Command Center</h1>
          <p class="body-sm text-accents-5">Encrypted Access Only</p>
        </div>
        <form id="loginForm" class="space-y-4">
          <div>
            <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Security Identifier</label>
            <input type="text" id="user" class="form-input" placeholder="admin" required />
          </div>
          <div>
            <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Access Key</label>
            <input type="password" id="pass" class="form-input" placeholder="••••••••" required />
          </div>
          <button type="submit" class="btn-primary w-full mt-6">Authorize Protocol</button>
        </form>
      </div>
    </div>

    <!-- ── Dashboard ── -->
    <div id="dashboard" class="admin-layout hidden">
      <!-- Sidebar -->
      <aside id="sidebar" class="sidebar">
        <div class="sidebar-header">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-cyan rounded-md flex items-center justify-center text-black font-bold text-lg">B</div>
            <span class="sidebar-header-text font-bold text-lg tracking-tight">BRICK<span class="text-cyan">RUSH</span></span>
          </div>
        </div>

        <nav class="nav-list">
          <button class="nav-link active" data-target="orders">
            <span class="nav-icon">📦</span>
            <span class="nav-text">Orders</span>
          </button>
          <button class="nav-link" data-target="inventory">
            <span class="nav-icon">🛡️</span>
            <span class="nav-text">Products</span>
          </button>
          <button class="nav-link" data-target="settings">
            <span class="nav-icon">⚙️</span>
            <span class="nav-text">Settings</span>
          </button>
          <button class="nav-link" data-target="categories">
            <span class="nav-icon">🏷️</span>
            <span class="nav-text">Category</span>
          </button>
          <a href="/" class="nav-link mt-4 text-cyan/80">
            <span class="nav-icon">🏠</span>
            <span class="nav-text">Back to Home</span>
          </a>
        </nav>

        <div class="sidebar-footer">
          <button id="logout" class="nav-link text-error/80 hover:text-error hover:bg-error/10">
            <span class="nav-icon">Logout</span>
            <span class="nav-text">Terminate Session</span>
          </button>
        </div>
      </aside>

      <!-- Main Content -->
      <div class="main-wrapper">
        <header class="top-bar">
          <div class="flex items-center gap-4">
            <button id="sidebarToggle" class="menu-toggle">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            </button>
            <h2 id="pageTitle" class="text-sm font-semibold text-accents-5 uppercase tracking-widest">Dashboard</h2>
          </div>
          <div class="flex items-center gap-4">
            <div id="connectionStatus" class="flex items-center gap-2 px-3 py-1 bg-cyan-soft border border-cyan/20 rounded-full">
              <span class="w-2 h-2 bg-cyan rounded-full animate-pulse"></span>
              <span class="text-[10px] font-bold text-cyan uppercase tracking-tighter">Secure Line Active</span>
            </div>
          </div>
        </header>

        <main class="main-content">
          <!-- Orders Tab -->
          <section id="orders" class="tab-content active animate-fade-in">
            <header class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
              <div>
                <h2 class="display-md mb-1">Order Pipeline</h2>
                <p class="body-sm text-accents-5">Monitor and process incoming orders.</p>
              </div>
              <button onclick="window.clearOrders()" class="btn-secondary !h-9 !px-4 !text-xs text-error border-error/20 hover:bg-error/5">Wipe Pipeline</button>
            </header>

            <div class="grid grid-cols-2 gap-4 mb-6" id="orderStats">
              <div class="card p-5 flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl bg-cyan-soft border border-cyan/10 flex items-center justify-center text-cyan shrink-0">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10M18 20V4M6 20v-4"/></svg>
                </div>
                <div>
                  <div class="text-[9px] caption-mono tracking-widest text-accents-5 mb-1">Total Revenue</div>
                  <div id="statRevenue" class="text-lg font-bold text-white">Tk 0</div>
                </div>
              </div>
              <div class="card p-5 flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl bg-cyan-soft border border-cyan/10 flex items-center justify-center text-cyan shrink-0">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/></svg>
                </div>
                <div>
                  <div class="text-[9px] caption-mono tracking-widest text-accents-5 mb-1">Total Orders</div>
                  <div id="statOrders" class="text-lg font-bold text-white">0</div>
                </div>
              </div>
            </div>

            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th style="width:100px">Ref ID</th>
                    <th>Customer</th>
                    <th style="width:30%">Items</th>
                    <th style="width:90px">Total</th>
                    <th style="width:110px">Payment</th>
                    <th style="width:110px">Status</th>
                    <th style="width:80px" class="text-right">Actions</th>
                  </tr>
                </thead>
                <tbody id="ordersBody"></tbody>
              </table>
            </div>
          </section>

          <!-- Inventory Tab -->
          <section id="inventory" class="tab-content animate-fade-in">
            <header class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
              <div>
                <h2 class="display-md mb-1">Product Inventory</h2>
                <p class="body-sm text-accents-5">Manage your minifigure collection.</p>
              </div>
              <div class="flex gap-2">
                <button onclick="window.resetToDefaults()" class="btn-secondary !h-9 !px-4 !text-xs text-accents-5 border-accents-2 hover:bg-accents-1">Reset to Defaults</button>
                <button onclick="window.showProductModal()" class="btn-primary !h-9 !px-6 !text-xs">+ Add Product</button>
              </div>
            </header>

            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th style="width:40%">Product</th>
                    <th style="width:120px">Category</th>
                    <th style="width:100px">Price</th>
                    <th style="width:120px" class="text-right">Actions</th>
                  </tr>
                </thead>
                <tbody id="inventoryBody"></tbody>
              </table>
            </div>
          </section>

          <!-- Categories Tab -->
          <section id="categories" class="tab-content animate-fade-in">
            <header class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
              <div>
                <h2 class="display-md mb-1">Categories</h2>
                <p class="body-sm text-accents-5">Organize your store structure.</p>
              </div>
              <form id="categoryForm" class="flex gap-2">
                <input type="text" id="catName" class="form-input !h-9 !px-4 !text-xs" placeholder="New category..." required />
                <button type="submit" class="btn-primary !h-9 !px-6 !text-xs">Add</button>
              </form>
            </header>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4" id="categoryList"></div>
          </section>

          <!-- Settings Tab -->
          <section id="settings" class="tab-content animate-fade-in">
            <header class="mb-8">
              <h2 class="display-md mb-1">System Settings</h2>
              <p class="body-sm text-accents-5">Configure store-wide parameters.</p>
            </header>

            <div class="card p-6 max-w-2xl">
              <form id="settingsForm" class="space-y-6">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                  <div>
                    <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Support Contact</label>
                    <input type="text" id="setContact" class="form-input" />
                  </div>
                  <div>
                    <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Bkash Merchant</label>
                    <input type="text" id="setBkash" class="form-input" />
                  </div>
                  <div>
                    <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Nagad Personal</label>
                    <input type="text" id="setNagad" class="form-input" />
                  </div>
                  <div>
                    <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Delivery Fee (Tk)</label>
                    <input type="number" min="0" step="1" id="setDeliveryFee" class="form-input" placeholder="0" />
                  </div>
                </div>
                <div class="pt-4">
                  <button type="submit" class="btn-primary !h-10 px-8 text-sm">Save Configuration</button>
                </div>
              </form>
            </div>
          </section>
        </main>
      </div>
    </div>

    <!-- ── Modals ── -->
    <div id="productModal" class="modal-overlay hidden">
      <div class="modal-content card max-w-2xl w-full">
        <div class="flex items-center justify-between mb-8 border-b border-accents-2 pb-6">
          <h3 id="modalTitle" class="display-sm">Product Configuration</h3>
          <button onclick="window.closeProductModal()" class="text-accents-5 hover:text-white transition-colors text-2xl">&times;</button>
        </div>
        
        <form id="productForm" class="space-y-8">
          <input type="hidden" id="editIndex" value="-1" />
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Left Side: Basic Info -->
            <div class="space-y-6">
              <div>
                <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Product Identification</label>
                <input type="text" id="pName" class="form-input" placeholder="Minifigure name..." required />
              </div>
              
              <div>
                <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Classification</label>
                <select id="pCat" class="form-input"></select>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Standard Price (Tk)</label>
                  <input type="number" id="pPrice" class="form-input" placeholder="0" required />
                </div>
                <div>
                  <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Sale Price (Tk)</label>
                  <input type="number" id="pDiscount" class="form-input" placeholder="Optional" />
                </div>
              </div>
            </div>

            <!-- Right Side: Visuals -->
            <div class="space-y-6">
              <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Visual Assets</label>
              
              <div class="flex flex-col gap-4">
                <div id="imagePreview" class="w-full aspect-square rounded-lg border border-accents-2 bg-accents-1 overflow-hidden flex items-center justify-center relative group">
                  <span class="text-xs text-accents-4">No Asset Selected</span>
                </div>
                
                <div class="space-y-3">
                  <input type="text" id="pImage" class="form-input" placeholder="External Asset URL..." />
                  
                  <div class="relative">
                    <input type="file" id="pFile" class="hidden" accept="image/*" />
                    <button type="button" onclick="document.getElementById('pFile').click()" class="btn-secondary !h-10 !px-4 !text-[11px] uppercase font-bold tracking-wider w-full">
                      Upload Local Binary
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="flex gap-4 pt-6 border-t border-accents-2">
            <button type="button" onclick="window.closeProductModal()" class="btn-secondary flex-1 !h-12 text-sm">Discard Changes</button>
            <button type="submit" class="btn-primary flex-1 !h-12 text-sm">Authorize Protocol</button>
          </div>
        </form>
      </div>
    </div>

    <script is:inline>
      const USER = 'admin';
      const PASS = 'brickrush2024';

      // ─── UI Interactions ───
      const sidebar = document.getElementById('sidebar');
      const sidebarToggle = document.getElementById('sidebarToggle');
      const sidebarOverlay = document.getElementById('sidebarOverlay');

      sidebarToggle.onclick = () => {
        if (window.innerWidth <= 1024) {
          sidebar.classList.toggle('open');
          sidebarOverlay.classList.toggle('show');
        } else {
          sidebar.classList.toggle('collapsed');
        }
      };

      sidebarOverlay.onclick = () => {
        sidebar.classList.remove('open');
        sidebarOverlay.classList.remove('show');
      };

      // ─── Auth ───
      function checkAuth() {
        document.body.classList.add('loaded');
        if (localStorage.getItem('jv_admin')) {
          showDashboard();
        }
      }

      document.getElementById('loginForm').onsubmit = (e) => {
        e.preventDefault();
        const u = document.getElementById('user').value;
        const p = document.getElementById('pass').value;
        if (u === USER && p === PASS) {
          localStorage.setItem('jv_admin', 'true');
          showDashboard();
        } else {
          alert('Access Denied: Protocol Violation');
        }
      };

      function showDashboard() {
        const loginScreen = document.getElementById('loginScreen');
        const dashboard = document.getElementById('dashboard');
        
        if (loginScreen) {
          loginScreen.style.setProperty('display', 'none', 'important');
          loginScreen.classList.add('hidden');
        }
        if (dashboard) {
          dashboard.style.setProperty('display', 'flex', 'important');
          dashboard.classList.remove('hidden');
        }
        
        try {
          init();
        } catch (e) {
          console.error('Dashboard init failed:', e);
        }
      }

      const logout = () => {
        localStorage.removeItem('jv_admin');
        location.reload();
      };
      document.getElementById('logout').onclick = logout;

      // ─── State ───
      let orders = [];
      let products = [];
      let categories = [];
      let settings = { contact: '', bkash: '', nagad: '', deliveryFee: '0' };

      const defaultProducts = [
        { name: 'Iron Man Mk 85', price: 'Tk 450', image: 'https://placehold.co/400x533/111/50e3c2?text=Iron+Man&font=inter', category: 'Marvel' },
        { name: 'Batman Dark Knight', price: 'Tk 380', image: 'https://placehold.co/400x533/111/50e3c2?text=Batman&font=inter', category: 'DC' },
        { name: 'Goku Ultra Instinct', price: 'Tk 520', image: 'https://placehold.co/400x533/111/50e3c2?text=Goku&font=inter', category: 'Anime' },
        { name: 'Eleven', price: 'Tk 420', image: 'https://placehold.co/400x533/111/50e3c2?text=Eleven&font=inter', category: 'Stranger Things' },
        { name: 'Spider-Man Miles', price: 'Tk 480', image: 'https://placehold.co/400x533/111/50e3c2?text=Miles&font=inter', category: 'Marvel' },
        { name: 'Luffy Gear 5', price: 'Tk 550', image: 'https://placehold.co/400x533/111/50e3c2?text=Luffy&font=inter', category: 'One Piece' },
        { name: 'Mandalorian', price: 'Tk 600', image: 'https://placehold.co/400x533/111/50e3c2?text=Mando&font=inter', category: 'Star Wars' },
        { name: 'Naruto Baryon', price: 'Tk 520', image: 'https://placehold.co/400x533/111/50e3c2?text=Naruto&font=inter', category: 'Anime' },
        { name: 'Wolverine Logan', price: 'Tk 460', image: 'https://placehold.co/400x533/111/50e3c2?text=Wolverine&font=inter', category: 'Marvel' },
        { name: 'Joker Heath', price: 'Tk 400', image: 'https://placehold.co/400x533/111/50e3c2?text=Joker&font=inter', category: 'DC' },
        { name: 'Tanjiro Sun', price: 'Tk 490', image: 'https://placehold.co/400x533/111/50e3c2?text=Tanjiro&font=inter', category: 'Anime' },
        { name: 'Darth Vader', price: 'Tk 650', image: 'https://placehold.co/400x533/111/50e3c2?text=Vader&font=inter', category: 'Star Wars' },
      ];
      const defaultCategories = ['Marvel', 'DC', 'Anime', 'Star Wars', 'One Piece', 'Stranger Things', 'Exclusive'];

      function loadData() {
        try {
          orders = JSON.parse(localStorage.getItem('jv_orders') || '[]');
          products = JSON.parse(localStorage.getItem('jv_products') || JSON.stringify(defaultProducts));
          categories = JSON.parse(localStorage.getItem('jv_categories') || JSON.stringify(defaultCategories));
          settings = JSON.parse(localStorage.getItem('jv_settings') || JSON.stringify({ contact: '', bkash: '', nagad: '', deliveryFee: '0' }));
          
          if (!localStorage.getItem('jv_products')) localStorage.setItem('jv_products', JSON.stringify(defaultProducts));
          if (!localStorage.getItem('jv_categories')) localStorage.setItem('jv_categories', JSON.stringify(defaultCategories));
          
          document.getElementById('setContact').value = settings.contact || '';
          document.getElementById('setBkash').value = settings.bkash || '';
          document.getElementById('setNagad').value = settings.nagad || '';
          document.getElementById('setDeliveryFee').value = settings.deliveryFee || '0';
        } catch (e) { console.error(e); }
      }

      function saveData() {
        localStorage.setItem('jv_orders', JSON.stringify(orders));
        localStorage.setItem('jv_products', JSON.stringify(products));
        localStorage.setItem('jv_categories', JSON.stringify(categories));
        localStorage.setItem('jv_settings', JSON.stringify(settings));
        renderAll();
      }

      function renderAll() {
        renderStats();
        renderOrders();
        renderInventory();
        renderCategories();
        updateCategoryDropdowns();
      }

      function renderStats() {
        const totalRev = orders.reduce((sum, o) => sum + (Number(o.total) || 0), 0);
        const statRevenue = document.getElementById('statRevenue');
        const statOrders = document.getElementById('statOrders');
        if (statRevenue) statRevenue.textContent = 'Tk ' + totalRev.toLocaleString();
        if (statOrders) statOrders.textContent = orders.length;
      }

      function renderOrders() {
        const body = document.getElementById('ordersBody');
        if (!body) return;
        if (orders.length === 0) {
          body.innerHTML = '<tr><td colspan="7"><div class="tempty"><span>📦</span>No orders yet.</div></td></tr>';
          return;
        }
        body.innerHTML = orders.map((o, i) => {
          var s = (o.status || 'pending').toLowerCase().replace(/\s+/g, '');
          return '<tr>' +
            '<td><span class="font-mono text-[11px] font-bold text-white">' + (o.id || '???') + '</span></td>' +
            '<td><div class="text-xs font-medium text-white">' + (o.customer?.name || 'Unknown') + '</div><div class="text-[10px] text-accents-4">' + (o.customer?.phone || 'N/A') + '</div></td>' +
            '<td><span class="text-[11px] text-accents-5">' + (o.items || []).map(function(it) { return it.name; }).join(', ') + '</span></td>' +
            '<td><span class="text-xs font-semibold text-cyan">Tk ' + (Number(o.total) || 0).toLocaleString() + '</span></td>' +
            '<td><div class="text-[10px] font-semibold text-white uppercase">' + (o.payment?.method || 'cod') + '</div><div class="text-[9px] text-accents-4">' + (o.payment?.trxId || '—') + '</div></td>' +
            '<td><span class="badge badge-' + (s || 'default') + '">' + (o.status || 'pending') + '</span></td>' +
            '<td class="text-right"><button onclick="window.deleteOrder(' + i + ')" class="act danger">Delete</button></td>' +
            '</tr>';
        }).join('');
      }

      function renderInventory() {
        const body = document.getElementById('inventoryBody');
        if (!body) return;
        if (products.length === 0) {
          body.innerHTML = '<tr><td colspan="4"><div class="tempty"><span>🛡️</span>No products in inventory.</div></td></tr>';
          return;
        }
        body.innerHTML = products.map(function(p, i) {
          var hasDiscount = p.discountPrice && p.discountPrice !== p.price;
          var priceHtml = hasDiscount
            ? '<div><span class="text-xs font-semibold text-cyan">' + p.discountPrice + '</span> <span class="text-[9px] text-accents-4 line-through">' + p.price + '</span></div>'
            : '<span class="text-xs font-medium text-white">' + p.price + '</span>';
          return '<tr>' +
            '<td><div class="flex items-center gap-3"><img src="' + p.image + '" class="prod-thumb" /><span class="text-xs font-medium text-white">' + p.name + '</span></div></td>' +
            '<td><span class="cat-tag">' + p.category + '</span></td>' +
            '<td>' + priceHtml + '</td>' +
            '<td class="text-right"><button onclick="window.editProduct(' + i + ')" class="act primary">Edit</button> <button onclick="window.deleteProduct(' + i + ')" class="act danger">Delete</button></td>' +
            '</tr>';
        }).join('');
      }

      function renderCategories() {
        const list = document.getElementById('categoryList');
        if (!list) return;
        if (categories.length === 0) {
          list.innerHTML = '<div class="col-span-full empty-state"><div class="empty-state-icon">🏷️</div><div class="empty-state-text">No categories created yet.</div></div>';
          return;
        }
        list.innerHTML = categories.map((c, i) => `
          <div class="card p-5 flex items-center justify-between group hover:border-accents-3 transition-all duration-200">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-cyan-soft border border-cyan/10 flex items-center justify-center text-cyan text-xs font-bold">${c.charAt(0)}</div>
              <span class="text-sm font-medium text-white">${c}</span>
            </div>
            <button onclick="window.deleteCategory(${i})" class="table-action danger opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity">Remove</button>
          </div>
        `).join('');
      }

      function updateCategoryDropdowns() {
        const select = document.getElementById('pCat');
        if (!select) return;
        const currentVal = select.value;
        select.innerHTML = categories.map(c => `<option value="${c}">${c}</option>`).join('');
        if (categories.includes(currentVal)) select.value = currentVal;
      }

      window.deleteCategory = (i) => {
        if (confirm('Delete category?')) { categories.splice(i, 1); saveData(); }
      };

      document.getElementById('categoryForm').onsubmit = (e) => {
        e.preventDefault();
        const inp = document.getElementById('catName');
        if (inp.value && !categories.includes(inp.value)) { categories.push(inp.value); saveData(); inp.value = ''; }
      };

      document.getElementById('settingsForm').onsubmit = (e) => {
        e.preventDefault();
        settings = {
          contact: document.getElementById('setContact').value,
          bkash: document.getElementById('setBkash').value,
          nagad: document.getElementById('setNagad').value,
          deliveryFee: document.getElementById('setDeliveryFee').value || '0'
        };
        saveData();
        alert('Settings Saved');
      };

      window.resetToDefaults = () => {
        if (confirm('This will delete all current products and restore the 12 example units. Proceed?')) {
          localStorage.removeItem('jv_products');
          localStorage.removeItem('jv_categories');
          location.reload();
        }
      };

      window.deleteOrder = (i) => {
        if (confirm('Delete order?')) { orders.splice(i, 1); saveData(); }
      };

      window.clearOrders = () => {
        if (confirm('Clear all orders?')) { orders = []; saveData(); }
      };

      const pModal = document.getElementById('productModal');
      const pForm = document.getElementById('productForm');
      const pFile = document.getElementById('pFile');
      const pUrl = document.getElementById('pImage');
      const pPreview = document.getElementById('imagePreview');

      let currentImageData = '';

      function updatePreview(src) {
        if (src) {
          pPreview.innerHTML = `<img src="${src}" class="w-full h-full object-cover" />`;
          currentImageData = src;
        } else {
          pPreview.innerHTML = '<span class="text-[10px] text-accents-4">No Image</span>';
          currentImageData = '';
        }
      }

      pUrl.oninput = (e) => updatePreview(e.target.value);

      pFile.onchange = (e) => {
        const file = e.target.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = (re) => {
            updatePreview(re.target.result);
            pUrl.value = ''; // Clear URL if file is chosen
          };
          reader.readAsDataURL(file);
        }
      };

      window.showProductModal = () => {
        document.getElementById('editIndex').value = '-1';
        pForm.reset();
        updatePreview('');
        pModal.classList.remove('hidden');
      };

      window.closeProductModal = () => pModal.classList.add('hidden');

      window.editProduct = (i) => {
        const p = products[i];
        document.getElementById('editIndex').value = i;
        document.getElementById('pName').value = p.name;
        document.getElementById('pCat').value = p.category;
        document.getElementById('pPrice').value = p.price.replace('Tk ', '');
        document.getElementById('pDiscount').value = p.discountPrice ? p.discountPrice.replace('Tk ', '') : '';
        pUrl.value = p.image.startsWith('data:') ? '' : p.image;
        updatePreview(p.image);
        pModal.classList.remove('hidden');
      };

      window.deleteProduct = (i) => {
        if (confirm('Delete product?')) { products.splice(i, 1); saveData(); }
      };

      pForm.onsubmit = (e) => {
        e.preventDefault();
        const i = parseInt(document.getElementById('editIndex').value);
        
        // Final image source priority: 1. Manual URL, 2. Current File Data
        const finalImage = pUrl.value || currentImageData;
        
        if (!finalImage) {
          alert('Please provide an image URL or upload a file.');
          return;
        }

        const discVal = document.getElementById('pDiscount').value;
        const newP = {
          name: document.getElementById('pName').value,
          category: document.getElementById('pCat').value,
          price: 'Tk ' + document.getElementById('pPrice').value,
          discountPrice: discVal ? 'Tk ' + discVal : null,
          image: finalImage
        };
        
        if (i === -1) products.push(newP);
        else products[i] = newP;
        
        saveData();
        window.closeProductModal();
      };

      document.querySelectorAll('.nav-link[data-target]').forEach(btn => {
        btn.onclick = () => {
          document.querySelectorAll('.nav-link').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          
          document.querySelectorAll('.tab-content').forEach(tc => tc.classList.remove('active'));
          const target = document.getElementById(btn.dataset.target);
          if (target) target.classList.add('active');
          
          document.getElementById('pageTitle').textContent = btn.dataset.target;

          if (window.innerWidth <= 1024) {
            sidebar.classList.remove('open');
            sidebarOverlay.classList.remove('show');
          }
        };
      });

      function init() { loadData(); renderAll(); }
      checkAuth();
    </script>
  </body>
</html>
