---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Admin Command Center - BRICK RUSH</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
    <style>
      [v-cloak] { display: none; }
      body { opacity: 0; transition: opacity 0.3s ease; }
      body.loaded { opacity: 1; }
      
      .admin-layout { display: flex; flex-direction: column; min-height: 100vh; background: #000; }
      @media (min-width: 768px) {
        .admin-layout { flex-direction: row; }
        .sidebar { width: 280px; border-right: 1px solid var(--accents-2); border-bottom: none; height: 100vh; position: sticky; top: 0; }
      }
      .sidebar { padding: 32px 24px; border-bottom: 1px solid var(--accents-2); display: flex; flex-direction: column; gap: 8px; }
      .main-content { flex: 1; padding: 32px 20px; max-width: 1200px; margin: 0 auto; width: 100%; }
      
      .login-screen {
        position: fixed; inset: 0; z-index: 9999;
        display: flex; align-items: center; justify-content: center;
        background: #000;
        padding: 20px;
      }
      .login-card { width: 100%; max-width: 400px; }
      
      .table-container { 
        border: 1px solid var(--accents-2); 
        border-radius: 12px; 
        overflow-x: auto; 
        background: var(--ds-background-200); 
        box-shadow: var(--shadow-level-2);
      }
      table { width: 100%; border-collapse: collapse; min-width: 800px; }
      th { background: var(--ds-background-300); padding: 16px; text-align: left; color: var(--accents-5); font-weight: 500; border-bottom: 1px solid var(--accents-2); }
      td { padding: 16px; border-top: 1px solid var(--accents-2); vertical-align: middle; }
      
      .status-badge {
        display: inline-flex;
        padding: 4px 10px; border-radius: 9999px; font-size: 10px; font-weight: 800;
        text-transform: uppercase; letter-spacing: 0.1em;
      }

      .mobile-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px; border-bottom: 1px solid var(--accents-2);
        background: #000; position: sticky; top: 0; z-index: 100;
      }

      .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
      }

      .stat-card {
        padding: 24px;
        background: var(--ds-background-200);
        border: 1px solid var(--accents-2);
        border-radius: 12px;
      }

      .tab-content { display: none; }
      .tab-content.active { display: block; }
    </style>
  </head>
  <body>
    <!-- ── Login ── -->
    <div id="loginScreen" class="login-screen">
      <div class="login-card card animate-fade-in">
        <div class="mb-8 text-center">
          <div class="flex items-center justify-center gap-2 mb-4">
             <span class="caption-mono text-cyan font-bold text-2xl">BRICK</span>
             <span class="caption-mono text-white font-bold text-2xl">RUSH</span>
          </div>
          <h1 class="display-sm">Command Center</h1>
          <p class="body-sm text-accents-5">Encrypted Access Only</p>
        </div>
        <form id="loginForm" class="space-y-4">
          <div>
            <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Security Identifier</label>
            <input type="text" id="user" class="form-input" placeholder="admin" required />
          </div>
          <div>
            <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Access Key</label>
            <input type="password" id="pass" class="form-input" placeholder="••••••••" required />
          </div>
          <button type="submit" class="btn-primary w-full mt-6">Authorize Protocol</button>
        </form>
      </div>
    </div>

    <!-- ── Dashboard ── -->
    <div id="dashboard" class="admin-layout hidden">
      <!-- Mobile Header -->
      <header class="mobile-header md:hidden">
        <div class="flex items-center gap-2">
           <span class="caption-mono text-cyan font-bold">BRICK</span>
           <span class="caption-mono text-white font-bold">RUSH</span>
        </div>
        <button id="logoutMob" class="text-error text-xs caption-mono">Logout</button>
      </header>

      <aside class="sidebar hidden md:flex">
        <div class="mb-10">
          <span class="caption-mono text-cyan font-bold text-xl">BRICK</span>
          <span class="caption-mono text-white font-bold text-xl">RUSH</span>
        </div>
        <div class="caption-mono text-accents-4 mb-4 text-[10px]">Operations</div>
        <button class="nav-link w-full text-left active" data-target="orders">Orders</button>
        <button class="nav-link w-full text-left" data-target="inventory">Products</button>
        <button class="nav-link w-full text-left" data-target="categories">Categories</button>
        <button class="nav-link w-full text-left" data-target="settings">Settings</button>
        
        <div class="mt-auto border-t border-accents-2 pt-8">
          <a href="/" class="nav-link block text-cyan mb-2">← Exit to Store</a>
          <button id="logout" class="nav-link w-full text-left text-error opacity-60 hover:opacity-100">Terminate Session</button>
        </div>
      </aside>

      <main class="main-content">
        <!-- Orders Tab -->
        <section id="orders" class="tab-content active animate-fade-in">
          <header class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-10">
            <div>
              <h2 class="display-md mb-1">Order Pipeline</h2>
              <p class="body-sm text-accents-5">Process and fulfill customer requests.</p>
            </div>
            <div class="flex items-center gap-2">
              <button onclick="window.clearOrders()" class="btn-secondary !text-xs !py-1 px-3 border-error/20 text-error">Wipe Data</button>
            </div>
          </header>

          <div class="stats-grid mb-10">
            <div class="stat-card">
              <div class="caption-mono text-[10px] text-accents-5 mb-1 uppercase tracking-wider">Total Revenue</div>
              <div id="statRevenue" class="display-sm text-cyan">Tk 0</div>
            </div>
            <div class="stat-card">
              <div class="caption-mono text-[10px] text-accents-5 mb-1 uppercase tracking-wider">Gross Orders</div>
              <div id="statOrders" class="display-sm">0</div>
            </div>
            <div class="stat-card">
              <div class="caption-mono text-[10px] text-accents-5 mb-1 uppercase tracking-wider">Growth Metrics</div>
              <div id="orderBreakdownChart" class="flex items-end gap-1 h-12 pt-2">
                <!-- Simple CSS Chart will go here -->
              </div>
            </div>
          </div>

          <div class="table-container">
            <table>
              <thead>
                <tr>
                  <th class="caption-mono text-[10px]">Ref ID</th>
                  <th class="caption-mono text-[10px]">Customer</th>
                  <th class="caption-mono text-[10px]">Items</th>
                  <th class="caption-mono text-[10px]">Total</th>
                  <th class="caption-mono text-[10px]">Status</th>
                  <th class="caption-mono text-[10px] text-right">Actions</th>
                </tr>
              </thead>
              <tbody id="ordersBody"></tbody>
            </table>
          </div>
        </section>

        <!-- Inventory Tab -->
        <section id="inventory" class="tab-content animate-fade-in">
          <header class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-10">
            <div>
              <h2 class="display-md mb-1">Inventory Management</h2>
              <p class="body-sm text-accents-5">Manage products and stock levels.</p>
            </div>
            <button onclick="window.showProductModal()" class="btn-primary !text-xs !py-1.5 px-4">+ Add Minifigure</button>
          </header>

          <div class="table-container">
            <table>
              <thead>
                <tr>
                  <th class="caption-mono text-[10px]">Product</th>
                  <th class="caption-mono text-[10px]">Category</th>
                  <th class="caption-mono text-[10px]">Price</th>
                  <th class="caption-mono text-[10px] text-right">Actions</th>
                </tr>
              </thead>
              <tbody id="inventoryBody"></tbody>
            </table>
          </div>
        </section>

        <!-- Categories Tab -->
        <section id="categories" class="tab-content animate-fade-in">
          <header class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-10">
            <div>
              <h2 class="display-md mb-1">Category Control</h2>
              <p class="body-sm text-accents-5">Define and organize product segments.</p>
            </div>
            <form id="categoryForm" class="flex gap-2">
              <input type="text" id="catName" class="form-input !py-1.5 !px-3 !text-xs" placeholder="New category..." required />
              <button type="submit" class="btn-primary !text-xs !py-1.5 px-4">Add</button>
            </form>
          </header>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="categoryList">
            <!-- Categories will be injected here -->
          </div>
        </section>

        <!-- Settings Tab -->
        <section id="settings" class="tab-content animate-fade-in">
          <header class="mb-10">
            <h2 class="display-md mb-1">System Settings</h2>
            <p class="body-sm text-accents-5">Configure contact and payment gateway details.</p>
          </header>

          <div class="card p-8 max-w-2xl">
            <form id="settingsForm" class="space-y-6">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Support Contact</label>
                  <input type="text" id="setContact" class="form-input" placeholder="+880..." />
                </div>
                <div>
                  <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Bkash Merchant</label>
                  <input type="text" id="setBkash" class="form-input" placeholder="017..." />
                </div>
                <div>
                  <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Nagad Personal</label>
                  <input type="text" id="setNagad" class="form-input" placeholder="019..." />
                </div>
              </div>
              <div class="pt-4">
                <button type="submit" class="btn-primary px-8">Update Protocol</button>
              </div>
            </form>
          </div>
        </section>
      </main>
    </div>

    <!-- ── Modals ── -->
    <div id="productModal" class="modal-overlay hidden">
      <div class="modal-content card max-w-lg w-full">
        <h3 id="modalTitle" class="display-sm mb-6">New Minifigure</h3>
        <form id="productForm" class="space-y-4">
          <input type="hidden" id="editIndex" value="-1" />
          <div>
            <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Product Name</label>
            <input type="text" id="pName" class="form-input" required />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Category</label>
              <select id="pCat" class="form-input">
                <option>Marvel</option>
                <option>DC</option>
                <option>Anime</option>
                <option>Star Wars</option>
                <option>One Piece</option>
                <option>Stranger Things</option>
                <option>Exclusive</option>
              </select>
            </div>
            <div>
              <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Price (Tk)</label>
              <input type="number" id="pPrice" class="form-input" required />
            </div>
          </div>
          <div>
            <label class="caption-mono text-accents-5 mb-2 block text-[10px]">Image URL</label>
            <input type="text" id="pImage" class="form-input" placeholder="https://..." required />
          </div>
          <div class="flex gap-4 mt-8">
            <button type="button" onclick="window.closeProductModal()" class="btn-secondary flex-1">Cancel</button>
            <button type="submit" class="btn-primary flex-1">Save Unit</button>
          </div>
        </form>
      </div>
    </div>

    <script is:inline>
      const USER = 'admin';
      const PASS = 'brickrush2024';

      // ─── Auth ───
      function checkAuth() {
        if (localStorage.getItem('jv_admin')) {
          showDashboard();
        } else {
          document.body.classList.add('loaded');
        }
      }

      document.getElementById('loginForm').onsubmit = (e) => {
        e.preventDefault();
        const u = document.getElementById('user').value;
        const p = document.getElementById('pass').value;
        if (u === USER && p === PASS) {
          localStorage.setItem('jv_admin', 'true');
          showDashboard();
        } else {
          alert('Access Denied: Protocol Violation');
        }
      };

      function showDashboard() {
        const loginScreen = document.getElementById('loginScreen');
        const dashboard = document.getElementById('dashboard');
        
        if (loginScreen) {
          loginScreen.style.setProperty('display', 'none', 'important');
          loginScreen.classList.add('hidden');
        }
        if (dashboard) {
          dashboard.style.setProperty('display', 'flex', 'important');
          dashboard.classList.remove('hidden');
        }
        
        init();
        setTimeout(() => {
          document.body.classList.add('loaded');
        }, 50);
      }

      const logout = () => {
        localStorage.removeItem('jv_admin');
        location.reload();
      };
      document.getElementById('logout').onclick = logout;
      document.getElementById('logoutMob').onclick = logout;

      // ─── State ───
      let orders = [];
      let products = [];
      let categories = [];
      let settings = { contact: '', bkash: '', nagad: '' };

      const defaultProducts = [
        { name: 'Iron Man Mk 85', price: 'Tk 450', image: 'https://placehold.co/400x533/111/50e3c2?text=Iron+Man&font=inter', category: 'Marvel' },
        { name: 'Batman Dark Knight', price: 'Tk 380', image: 'https://placehold.co/400x533/111/50e3c2?text=Batman&font=inter', category: 'DC' },
        { name: 'Goku Ultra Instinct', price: 'Tk 520', image: 'https://placehold.co/400x533/111/50e3c2?text=Goku&font=inter', category: 'Anime' },
        { name: 'Eleven', price: 'Tk 420', image: 'https://placehold.co/400x533/111/50e3c2?text=Eleven&font=inter', category: 'Stranger Things' },
        { name: 'Spider-Man Miles', price: 'Tk 480', image: 'https://placehold.co/400x533/111/50e3c2?text=Miles&font=inter', category: 'Marvel' },
        { name: 'Luffy Gear 5', price: 'Tk 550', image: 'https://placehold.co/400x533/111/50e3c2?text=Luffy&font=inter', category: 'One Piece' },
        { name: 'Mandalorian', price: 'Tk 600', image: 'https://placehold.co/400x533/111/50e3c2?text=Mando&font=inter', category: 'Star Wars' },
        { name: 'Naruto Baryon', price: 'Tk 520', image: 'https://placehold.co/400x533/111/50e3c2?text=Naruto&font=inter', category: 'Anime' },
      ];
      const defaultCategories = ['Marvel', 'DC', 'Anime', 'Star Wars', 'One Piece', 'Stranger Things', 'Exclusive'];

      function loadData() {
        try {
          orders = JSON.parse(localStorage.getItem('jv_orders') || '[]');
          products = JSON.parse(localStorage.getItem('jv_products') || JSON.stringify(defaultProducts));
          categories = JSON.parse(localStorage.getItem('jv_categories') || JSON.stringify(defaultCategories));
          settings = JSON.parse(localStorage.getItem('jv_settings') || JSON.stringify({ contact: '', bkash: '', nagad: '' }));
          
          if (!localStorage.getItem('jv_products')) localStorage.setItem('jv_products', JSON.stringify(defaultProducts));
          if (!localStorage.getItem('jv_categories')) localStorage.setItem('jv_categories', JSON.stringify(defaultCategories));
          
          document.getElementById('setContact').value = settings.contact || '';
          document.getElementById('setBkash').value = settings.bkash || '';
          document.getElementById('setNagad').value = settings.nagad || '';
        } catch (e) { console.error(e); }
      }

      function saveData() {
        localStorage.setItem('jv_orders', JSON.stringify(orders));
        localStorage.setItem('jv_products', JSON.stringify(products));
        localStorage.setItem('jv_categories', JSON.stringify(categories));
        localStorage.setItem('jv_settings', JSON.stringify(settings));
        renderAll();
      }

      function renderAll() {
        renderStats();
        renderOrders();
        renderInventory();
        renderCategories();
        updateCategoryDropdowns();
      }

      function renderStats() {
        const totalRev = orders.reduce((sum, o) => sum + (Number(o.total) || 0), 0);
        document.getElementById('statRevenue').textContent = 'Tk ' + totalRev.toLocaleString();
        document.getElementById('statOrders').textContent = orders.length;
        
        const chart = document.getElementById('orderBreakdownChart');
        if (!chart) return;
        const validTotals = orders.map(o => Number(o.total) || 0);
        const maxTotal = Math.max(...validTotals, 1000);
        chart.innerHTML = orders.slice(0, 10).reverse().map(o => {
          const h = ((Number(o.total) || 0) / maxTotal) * 100;
          return `<div class="flex-1 bg-cyan/20 border-t-2 border-cyan rounded-t-sm" style="height: ${h}%"></div>`;
        }).join('');
      }

      function renderOrders() {
        const body = document.getElementById('ordersBody');
        if (!body) return;
        if (orders.length === 0) {
          body.innerHTML = `<tr><td colspan="6" class="text-center py-12 text-accents-4 italic text-sm">No orders yet.</td></tr>`;
          return;
        }
        body.innerHTML = orders.map((o, i) => `
          <tr class="hover:bg-accents-1/30">
            <td class="caption-mono text-[11px] font-bold">${o.id || '???'}</td>
            <td>
              <div class="text-white font-medium text-xs">${o.customer?.name || 'Unknown'}</div>
              <div class="text-[10px] text-accents-4">${o.customer?.phone || 'N/A'}</div>
            </td>
            <td>
              <div class="text-[10px] text-accents-5 truncate max-w-[200px]">${(o.items || []).map(it => it.name).join(', ')}</div>
            </td>
            <td class="text-cyan font-bold text-xs">Tk ${(Number(o.total) || 0).toLocaleString()}</td>
            <td><span class="status-badge border border-current/20">${o.status || 'pending'}</span></td>
            <td class="text-right">
              <button onclick="window.deleteOrder(${i})" class="text-error text-[10px] caption-mono">Delete</button>
            </td>
          </tr>
        `).join('');
      }

      function renderInventory() {
        const body = document.getElementById('inventoryBody');
        if (!body) return;
        body.innerHTML = products.map((p, i) => `
          <tr class="hover:bg-accents-1/30">
            <td class="flex items-center gap-3">
              <img src="${p.image}" class="w-8 h-8 rounded object-cover" />
              <span class="text-white text-xs font-medium">${p.name}</span>
            </td>
            <td><span class="text-accents-5 text-[10px] caption-mono">${p.category}</span></td>
            <td class="text-cyan font-bold text-xs">${p.price}</td>
            <td class="text-right space-x-2">
              <button onclick="window.editProduct(${i})" class="text-accents-5 text-[10px] caption-mono">Edit</button>
              <button onclick="window.deleteProduct(${i})" class="text-error text-[10px] caption-mono">Delete</button>
            </td>
          </tr>
        `).join('');
      }

      function renderCategories() {
        const list = document.getElementById('categoryList');
        if (!list) return;
        list.innerHTML = categories.map((c, i) => `
          <div class="card p-4 flex items-center justify-between group">
            <span class="text-sm font-medium text-white">${c}</span>
            <button onclick="window.deleteCategory(${i})" class="text-error opacity-0 group-hover:opacity-100 text-[10px] caption-mono">Remove</button>
          </div>
        `).join('');
      }

      function updateCategoryDropdowns() {
        const select = document.getElementById('pCat');
        if (!select) return;
        const currentVal = select.value;
        select.innerHTML = categories.map(c => `<option value="${c}">${c}</option>`).join('');
        if (categories.includes(currentVal)) select.value = currentVal;
      }

      window.deleteCategory = (i) => {
        if (confirm('Delete category?')) { categories.splice(i, 1); saveData(); }
      };

      document.getElementById('categoryForm').onsubmit = (e) => {
        e.preventDefault();
        const inp = document.getElementById('catName');
        if (inp.value && !categories.includes(inp.value)) { categories.push(inp.value); saveData(); inp.value = ''; }
      };

      document.getElementById('settingsForm').onsubmit = (e) => {
        e.preventDefault();
        settings = {
          contact: document.getElementById('setContact').value,
          bkash: document.getElementById('setBkash').value,
          nagad: document.getElementById('setNagad').value
        };
        saveData();
        alert('Settings Saved');
      };

      window.deleteOrder = (i) => {
        if (confirm('Delete order?')) { orders.splice(i, 1); saveData(); }
      };

      window.clearOrders = () => {
        if (confirm('Clear all orders?')) { orders = []; saveData(); }
      };

      const pModal = document.getElementById('productModal');
      const pForm = document.getElementById('productForm');

      window.showProductModal = () => {
        document.getElementById('editIndex').value = '-1';
        pForm.reset();
        pModal.classList.remove('hidden');
      };

      window.closeProductModal = () => pModal.classList.add('hidden');

      window.editProduct = (i) => {
        const p = products[i];
        document.getElementById('editIndex').value = i;
        document.getElementById('pName').value = p.name;
        document.getElementById('pCat').value = p.category;
        document.getElementById('pPrice').value = p.price.replace('Tk ', '');
        document.getElementById('pImage').value = p.image;
        pModal.classList.remove('hidden');
      };

      window.deleteProduct = (i) => {
        if (confirm('Delete product?')) { products.splice(i, 1); saveData(); }
      };

      pForm.onsubmit = (e) => {
        e.preventDefault();
        const i = parseInt(document.getElementById('editIndex').value);
        const newP = {
          name: document.getElementById('pName').value,
          category: document.getElementById('pCat').value,
          price: 'Tk ' + document.getElementById('pPrice').value,
          image: document.getElementById('pImage').value
        };
        if (i === -1) products.push(newP);
        else products[i] = newP;
        saveData();
        window.closeProductModal();
      };

      document.querySelectorAll('.sidebar .nav-link[data-target]').forEach(btn => {
        btn.onclick = () => {
          document.querySelectorAll('.sidebar .nav-link').forEach(b => b.classList.remove('active', '!bg-accents-1'));
          btn.classList.add('active', '!bg-accents-1');
          document.querySelectorAll('.tab-content').forEach(tc => {
            tc.classList.remove('active');
            tc.style.setProperty('display', 'none', 'important');
          });
          const target = document.getElementById(btn.dataset.target);
          if (target) {
            target.classList.add('active');
            target.style.setProperty('display', 'block', 'important');
          }
        };
      });

      function init() { loadData(); renderAll(); }
      checkAuth();
    </script>
  </body>
</html>
