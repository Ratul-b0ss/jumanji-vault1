    <script is:inline>
      // ─── Confirm Modal System ───
      window.showConfirmModal = function(message) {
        return new Promise(function(resolve) {
          var modal = document.getElementById('confirmModal');
          var msgEl = document.getElementById('confirmMessage');
          var titleEl = document.getElementById('confirmTitle');
          var confirmBtn = document.getElementById('confirmDelete');
          var cancelBtn = document.getElementById('confirmCancel');

          if (!modal || !msgEl || !titleEl) { resolve(false); return; }

          msgEl.textContent = message;
          titleEl.textContent = 'Confirm Delete';
          confirmBtn.textContent = 'Delete';
          modal.classList.remove('hidden');
          setTimeout(function() { modal.classList.remove('opacity-0'); }, 10);
          document.body.classList.add('no-scroll');

          function cleanup() {
            modal.classList.add('hidden');
            modal.classList.add('opacity-0');
            document.body.classList.remove('no-scroll');
            confirmBtn.onclick = null;
            cancelBtn.onclick = null;
            modal.onclick = null;
          }

          confirmBtn.onclick = function() {
            cleanup();
            resolve(true);
          };
          cancelBtn.onclick = function() {
            cleanup();
            resolve(false);
          };

          // Click overlay to cancel
          modal.onclick = function(e) {
            if (e.target === modal) {
              cleanup();
              resolve(false);
            }
          };
        });
      };

      // ─── Toast System ───
      window.showToast = function(message, type) {
        type = type || 'info';
        var container = document.getElementById('toastContainer');
        if (!container) return;
        var el = document.createElement('div');
        el.className = 'toast ' + type;
        el.textContent = message;
        container.appendChild(el);
        setTimeout(function() {
          el.style.animation = 'toastOut 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards';
          setTimeout(function() { if (el.parentNode) el.parentNode.removeChild(el); }, 250);
        }, 2500);
      };

      // ─── Supabase Client ───
      var SUPABASE_URL = 'https://bpgdniisgxzgrrcqlnwp.supabase.co';
      var SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJwZ2RuaWlzZ3h6Z3JyY3FsbndwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE3NjU2ODIsImV4cCI6MjA5NzM0MTY4Mn0.krm-gAAveC4y8bBIwEMFTggXSDzn4Ypj_r5UjoJ5uuk';
      var ADMIN_USER = 'admin';
      var ADMIN_PASS = 'brickrush2024';

      // Simple helper to call Supabase REST API
      function supabaseRequest(method, path, body, headers) {
        var url = SUPABASE_URL + '/rest/v1/' + path;
        var token = getToken();
        var options = {
          method: method,
          headers: {
            'apikey': SUPABASE_ANON_KEY,
            'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
            'Content-Type': 'application/json',
            'Prefer': 'return=representation',
            ...(token ? { 'x-admin-token': token } : {}),
            ...(headers || {})
          }
        };
        if (body && method !== 'GET') options.body = JSON.stringify(body);
        return fetch(url, options).then(function(r) {
          if (!r.ok) throw new Error(r.statusText);
          // DELETE / PATCH with return=minimal can return empty body (204 or 200 with no content)
          // Read as text first, then parse conditionally to avoid JSON parse errors on empty bodies
          return r.text().then(function(text) {
            return text ? JSON.parse(text) : null;
          });
        });
      }

      function getToken() { return localStorage.getItem('jv_token'); }

      // ── Sidebar ──
      var sb = document.getElementById('sb'), ham = document.getElementById('hamBtn'), ol = document.getElementById('ol');
      ham.onclick = function() { if (window.innerWidth <= 1024) { sb.classList.toggle('open'); ol.classList.toggle('on'); } };
      ol.onclick = function() { sb.classList.remove('open'); ol.classList.remove('on'); };

      // ─── Auth ───
      document.getElementById('loginForm').onsubmit = async function(e) {
        e.preventDefault();
        var user = document.getElementById('user').value;
        var pass = document.getElementById('pass').value;
        if (user !== ADMIN_USER || pass !== ADMIN_PASS) { window.showToast('Access Denied', 'error'); return; }

        // Generate token and store in Supabase
        var chars = 'abcdefghijklmnopqrstuvwxyz0123456789';
        var token = '';
        for (var i = 0; i < 32; i++) token += chars[Math.floor(Math.random() * chars.length)];
        token += Date.now().toString(36);

        try {
          await supabaseRequest('POST', 'admin_sessions', { token: token });
          localStorage.setItem('jv_token', token);
          localStorage.setItem('jv_admin', 'true');
          document.body.classList.add('loaded');
          document.getElementById('loginScreen').style.display = 'none';
          document.getElementById('dash').style.display = 'flex';
          init();
        } catch(e) { window.showToast('Server error — check connection', 'error'); }
      };

      // Auto-login check
      (async function() {
        if (localStorage.getItem('jv_admin') && localStorage.getItem('jv_token')) {
          try {
            var sessions = await supabaseRequest('GET', 'admin_sessions?token=eq.' + localStorage.getItem('jv_token') + '&select=token');
            if (sessions && sessions.length > 0) {
              document.body.classList.add('loaded');
              document.getElementById('loginScreen').style.display = 'none';
              document.getElementById('dash').style.display = 'flex';
              setTimeout(init, 50);
              return;
            }
          } catch(e) {}
          localStorage.removeItem('jv_token');
          localStorage.removeItem('jv_admin');
        }
        document.body.classList.add('loaded');
      })();

      document.getElementById('logoutBtn').onclick = async function() {
        try {
          await supabaseRequest('DELETE', 'admin_sessions?token=eq.' + getToken(), null, { Prefer: 'return=minimal' });
        } catch(e) {}
        localStorage.removeItem('jv_token');
        localStorage.removeItem('jv_admin');
        location.reload();
      };

      // ─── Tab Navigation ───
      document.querySelectorAll('[data-tab]').forEach(function(btn) {
        btn.onclick = function() {
          document.querySelectorAll('[data-tab]').forEach(function(b) { b.classList.remove('on'); });
          btn.classList.add('on');
          document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('on'); });
          var target = document.getElementById(btn.getAttribute('data-tab'));
          if (target) target.classList.add('on');
          document.getElementById('pgTitle').textContent = btn.querySelector('span:last-child').textContent;
          if (window.innerWidth <= 1024) { sb.classList.remove('open'); ol.classList.remove('on'); }
        };
      });

      // ─── Data ───
      var orders = [], products = [], categories = [], coupons = [];
      var settings = { contact: '', bkash: '', nagad: '', facebook: '', instagram: '', fee_ctg: 70, fee_outside: 130 };

      async function load() {
        // Show glowing loader spinners inside dashboard tabs during Supabase fetching
        var spinner = '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px 20px;gap:12px;width:100%;grid-column:1/-1;">' +
          '<div style="width:24px;height:24px;border:2px solid rgba(80,227,194,0.08);border-top-color:var(--cyan);border-radius:50%;animation:dashSpin 0.8s linear infinite;box-shadow:0 0 10px rgba(80,227,194,0.15);"></div>' +
          '<span class="caption-mono text-accents-4 text-[9px] tracking-widest">CONNECTING TO VAULT...</span>' +
          '</div>';
        
        var ordersBody = document.getElementById('ordersBody');
        if (ordersBody) ordersBody.innerHTML = spinner;
        var invBody = document.getElementById('invBody');
        if (invBody) invBody.innerHTML = spinner;
        var catList = document.getElementById('catList');
        if (catList) catList.innerHTML = spinner;

        try {
          var [p, c, o, s, cp] = await Promise.all([
            supabaseRequest('GET', 'products?order=id.asc').catch(function() { return []; }),
            supabaseRequest('GET', 'categories?order=name.asc').catch(function() { return []; }),
            supabaseRequest('GET', 'orders?order=created_at.desc').catch(function() { return []; }),
            supabaseRequest('GET', 'settings?select=*&limit=1').catch(function() { return []; }),
            supabaseRequest('GET', 'coupons?order=code.asc').catch(function() { return []; })
          ]);
          products = Array.isArray(p) ? p : [];
          categories = Array.isArray(c) ? c : [];
          orders = Array.isArray(o) ? o : [];
          coupons = Array.isArray(cp) ? cp : [];
          var sRow = Array.isArray(s) && s.length > 0 ? s[0] : {};
          settings = sRow;
 
          document.getElementById('fContact').value = settings.contact || '';
          document.getElementById('fBkash').value = settings.bkash || '';
          document.getElementById('fNagad').value = settings.nagad || '';
          document.getElementById('fFacebook').value = settings.facebook || '';
          document.getElementById('fInstagram').value = settings.instagram || '';
          document.getElementById('fFeeCtg').value = settings.fee_ctg || '70';
          document.getElementById('fFeeOutside').value = settings.fee_outside || '130';
 
          render();
        } catch(e) { console.error(e); }
      }

      function render() { renderStats(); renderOrders(); renderInv(); renderCats(); renderCoupons(); updCats(); }

      function renderStats() {
        var rev = orders.reduce(function(s, o) { return o.status !== 'cancelled' ? s + (Number(o.total)||0) : s; }, 0);
        document.getElementById('statRev').textContent = 'Tk ' + rev.toLocaleString();
        document.getElementById('statOrd').textContent = orders.length;
      }

      window.deleteOrder = async function(i) {
        var confirmed = await window.showConfirmModal('Are you sure you want to delete this order? This action cannot be undone.');
        if (!confirmed) return;
        var originalOrders = [...orders];
        var deletedOrder = orders[i];
        
        // Optimistic Update
        orders.splice(i, 1);
        render();
        window.showToast('Deleting order...', 'info');

        try {
          await supabaseRequest('DELETE', 'orders?id=eq.' + encodeURIComponent(deletedOrder.id), null, { Prefer: 'return=minimal' });
          window.showToast('Order deleted successfully', 'success');
        } catch(e) {
          orders = originalOrders;
          render();
          window.showToast('Failed to delete order', 'error');
        }
      };

      window.updateOrderStatus = async function(i, status) {
        var oldStatus = orders[i].status;

        // Optimistic Update
        orders[i].status = status;
        render();
        window.showToast('Updating status...', 'info');

        try {
          await supabaseRequest('PATCH', 'orders?id=eq.' + encodeURIComponent(orders[i].id), { status: status }, { Prefer: 'return=minimal' });
          window.showToast('Order status updated', 'success');
        } catch(e) {
          orders[i].status = oldStatus;
          render();
          window.showToast('Failed to update status', 'error');
        }
      };

      function renderOrders() {
        var body = document.getElementById('ordersBody');
        if (!body) return;
        if (!orders.length) { body.innerHTML = '<div class="empty"><span class="empty-e">📦</span><span class="empty-t">No orders yet.</span></div>'; return; }

        body.innerHTML = orders.map(function(o,i) {
          var st = (o.status || 'pending').toLowerCase();
          var stCls = st === 'pending' ? 'pending' : st === 'processing' ? 'process' : st === 'completed' ? 'done' : st === 'cancelled' ? 'cancelled' : 'pending';
          var zoneLabel = o.zone === 'ctg' ? 'Inside Chittagong' : o.zone === 'outside' ? 'Outside Chittagong' : 'Not set';
          var zoneFee = o.delivery_fee ? 'Tk ' + Number(o.delivery_fee).toLocaleString() : '';
          var items = typeof o.items_json === 'string' ? JSON.parse(o.items_json) : (o.items || []);
          var itemsHtml = items.map(function(it) {
            var ip = parseInt(it.price ? it.price.replace(/[^0-9]/g, '') : '0') || 0;
            return '<span style="display:flex;justify-content:space-between;gap:8px;font-size:12px;color:#eaeaea;"><span>' + it.name + ' <span style="color:#888;">x' + (it.qty || 1) + '</span></span><span style="color:#888;">Tk ' + (ip * (it.qty || 1)).toLocaleString() + '</span></span>';
          }).join('');

          return '<div class="oc">' +
            '<div class="oc-top"><span class="oc-id">#' + (o.id || '???') + '</span><span class="sbad ' + stCls + '">' + (o.status || 'pending') + '</span></div>' +
            '<div class="oc-body">' +
              '<div class="oc-f"><span class="oc-fl">Customer</span><span class="oc-fv">' + (o.customer_name || 'Unknown') + '</span><span style="font-size:11px;color:#888;">' + (o.customer_phone || '') + '</span><span style="font-size:10px;color:#666;">' + (o.customer_address || '') + '</span></div>' +
              '<div class="oc-f"><span class="oc-fl">Zone</span><span class="oc-fv" style="font-size:13px;">' + zoneLabel + '</span><span style="font-size:11px;color:#888;">' + zoneFee + '</span></div>' +
              '<div class="oc-f" style="grid-column:1/-1;"><span class="oc-fl" style="margin-bottom:4px;">Items</span>' + itemsHtml + '</div>' +
              '<div class="oc-f"><span class="oc-fl">Payment</span><span class="oc-fv" style="text-transform:uppercase;font-size:12px;">' + (o.payment_method || 'cod') + '</span><span style="font-size:10px;color:#888;">TrxID: ' + (o.payment_trxid || '—') + '</span></div>' +
              '<div class="oc-f"><span class="oc-fl">Total</span><span class="oc-fv m">Tk ' + (Number(o.total)||0).toLocaleString() + '</span></div>' +
            '</div>' +
            '<div class="oc-btm">' +
              '<span style="font-size:10px;color:#666;">' + (o.created_at ? new Date(o.created_at).toLocaleDateString() : '') + '</span>' +
              '<div style="display:flex;gap:6px;align-items:center;">' +
                '<select class="status-select" onchange="window.updateOrderStatus(' + i + ', this.value)">' +
                  '<option value="pending"' + (st === 'pending' ? ' selected' : '') + '>Pending</option>' +
                  '<option value="processing"' + (st === 'processing' ? ' selected' : '') + '>Processing</option>' +
                  '<option value="completed"' + (st === 'completed' ? ' selected' : '') + '>Completed</option>' +
                  '<option value="cancelled"' + (st === 'cancelled' ? ' selected' : '') + '>Cancelled</option>' +
                '</select>' +
                '<button onclick="window.deleteOrder(' + i + ')" class="btn-sm danger">Delete</button>' +
              '</div>' +
            '</div>' +
          '</div>';
        }).join('');
      }

      window.deleteProduct = async function(i) {
        var confirmed = await window.showConfirmModal('Are you sure you want to delete this product? This action cannot be undone.');
        if (!confirmed) return;
        var originalProducts = [...products];
        var deletedProduct = products[i];

        // Optimistic Update
        products.splice(i, 1);
        render();
        window.showToast('Deleting product...', 'info');

        try {
          await supabaseRequest('DELETE', 'products?id=eq.' + deletedProduct.id, null, { Prefer: 'return=minimal' });
          window.showToast('Product deleted successfully', 'success');
        } catch(e) {
          products = originalProducts;
          render();
          window.showToast('Failed to delete product', 'error');
        }
      };

      function renderInv() {
        var body = document.getElementById('invBody');
        if (!body) return;
        if (!products.length) { body.innerHTML = '<div class="empty"><span class="empty-e">🛡️</span><span class="empty-t">No products.</span></div>'; return; }
        body.innerHTML = products.map(function(p,i) {
          var hd = p.discount_price && p.discount_price !== p.price;
          var stockLabel = p.in_stock === false 
            ? '<span style="color:#ef4444;font-size:10px;font-weight:600;margin-left:8px;text-transform:uppercase;">(Out of Stock)</span>' 
            : '';
          return '<div class="pc">' +
            '<img src="' + p.image + '" class="pc-img" />' +
            '<div class="pc-info"><div class="pc-name">' + p.name + stockLabel + '</div><span class="pc-cat">' + p.category + '</span></div>' +
            (hd ? '<div class="pc-price sold">' + p.discount_price + '<span class="pc-old">' + p.price + '</span></div>' : '<div class="pc-price">' + p.price + '</div>') +
            '<div class="pc-acts">' +
              '<button onclick="editProd(' + i + ')" class="btn-sm cyan">Edit</button>' +
              '<button onclick="window.deleteProduct(' + i + ')" class="btn-sm danger">Del</button>' +
            '</div>' +
          '</div>';
        }).join('');
      }

      function editProd(i) {
        var p = products[i];
        document.getElementById('editIx').value = i;
        document.getElementById('fName').value = p.name;
        document.getElementById('fCat').value = p.category;
        document.getElementById('fPrice').value = p.price.replace('Tk ','');
        document.getElementById('fDisc').value = p.discount_price ? p.discount_price.replace('Tk ','') : '';
        document.getElementById('fImg').value = p.image.startsWith('data:') ? '' : p.image;
        document.getElementById('fInStock').checked = p.in_stock !== false;
        updatePrev(p.image);
        document.getElementById('pModal').classList.remove('hidden');
        document.body.classList.add('no-scroll');
      }

      window.deleteCategory = async function(i) {
        var confirmed = await window.showConfirmModal('Are you sure you want to delete this category? Products in this category won\'t be affected.');
        if (!confirmed) return;
        try { await supabaseRequest('DELETE', 'categories?id=eq.' + categories[i].id, null, { Prefer: 'return=minimal' }); categories.splice(i, 1); render(); window.showToast('Category deleted', 'success'); }
        catch(e) { window.showToast('Failed to delete', 'error'); }
      };

      function renderCats() {
        var list = document.getElementById('catList');
        if (!list) return;
        if (!categories.length) { list.innerHTML = '<div class="empty" style="grid-column:1/-1"><span class="empty-e">🏷️</span><span class="empty-t">No categories.</span></div>'; return; }
        list.innerHTML = categories.map(function(c,i) {
          return '<div class="cc"><div class="cc-l"><div class="cc-i">' + c.name.charAt(0) + '</div><span class="cc-n">' + c.name + '</span></div><button onclick="window.deleteCategory(' + i + ')" class="btn-sm danger">Remove</button></div>';
        }).join('');
      }

      function updCats() {
        var sel = document.getElementById('fCat');
        if (!sel) return;
        var cur = sel.value;
        sel.innerHTML = categories.map(function(c) { return '<option value="' + c.name + '">' + c.name + '</option>'; }).join('');
        if (categories.some(function(c) { return c.name === cur; })) sel.value = cur;
      }

      document.getElementById('catForm').onsubmit = async function(e) {
        e.preventDefault();
        var inp = document.getElementById('catInp');
        if (inp.value && !categories.some(function(c) { return c.name === inp.value; })) {
          try {
            var newCat = await supabaseRequest('POST', 'categories', { name: inp.value });
            if (newCat && newCat.length > 0) categories.push(newCat[0]);
            else categories.push({ id: Date.now(), name: inp.value });
            render();
            inp.value = '';
            window.showToast('Category added', 'success');
          } catch(err) { window.showToast('Failed to add category', 'error'); }
        }
      };

      document.getElementById('setForm').onsubmit = async function(e) {
        e.preventDefault();
        var body = {
          contact: document.getElementById('fContact').value,
          bkash: document.getElementById('fBkash').value,
          nagad: document.getElementById('fNagad').value,
          facebook: document.getElementById('fFacebook').value,
          instagram: document.getElementById('fInstagram').value,
          fee_ctg: Number(document.getElementById('fFeeCtg').value) || 70,
          fee_outside: Number(document.getElementById('fFeeOutside').value) || 130
        };
        try {
          await supabaseRequest('PATCH', 'settings?id=eq.1', body, { Prefer: 'return=minimal' });
          settings = body;
          window.showToast('Settings saved', 'success');
        } catch(err) { window.showToast('Failed to save', 'error'); }
      };

      // ─── Coupon Management ───
      var cModal = document.getElementById('cModal');
      var cForm = document.getElementById('cForm');

      function renderCoupons() {
        var list = document.getElementById('couponList');
        if (!list) return;
        if (!coupons.length) { list.innerHTML = '<div class="empty"><span class="empty-e">🎟️</span><span class="empty-t">No coupons yet.</span></div>'; return; }

        list.innerHTML = coupons.map(function(c, i) {
          var isActive = c.active !== false;
          var expiry = c.expires_at ? new Date(c.expires_at).toLocaleDateString() : 'Never';
          var typeLabel = c.discount_type === 'percentage' ? c.discount_value + '%' : 'Tk ' + c.discount_value;
          var used = c.used_count || 0;
          var maxStr = c.max_uses > 0 ? used + '/' + c.max_uses : used + '/∞';
          return '<div class="cc">' +
            '<div class="cc-l" style="flex-wrap:wrap;">' +
              '<div class="cc-i" style="background:' + (isActive ? 'rgba(80,227,194,0.08)' : 'rgba(239,68,68,0.08)') + ';border-color:' + (isActive ? 'rgba(80,227,194,0.12)' : 'rgba(239,68,68,0.12)') + ';color:' + (isActive ? '#50e3c2' : '#ef4444') + ';">' + c.code.charAt(0) + '</div>' +
              '<div><span class="cc-n">' + c.code + '</span>' +
              '<div style="display:flex;gap:8px;font-size:10px;color:#666;margin-top:2px;flex-wrap:wrap;">' +
                '<span>' + typeLabel + '</span>' +
                '<span>Min: Tk ' + (c.min_order || 0) + '</span>' +
                '<span>Uses: ' + maxStr + '</span>' +
                '<span>Exp: ' + expiry + '</span>' +
              '</div></div>' +
            '</div>' +
            '<div style="display:flex;gap:4px;flex-shrink:0;">' +
              '<button onclick="window.toggleCoupon(' + i + ')" class="btn-sm ' + (isActive ? 'cyan' : 'danger') + '">' + (isActive ? 'Active' : 'Paused') + '</button>' +
              '<button onclick="window.deleteCoupon(' + i + ')" class="btn-sm danger">Del</button>' +
            '</div></div>';
        }).join('');
      }

      window.toggleCoupon = async function(i) {
        var c = coupons[i];
        var newActive = c.active === false ? true : false;
        try {
          await supabaseRequest('PATCH', 'coupons?id=eq.' + c.id, { active: newActive }, { Prefer: 'return=minimal' });
          coupons[i].active = newActive;
          render();
          window.showToast('Coupon ' + (newActive ? 'activated' : 'paused'), 'success');
        } catch(e) { window.showToast('Failed to update coupon', 'error'); }
      };

      window.deleteCoupon = async function(i) {
        var confirmed = await window.showConfirmModal('Delete coupon "' + coupons[i].code + '"?');
        if (!confirmed) return;
        try {
          await supabaseRequest('DELETE', 'coupons?id=eq.' + coupons[i].id, null, { Prefer: 'return=minimal' });
          coupons.splice(i, 1);
          render();
          window.showToast('Coupon deleted', 'success');
        } catch(e) { window.showToast('Failed to delete', 'error'); }
      };

      window.showCouponModal = function() {
        document.getElementById('cEditId').value = '';
        cForm.reset();
        document.getElementById('cType').value = 'percentage';
        cModal.classList.remove('hidden');
        document.body.classList.add('no-scroll');
      };

      window.closeCouponModal = function() {
        cModal.classList.add('hidden');
        document.body.classList.remove('no-scroll');
      };

      cForm.onsubmit = async function(e) {
        e.preventDefault();
        var editId = document.getElementById('cEditId').value;
        var code = document.getElementById('cCode').value.toUpperCase().trim();
        var body = {
          code: code,
          discount_type: document.getElementById('cType').value,
          discount_value: Number(document.getElementById('cValue').value),
          min_order: Number(document.getElementById('cMin').value) || 0,
          max_uses: Number(document.getElementById('cMax').value) || 0,
          expires_at: document.getElementById('cExpires').value ? new Date(document.getElementById('cExpires').value).toISOString() : null,
          active: true
        };

        var btn = cForm.querySelector('button[type="submit"]');
        btn.disabled = true;
        btn.textContent = 'Saving...';

        try {
          if (!editId) {
            var created = await supabaseRequest('POST', 'coupons', body);
            if (created && created.length > 0) coupons.push(created[0]);
            else coupons.push(body);
          } else {
            await supabaseRequest('PATCH', 'coupons?id=eq.' + editId, body, { Prefer: 'return=minimal' });
            var idx = coupons.findIndex(function(c) { return c.id == editId; });
            if (idx >= 0) coupons[idx] = { ...coupons[idx], ...body };
          }
          render();
          window.closeCouponModal();
          window.showToast('Coupon saved', 'success');
        } catch(err) {
          window.showToast('Failed to save coupon', 'error');
        } finally {
          btn.disabled = false;
          btn.textContent = 'Save Coupon';
        }
      };

      window.clearOrders = async function() {
        var confirmed = await window.showConfirmModal('Are you sure you want to clear ALL orders? This action cannot be undone.');
        if (!confirmed) return;
        try { await supabaseRequest('DELETE', 'orders?id=gt.0', null, { Prefer: 'return=minimal' }); orders = []; render(); window.showToast('All orders cleared', 'success'); }
        catch(e) { window.showToast('Failed to clear', 'error'); }
      };

      // ─── Product Modal ───
      var modal = document.getElementById('pModal');
      var pForm = document.getElementById('pForm');
      var pFile = document.getElementById('fFile');
      var pUrl = document.getElementById('fImg');
      var pPrev = document.getElementById('imgPrev');
      var imgData = '';

      function updatePrev(src) {
        if (src) { pPrev.innerHTML = '<img src="' + src + '" class="w-full h-full object-cover" />'; imgData = src; }
        else { pPrev.innerHTML = '<span class="text-xs text-accents-4">No image</span>'; imgData = ''; }
      }
      pUrl.oninput = function(e) { updatePrev(e.target.value); };

      // Upload image to Supabase Storage
      async function uploadImage(file) {
        var formData = new FormData();
        formData.append('file', file);
        var fileName = Date.now() + '-' + file.name.replace(/[^a-zA-Z0-9.]/g, '_');
        try {
          var res = await fetch(SUPABASE_URL + '/storage/v1/object/products/' + fileName, {
            method: 'POST',
            headers: {
              'apikey': SUPABASE_ANON_KEY,
              'Authorization': 'Bearer ' + SUPABASE_ANON_KEY
            },
            body: file
          });
          if (res.ok) return SUPABASE_URL + '/storage/v1/object/public/products/' + fileName;
          throw new Error('Upload failed');
        } catch(e) { throw e; }
      }

      pFile.onchange = async function(e) {
        var file = e.target.files[0];
        if (file) {
          if (file.size > 5 * 1024 * 1024) { window.showToast('Image too large (max 5MB)', 'warning'); return; }
          var reader = new FileReader();
          reader.onload = function(re) { updatePrev(re.target.result); };
          reader.readAsDataURL(file);
          pUrl.value = 'uploading...';
          try {
            var url = await uploadImage(file);
            pUrl.value = url;
            imgData = url;
            pUrl.style.color = '#50e3c2';
            window.showToast('Image uploaded', 'success');
          } catch(err) { window.showToast('Upload failed — use URL instead', 'error'); pUrl.value = ''; pUrl.style.color = ''; }
        }
      };

      window.showProductModal = function() {
        document.getElementById('editIx').value = '-1'; pForm.reset(); updatePrev(''); 
        document.getElementById('fInStock').checked = true;
        modal.classList.remove('hidden');
        document.body.classList.add('no-scroll');
      };
      window.closeProductModal = function() { modal.classList.add('hidden'); document.body.classList.remove('no-scroll'); };

      pForm.onsubmit = async function(e) {
        e.preventDefault();
        var ix = parseInt(document.getElementById('editIx').value);
        var finImg = pUrl.value || imgData;
        if (!finImg || finImg === 'uploading...') { window.showToast('Please add an image', 'warning'); return; }
        var disc = document.getElementById('fDisc').value;
        var prod = {
          name: document.getElementById('fName').value,
          category: document.getElementById('fCat').value,
          price: 'Tk ' + document.getElementById('fPrice').value,
          discount_price: disc ? 'Tk ' + disc : null,
          image: finImg,
          in_stock: document.getElementById('fInStock').checked
        };

        var submitBtn = pForm.querySelector('button[type="submit"]');
        var originalBtnText = submitBtn.textContent;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Saving...';

        try {
          if (ix === -1) {
            var created = await supabaseRequest('POST', 'products', prod);
            if (created && created.length > 0) products.push(created[0]);
            else products.push(prod);
          } else {
            // Optimistic edit
            var originalProd = { ...products[ix] };
            products[ix] = { ...products[ix], ...prod };
            render();
            window.closeProductModal();

            await supabaseRequest('PATCH', 'products?id=eq.' + products[ix].id, prod, { Prefer: 'return=minimal' });
          }
          
          if (ix === -1) {
            render();
            window.closeProductModal();
          }
          window.showToast('Product saved successfully', 'success');
        } catch(err) {
          window.showToast('Failed to save product', 'error');
          if (ix !== -1) {
            products[ix] = originalProd;
            render();
          }
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = originalBtnText;
        }
      };

      function init() { load(); }
    </script>
  </body>
</html>
