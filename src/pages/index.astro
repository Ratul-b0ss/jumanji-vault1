---
import Layout from '../layouts/Layout.astro';
---

<Layout title="JUMANJI VAULT - Premium LEGO Minifigures">

  <!-- HERO -->
  <section class="section-hero relative section-fade-in">
    <div class="page-container relative z-10 text-center">
      <!-- Headline -->
      <h1 class="typo-display-xl mx-auto mb-3 md:mb-5 text-gradient-brand" style="max-width: 800px; font-size: clamp(38px, 6vw, 72px); line-height: 1.05;">
        JUMANJI VAULT
      </h1>

      <p class="mx-auto mb-5 md:mb-8 text-gradient-gold" style="max-width: 520px; font-size: clamp(13px, 1.6vw, 15px); line-height: 1.6;">
        Marvel, DC, Anime, Dragon Ball Z, and more. Authentic detail, premium ABS plastic, cash on delivery across Bangladesh.
      </p>

      <!-- CTAs -->
      <div class="mb-6 md:mb-14">
        <a href="#products" class="btn-ghost hero-cta">
          Browse Collection
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1.5 md:ml-2">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Feature pills -->
      <div class="flex flex-wrap items-center justify-center gap-1.5 md:gap-2 px-0">
        <span class="badge-pill text-[11px] md:text-[13px] px-2 md:px-3 py-0.5 md:py-1">Cash on Delivery</span>
        <span class="badge-pill text-[11px] md:text-[13px] px-2 md:px-3 py-0.5 md:py-1">Premium ABS</span>
        <span class="badge-pill text-[11px] md:text-[13px] px-2 md:px-3 py-0.5 md:py-1">1-3 Day Delivery</span>
        <span class="badge-pill text-[11px] md:text-[13px] px-2 md:px-3 py-0.5 md:py-1">Accessories</span>
        <span class="badge-pill text-[11px] md:text-[13px] px-2 md:px-3 py-0.5 md:py-1">Authentic Design</span>
      </div>
    </div>
  </section>



  <!-- PRODUCTS -->
  <section id="products" class="section-products section-fade-in">
    <div class="page-container">
      <!-- Category filter tabs -->
      <div id="categoryFilters" class="flex flex-wrap items-center gap-2 mb-6"></div>

      <div id="productGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3"></div>

    </div>
  </section>

</Layout>

<script>
  var defaultProducts = [
    { name: 'Iron Man Mk 85', price: 'Tk 450', image: 'https://placehold.co/400x533/141414/FFD700?text=Iron+Man+Mk+85&font=inter', tag: 'Marvel', category: 'Marvel' },
    { name: 'Batman Dark Knight', price: 'Tk 380', image: 'https://placehold.co/400x533/141414/FFD700?text=Batman+Dark+Knight&font=inter', tag: 'DC', category: 'DC' },
    { name: 'Goku Ultra Instinct', price: 'Tk 520', image: 'https://placehold.co/400x533/141414/FFD700?text=Goku+Ultra+Instinct&font=inter', tag: 'Anime', category: 'Dragon Ball Z' },
    { name: 'Eleven', price: 'Tk 420', image: 'https://placehold.co/400x533/141414/FFD700?text=Eleven&font=inter', tag: 'Stranger Things', category: 'Stranger Things' },
    { name: 'Spider-Man Miles', price: 'Tk 480', image: 'https://placehold.co/400x533/141414/FFD700?text=Spider-Man+Miles&font=inter', tag: 'Marvel', category: 'Marvel' },
    { name: 'Luffy Gear 5', price: 'Tk 550', image: 'https://placehold.co/400x533/141414/FFD700?text=Luffy+Gear+5&font=inter', tag: 'Anime', category: 'One Piece' },
  ];
  var defaultCategories = ['Marvel','DC','Anime','Dragon Ball Z','Stranger Things','One Piece'];

  var currentCategory = 'All';

  function esc(str) { return String(str).replace(/"/g, '&quot;').replace(/'/g, '&#39;'); }

  function getProducts() {
    try { return JSON.parse(localStorage.getItem('jv_products')) || defaultProducts; }
    catch { return defaultProducts; }
  }

  function getCategories() {
    try { return JSON.parse(localStorage.getItem('jv_categories')) || defaultCategories; }
    catch { return defaultCategories; }
  }

  function renderCategoryFilters() {
    var container = document.getElementById('categoryFilters');
    if (!container) return;
    var cats = getCategories();
    var allCats = ['All'].concat(cats);
    container.innerHTML = allCats.map(function(c) {
      var active = c === currentCategory ? ' category-filter-active' : '';
      return '<button class="category-filter' + active + '" data-cat="' + esc(c) + '">' + esc(c) + '</button>';
    }).join('');
    container.querySelectorAll('.category-filter').forEach(function(btn) {
      btn.addEventListener('click', function() {
        currentCategory = this.dataset.cat;
        renderCategoryFilters();
        renderProducts();
      });
    });
  }

  function renderProducts() {
    var products = getProducts();
    var grid = document.getElementById('productGrid');
    if (!grid) return;

    var filtered = currentCategory === 'All'
      ? products
      : products.filter(function(p) { return p.category === currentCategory; });

    if (filtered.length === 0) {
      grid.innerHTML = '<p style="grid-column:1/-1;text-align:center;padding:60px 0;color:var(--muted);">No products in this category.</p>';
      return;
    }

    grid.innerHTML = filtered.map(function(p, i) {
      return '<article class="card-product product-card-entrance" style="animation-delay:' + (i * 0.06) + 's">' +
        '<div class="card-img-wrap">' +
        '<img src="' + p.image + '" alt="' + p.name + '" loading="lazy" />' +
        (p.tag ? '<span class="card-tag">' + p.tag + '</span>' : '') +
        '<button type="button" class="card-add-btn" data-name="' + esc(p.name) + '" data-price="' + esc(p.price) + '" data-image="' + esc(p.image) + '">' +
        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>' +
        '</button></div>' +
        '<div class="card-info">' +
        '<span class="card-name">' + p.name + '</span>' +
        '<span class="card-price">' + p.price + '</span></div></article>';
    }).join('');

    // Wire up + buttons
    grid.querySelectorAll('button').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var product = {
          name: this.dataset.name,
          price: this.dataset.price,
          image: this.dataset.image,
        };
        if (window.addToCart) window.addToCart(product);
      });
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    renderCategoryFilters();
    renderProducts();
  });
</script>
