---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BRICK RUSH - Premium LEGO Minifigures">

  <!-- ── Hero Band ── -->
  <section class="section-hero relative overflow-hidden">
    <div class="container text-center relative z-10">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-cyan-soft border border-cyan/20 mb-10 animate-fade-in opacity-0" style="animation-delay: 0.2s">
        <span class="w-2 h-2 rounded-full bg-cyan animate-pulse"></span>
        <span class="caption-mono text-[10px] text-cyan font-bold">New Exclusive Drops Live</span>
      </div>
      
      <h1 class="display-xl mb-6 text-gradient-cyan animate-fade-in opacity-0" style="animation-delay: 0.4s">
        Build your legacy <br class="hidden sm:block" /> with premium bricks.
      </h1>

      <p class="body-lg mx-auto mb-12 max-w-xl animate-fade-in opacity-0" style="animation-delay: 0.6s">
        Authentic detail, premium ABS plastic, and the most exclusive minifigures in Bangladesh. Hand-picked for the ultimate collector.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in opacity-0" style="animation-delay: 0.8s">
        <a href="#products" class="btn-primary w-full sm:w-auto">Explore Collection</a>
        <a href="#" class="btn-secondary w-full sm:w-auto">View Showcase</a>
      </div>
    </div>
    
    <!-- Decorative Mesh Gradient -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-[1400px] pointer-events-none opacity-40">
      <div class="absolute top-[-10%] left-[20%] w-[40%] h-[60%] bg-cyan/20 blur-[120px] rounded-full"></div>
      <div class="absolute top-[20%] right-[10%] w-[30%] h-[50%] bg-blue-500/10 blur-[100px] rounded-full"></div>
    </div>
  </section>

  <!-- ── Category Filter Band ── -->
  <section class="border-y border-accents-2 bg-black py-4 sticky top-[64px] z-40">
    <div class="overflow-x-auto no-scrollbar touch-pan-x">
      <div id="categoryFilters" class="flex items-center justify-start sm:justify-center gap-2 px-6 min-w-max mx-auto">
        <!-- Categories injected by JS -->
      </div>
    </div>
  </section>

  <!-- ── Products Grid ── -->
  <section id="products" class="py-16 sm:py-24">
    <div class="container">
      <div id="productGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 sm:gap-6 justify-center">
        <!-- Products injected by JS -->
      </div>
    </div>
  </section>

  <!-- ── Footer ── -->
  <footer class="relative bg-gradient-to-b from-black via-ds-background-200 to-black border-t border-accents-2 pt-16 pb-8 mt-16">
    <!-- Decorative Top Gradient Bar -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan/50 to-transparent"></div>
    
    <!-- Glow Behind -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[60%] h-32 bg-cyan/5 blur-[80px] rounded-full pointer-events-none"></div>

    <div class="container relative z-10">
      <!-- Middle: 4-Column Grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-12 mb-14">
        
        <!-- Column 1: Brand -->
        <div class="col-span-2 md:col-span-1">
          <div class="flex items-center gap-2 mb-5">
            <span class="w-8 h-8 bg-cyan rounded-md flex items-center justify-center text-black font-bold text-lg">B</span>
            <span class="font-bold text-lg tracking-tight text-white">BRICK<span class="text-cyan">RUSH</span></span>
          </div>
          <p class="text-xs text-accents-5 leading-relaxed mb-6 max-w-xs">
            Bangladesh's premier source for authentic premium LEGO minifigures. Every piece hand-selected for the discerning collector.
          </p>
          <div class="flex items-center gap-3">
            <a href="#" class="w-9 h-9 rounded-full bg-accents-1 border border-accents-2 flex items-center justify-center text-accents-5 hover:text-cyan hover:border-cyan transition-all duration-200" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            <a href="#" class="w-9 h-9 rounded-full bg-accents-1 border border-accents-2 flex items-center justify-center text-accents-5 hover:text-cyan hover:border-cyan transition-all duration-200" aria-label="Facebook">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <a href="#" class="w-9 h-9 rounded-full bg-accents-1 border border-accents-2 flex items-center justify-center text-accents-5 hover:text-cyan hover:border-cyan transition-all duration-200" aria-label="WhatsApp">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            </a>
          </div>
        </div>

        <!-- Column 2: Quick Links -->
        <div>
          <h4 class="caption-mono text-[10px] text-cyan font-bold tracking-widest mb-5">Navigation</h4>
          <ul class="space-y-3">
            <li><a href="/" class="text-xs text-accents-5 hover:text-white transition-colors">Home</a></li>
            <li><a href="#products" class="text-xs text-accents-5 hover:text-white transition-colors">Collection</a></li>
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">New Arrivals</a></li>
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">Limited Edition</a></li>
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">Pre-Orders</a></li>
          </ul>
        </div>

        <!-- Column 3: Categories -->
        <div>
          <h4 class="caption-mono text-[10px] text-cyan font-bold tracking-widest mb-5">Categories</h4>
          <ul class="space-y-3">
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">Marvel</a></li>
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">DC</a></li>
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">Anime</a></li>
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">Star Wars</a></li>
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">Exclusive</a></li>
          </ul>
        </div>

        <!-- Column 4: Contact -->
        <div>
          <h4 class="caption-mono text-[10px] text-cyan font-bold tracking-widest mb-5">Contact</h4>
          <ul class="space-y-4" id="footerContactList">
            <li class="flex flex-col">
              <span class="text-[9px] caption-mono tracking-widest text-accents-4 mb-1">Bkash</span>
              <span id="footerBkash" class="text-xs text-accents-5 font-mono">—</span>
            </li>
            <li class="flex flex-col">
              <span class="text-[9px] caption-mono tracking-widest text-accents-4 mb-1">Nagad</span>
              <span id="footerNagad" class="text-xs text-accents-5 font-mono">—</span>
            </li>
            <li class="flex flex-col">
              <span class="text-[9px] caption-mono tracking-widest text-accents-4 mb-1">Contact</span>
              <span id="footerContact" class="text-xs text-accents-5 font-mono">—</span>
            </li>
            <li class="pt-2">
              <a href="/admin" class="text-[9px] text-accents-4 hover:text-accents-5 transition-colors" style="letter-spacing: 0.05em;">©</a>
            </li>
          </ul>
        </div>
      </div>

      <!-- Bottom Bar -->
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4 pt-8 border-t border-accents-2">
        <div class="text-[10px] caption-mono tracking-widest text-accents-5">
          &copy; 2024 BRICK RUSH &mdash; ALL RIGHTS RESERVED
        </div>
        <div class="flex items-center gap-6 text-[10px] caption-mono tracking-widest text-accents-5">
          <a href="#" class="hover:text-white transition-colors">Privacy</a>
          <a href="#" class="hover:text-white transition-colors">Terms</a>
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-cyan/60 animate-pulse"></span>
            <span class="text-cyan/80">Secure</span>
          </span>
        </div>
      </div>
    </div>
  </footer>

</Layout>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  
  .text-gradient-cyan {
    background: linear-gradient(to bottom, #ffffff 30%, var(--cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>

<script is:inline>
  var defaultProducts = [
    { name: 'Iron Man Mk 85', price: 'Tk 450', image: 'https://placehold.co/400x533/111/50e3c2?text=Iron+Man&font=inter', category: 'Marvel' },
    { name: 'Batman Dark Knight', price: 'Tk 380', image: 'https://placehold.co/400x533/111/50e3c2?text=Batman&font=inter', category: 'DC' },
    { name: 'Goku Ultra Instinct', price: 'Tk 520', image: 'https://placehold.co/400x533/111/50e3c2?text=Goku&font=inter', category: 'Anime' },
    { name: 'Eleven', price: 'Tk 420', image: 'https://placehold.co/400x533/111/50e3c2?text=Eleven&font=inter', category: 'Stranger Things' },
    { name: 'Spider-Man Miles', price: 'Tk 480', image: 'https://placehold.co/400x533/111/50e3c2?text=Miles&font=inter', category: 'Marvel' },
    { name: 'Luffy Gear 5', price: 'Tk 550', image: 'https://placehold.co/400x533/111/50e3c2?text=Luffy&font=inter', category: 'One Piece' },
    { name: 'Mandalorian', price: 'Tk 600', image: 'https://placehold.co/400x533/111/50e3c2?text=Mando&font=inter', category: 'Star Wars' },
    { name: 'Naruto Baryon', price: 'Tk 520', image: 'https://placehold.co/400x533/111/50e3c2?text=Naruto&font=inter', category: 'Anime' },
    { name: 'Wolverine Logan', price: 'Tk 460', image: 'https://placehold.co/400x533/111/50e3c2?text=Wolverine&font=inter', category: 'Marvel' },
    { name: 'Joker Heath', price: 'Tk 400', image: 'https://placehold.co/400x533/111/50e3c2?text=Joker&font=inter', category: 'DC' },
    { name: 'Tanjiro Sun', price: 'Tk 490', image: 'https://placehold.co/400x533/111/50e3c2?text=Tanjiro&font=inter', category: 'Anime' },
    { name: 'Darth Vader', price: 'Tk 650', image: 'https://placehold.co/400x533/111/50e3c2?text=Vader&font=inter', category: 'Star Wars' },
  ];

  var currentCategory = 'All';

  function getProducts() {
    try {
      const stored = localStorage.getItem('jv_products');
      return stored ? JSON.parse(stored) : defaultProducts;
    } catch (e) {
      console.error('Product load error', e);
      return defaultProducts;
    }
  }

  function renderFilters() {
    var container = document.getElementById('categoryFilters');
    if (!container) return;
    const products = getProducts();
    const categories = [...new Set(products.map(p => p.category).filter(Boolean))];
    var cats = ['All'].concat(categories);
    
    container.innerHTML = cats.map(c => `
      <button class="nav-link whitespace-nowrap px-4 py-1.5 transition-all ${c === currentCategory ? 'active bg-accents-2 !text-cyan' : ''}" data-cat="${c}">${c}</button>
    `).join('');
    
    container.querySelectorAll('button').forEach(btn => {
      btn.onclick = () => {
        currentCategory = btn.dataset.cat || 'All';
        renderFilters();
        renderProducts();
        if (window.innerWidth < 640) {
           document.getElementById('products').scrollIntoView({ behavior: 'smooth' });
        }
      };
    });
  }

  function renderProducts() {
    var grid = document.getElementById('productGrid');
    if (!grid) return;
    const allProducts = getProducts();
    var filtered = currentCategory === 'All' ? allProducts : allProducts.filter(p => p.category === currentCategory);
    
    if (filtered.length === 0) {
      grid.innerHTML = '<div class="col-span-full py-20 text-center text-accents-4 italic">No minifigures found in this sector.</div>';
      return;
    }

    grid.innerHTML = filtered.map(p => {
      const pName = (p.name || 'Unknown Unit').replace(/'/g, "&apos;");
      const pPrice = p.price || 'Price TBA';
      const pDiscount = p.discountPrice;
      const hasDiscount = pDiscount && pDiscount !== pPrice;
      const displayPrice = hasDiscount ? pDiscount : pPrice;
      
      const pCat = p.category || 'General';
      const pImage = p.image || 'https://placehold.co/400x533/111/50e3c2?text=Unit&font=inter';

      return `
        <div class="card group cursor-pointer animate-fade-in flex flex-col h-full">
          <div class="aspect-[3/4] rounded-sm bg-accents-1 overflow-hidden relative mb-3 flex-shrink-0">
            ${hasDiscount ? `<div class="absolute top-2 left-2 z-10 bg-cyan text-black text-[9px] font-bold px-2 py-0.5 rounded-full uppercase tracking-tighter shadow-lg">Sale</div>` : ''}
            <img src="${pImage}" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-700 ease-out" loading="lazy" />
            <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
            <!-- Floating Cart Button - bold and mobile-first -->
            <button class="absolute bottom-3 right-3 w-12 h-12 rounded-full bg-accents-1 text-white flex items-center justify-center shadow-2xl ring-2 ring-white/20 hover:bg-accents-2 transition-colors duration-200 z-20" 
                    aria-label="Add to cart"
                    onclick="window.addToCart({name:'${pName}', price:'${displayPrice}', image:'${pImage}'}); event.stopPropagation();">
              <span class="text-2xl font-black leading-none text-cyan">+</span>
            </button>
          </div>
          <div class="flex flex-col flex-1 justify-between gap-2">
            <div>
              <span class="text-[13px] sm:text-sm text-white font-medium line-clamp-2 leading-tight mb-1 block">${pName}</span>
              <span class="text-accents-5 text-[9px] sm:text-[10px] caption-mono block">${pCat}</span>
            </div>
            <div class="flex items-center justify-between mt-auto">
              <div class="flex flex-col">
                <span class="text-cyan text-[13px] sm:text-sm font-bold leading-none">${displayPrice}</span>
                ${hasDiscount ? `<span class="text-[9px] text-accents-4 line-through mt-0.5">${pPrice}</span>` : ''}
              </div>
            </div>
          </div>
        </div>
      `;
    }).join('');
  }

  // ─── Footer Contact Info from Settings ───
  function loadFooterContact() {
    try {
      var settings = JSON.parse(localStorage.getItem('jv_settings') || '{}');
      var bkash = document.getElementById('footerBkash');
      var nagad = document.getElementById('footerNagad');
      var contact = document.getElementById('footerContact');
      if (bkash) bkash.textContent = settings.bkash || 'Not set';
      if (nagad) nagad.textContent = settings.nagad || 'Not set';
      if (contact) contact.textContent = settings.contact || 'Not set';
    } catch (e) {}
  }

  // Initial Render
  setTimeout(() => {
    renderFilters();
    renderProducts();
    loadFooterContact();
  }, 100);
</script>
