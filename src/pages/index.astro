---
import Layout from '../layouts/Layout.astro';
---

<Layout title="JUMANJI VAULT - Premium LEGO Minifigures">

  <!-- HERO -->
  <section class="section-hero relative overflow-hidden">
    <!-- Glow backdrop (hidden on small screens) -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none max-md:hidden" aria-hidden="true">
      <div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[800px] h-[500px] rounded-full" style="background: radial-gradient(ellipse, rgba(255,215,0,0.08), transparent);"></div>
      <div class="absolute top-[5%] left-[10%] w-[400px] h-[400px] rounded-full" style="background: radial-gradient(ellipse, rgba(232,0,45,0.05), transparent);"></div>
    </div>

    <div class="page-container relative z-10 text-center">
      <!-- Headline -->
      <h1 class="typo-display-xl mx-auto mb-3 md:mb-5" style="max-width: 800px; color: var(--white);">
        JUMANJI VAULT
      </h1>

      <p class="typo-body-lg mx-auto mb-5 md:mb-8" style="color: var(--muted); max-width: 520px; font-size: clamp(15px, 2vw, 18px);">
        Marvel, DC, Anime, Dragon Ball Z, and more. Authentic detail, premium ABS plastic, cash on delivery across Bangladesh.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-2 md:gap-3 mb-6 md:mb-14">
        <a href="#products" class="btn-gold hero-cta">
          Browse Collection
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1.5 md:ml-2">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
        <a href="#" class="btn-ghost hero-cta">Explore</a>
      </div>

      <!-- Feature pills -->
      <div class="flex flex-wrap items-center justify-center gap-1.5 md:gap-2 px-0">
        <span class="badge-pill text-[11px] md:text-[13px] px-2 md:px-3 py-0.5 md:py-1">Cash on Delivery</span>
        <span class="badge-pill text-[11px] md:text-[13px] px-2 md:px-3 py-0.5 md:py-1">Premium ABS</span>
        <span class="badge-pill text-[11px] md:text-[13px] px-2 md:px-3 py-0.5 md:py-1">1-3 Day Delivery</span>
        <span class="badge-pill text-[11px] md:text-[13px] px-2 md:px-3 py-0.5 md:py-1">Accessories</span>
        <span class="badge-pill text-[11px] md:text-[13px] px-2 md:px-3 py-0.5 md:py-1">Authentic Design</span>
      </div>
    </div>
  </section>



  <!-- PRODUCTS -->
  <section id="products" class="section-products">
    <div class="page-container">
      <!-- Category filter tabs -->
      <div id="categoryFilters" class="flex flex-wrap items-center gap-2 mb-6"></div>

      <div id="productGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3"></div>

    </div>
  </section>

</Layout>

<script>
  var defaultProducts = [
    { name: 'Iron Man Mk 85', price: 'Tk 450', image: '/images/product-1.svg', tag: 'Marvel', category: 'Marvel' },
    { name: 'Batman Dark Knight', price: 'Tk 380', image: '/images/product-2.svg', tag: 'DC', category: 'DC' },
    { name: 'Goku Ultra Instinct', price: 'Tk 520', image: '/images/product-3.svg', tag: 'Anime', category: 'Dragon Ball Z' },
    { name: 'Eleven', price: 'Tk 420', image: '/images/product-4.svg', tag: 'Stranger Things', category: 'Stranger Things' },
    { name: 'Spider-Man Miles', price: 'Tk 480', image: '/images/product-5.svg', tag: 'Marvel', category: 'Marvel' },
    { name: 'Luffy Gear 5', price: 'Tk 550', image: '/images/product-6.svg', tag: 'Anime', category: 'One Piece' },
  ];
  var defaultCategories = ['Marvel','DC','Anime','Dragon Ball Z','Stranger Things','One Piece'];

  var currentCategory = 'All';

  function esc(str) { return String(str).replace(/"/g, '&quot;').replace(/'/g, '&#39;'); }

  function getProducts() {
    try { return JSON.parse(localStorage.getItem('jv_products')) || defaultProducts; }
    catch { return defaultProducts; }
  }

  function getCategories() {
    try { return JSON.parse(localStorage.getItem('jv_categories')) || defaultCategories; }
    catch { return defaultCategories; }
  }

  function renderCategoryFilters() {
    var container = document.getElementById('categoryFilters');
    if (!container) return;
    var cats = getCategories();
    var allCats = ['All'].concat(cats);
    container.innerHTML = allCats.map(function(c) {
      var active = c === currentCategory ? ' category-filter-active' : '';
      return '<button class="category-filter' + active + '" data-cat="' + esc(c) + '">' + esc(c) + '</button>';
    }).join('');
    container.querySelectorAll('.category-filter').forEach(function(btn) {
      btn.addEventListener('click', function() {
        currentCategory = this.dataset.cat;
        renderCategoryFilters();
        renderProducts();
      });
    });
  }

  function renderProducts() {
    var products = getProducts();
    var grid = document.getElementById('productGrid');
    if (!grid) return;

    var filtered = currentCategory === 'All'
      ? products
      : products.filter(function(p) { return p.category === currentCategory; });

    if (filtered.length === 0) {
      grid.innerHTML = '<p style="grid-column:1/-1;text-align:center;padding:60px 0;color:var(--muted);">No products in this category.</p>';
      return;
    }

    grid.innerHTML = filtered.map(function(p) {
      return '<article class="card-product group cursor-pointer">' +
        '<div class="relative aspect-[3/4] overflow-hidden rounded-lg mb-2" style="background-color: var(--bg);">' +
        '<img src="' + p.image + '" alt="' + p.name + '" class="w-full h-full object-contain p-3 transition-transform duration-300 group-hover:scale-110" loading="lazy" />' +
        (p.tag ? '<span class="badge-tag absolute top-2 left-2 z-10">' + p.tag + '</span>' : '') +
        '<button type="button" class="absolute bottom-2 right-2 z-10 flex items-center justify-center" style="width:28px;height:28px;border-radius:9999px;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--bg);border:none;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,0.4);" data-name="' + esc(p.name) + '" data-price="' + esc(p.price) + '" data-image="' + esc(p.image) + '">' +
        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>' +
        '</button></div>' +
        '<div class="flex items-center justify-between gap-1">' +
        '<h3 class="typo-body-sm" style="color:var(--white);">' + p.name + '</h3>' +
        '<span class="typo-body-sm whitespace-nowrap text-gold">' + p.price + '</span></div></article>';
    }).join('');

    // Wire up + buttons
    grid.querySelectorAll('button').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var product = {
          name: this.dataset.name,
          price: this.dataset.price,
          image: this.dataset.image,
        };
        if (window.addToCart) window.addToCart(product);
      });
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    renderCategoryFilters();
    renderProducts();
  });
</script>
