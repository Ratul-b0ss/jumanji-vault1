---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BRICK RUSH - Premium LEGO Minifigures">

  <section class="section-hero relative overflow-hidden">
    <div class="container text-center relative z-10">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-cyan-soft border border-cyan/20 mb-10 animate-fade-in opacity-0" style="animation-delay: 0.2s">
        <span class="w-2 h-2 rounded-full bg-cyan animate-pulse"></span>
        <span class="caption-mono text-[10px] text-cyan font-bold">New Exclusive Drops Live</span>
      </div>
      
      <h1 class="display-xl mb-6 text-gradient-cyan animate-fade-in opacity-0" style="animation-delay: 0.4s">
        Build your legacy <br class="hidden sm:block" /> with premium bricks.
      </h1>

      <p class="body-lg mx-auto mb-12 max-w-xl animate-fade-in opacity-0" style="animation-delay: 0.6s">
        Authentic detail, premium ABS plastic, and the most exclusive minifigures in Bangladesh. Hand-picked for the ultimate collector.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in opacity-0" style="animation-delay: 0.8s">
        <a href="#products" class="btn-primary w-full sm:w-auto">Explore Collection</a>
        <a href="#" class="btn-secondary w-full sm:w-auto">View Showcase</a>
      </div>
    </div>
    
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-[1400px] pointer-events-none opacity-40">
      <div class="absolute top-[-10%] left-[20%] w-[40%] h-[60%] bg-cyan/20 blur-[120px] rounded-full"></div>
      <div class="absolute top-[20%] right-[10%] w-[30%] h-[50%] bg-blue-500/10 blur-[100px] rounded-full"></div>
    </div>
  </section>

  <section class="border-y border-accents-2 bg-black py-4 sticky top-[64px] z-40">
    <div class="overflow-x-auto no-scrollbar touch-pan-x">
      <div id="categoryFilters" class="flex items-center justify-start sm:justify-center gap-2 px-6 min-w-max mx-auto"></div>
    </div>
  </section>

  <section id="products" class="py-16 sm:py-24">
    <div class="container">
      <div id="productGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 sm:gap-6 justify-center"></div>
    </div>
  </section>

  <div id="zoomOverlay" class="fixed inset-0 z-[5000] bg-black/80 backdrop-blur-xl hidden opacity-0 transition-opacity duration-300 flex items-center justify-center p-4" style="display:none;">
    <button id="zoomClose" class="absolute top-6 right-6 w-10 h-10 rounded-full bg-white/10 text-white flex items-center justify-center hover:bg-white/20 transition-colors z-10">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="relative max-w-3xl w-full max-h-[90vh] flex items-center justify-center">
      <img id="zoomImage" src="" class="max-w-full max-h-[85vh] object-contain rounded-lg shadow-2xl" />
    </div>
  </div>

  <footer class="relative bg-gradient-to-b from-black via-ds-background-200 to-black border-t border-accents-2 pt-16 pb-8 mt-16">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan/50 to-transparent"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[60%] h-32 bg-cyan/5 blur-[80px] rounded-full pointer-events-none"></div>

    <div class="container relative z-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-12 mb-14">
        <div class="col-span-2 md:col-span-1">
          <div class="flex items-center gap-2 mb-5">
            <span class="w-8 h-8 bg-cyan rounded-md flex items-center justify-center text-black font-bold text-lg">B</span>
            <span class="font-bold text-lg tracking-tight text-white">BRICK<span class="text-cyan">RUSH</span></span>
          </div>
          <p class="text-xs text-accents-5 leading-relaxed mb-6 max-w-xs">
            Bangladesh's premier source for authentic premium LEGO minifigures. Every piece hand-selected for the discerning collector.
          </p>
          <div class="flex items-center gap-3">
            <a id="footerInstagram" href="#" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-accents-1 border border-accents-2 flex items-center justify-center text-accents-5 hover:text-cyan hover:border-cyan transition-all duration-200" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            <a id="footerFacebook" href="#" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-accents-1 border border-accents-2 flex items-center justify-center text-accents-5 hover:text-cyan hover:border-cyan transition-all duration-200" aria-label="Facebook">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <a id="footerWhatsApp" href="#" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-accents-1 border border-accents-2 flex items-center justify-center text-accents-5 hover:text-cyan hover:border-cyan transition-all duration-200" aria-label="WhatsApp">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            </a>
          </div>
        </div>

        <div>
          <h4 class="caption-mono text-[10px] text-cyan font-bold tracking-widest mb-5">Navigation</h4>
          <ul class="space-y-3">
            <li><a href="/" class="text-xs text-accents-5 hover:text-white transition-colors">Home</a></li>
            <li><a href="#products" class="text-xs text-accents-5 hover:text-white transition-colors">Collection</a></li>
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">New Arrivals</a></li>
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">Limited Edition</a></li>
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">Pre-Orders</a></li>
          </ul>
        </div>

        <div>
          <h4 class="caption-mono text-[10px] text-cyan font-bold tracking-widest mb-5">Categories</h4>
          <ul class="space-y-3">
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">Marvel</a></li>
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">DC</a></li>
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">Anime</a></li>
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">Star Wars</a></li>
            <li><a href="#" class="text-xs text-accents-5 hover:text-white transition-colors">Exclusive</a></li>
          </ul>
        </div>

        <div class="col-span-2 md:col-span-1">
          <h4 class="caption-mono text-[10px] text-cyan font-bold tracking-widest mb-5">Contact</h4>
          <ul class="space-y-4" id="footerContactList">
            <li class="flex flex-col">
              <span class="text-[9px] caption-mono tracking-widest text-accents-4 mb-1">Bkash</span>
              <span id="footerBkash" class="text-xs text-accents-5 font-mono">—</span>
            </li>
            <li class="flex flex-col">
              <span class="text-[9px] caption-mono tracking-widest text-accents-4 mb-1">Nagad</span>
              <span id="footerNagad" class="text-xs text-accents-5 font-mono">—</span>
            </li>
            <li class="flex flex-col">
              <span class="text-[9px] caption-mono tracking-widest text-accents-4 mb-1">Contact</span>
              <span id="footerContact" class="text-xs text-accents-5 font-mono">—</span>
            </li>
            <li class="pt-2">
              <a href="/admin" class="text-[9px] text-accents-4 hover:text-accents-5 transition-colors" style="letter-spacing: 0.05em;">©</a>
            </li>
          </ul>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row justify-between items-center gap-4 pt-8 border-t border-accents-2">
        <div class="text-[10px] caption-mono tracking-widest text-accents-5">
          &copy; 2024 BRICK RUSH &mdash; ALL RIGHTS RESERVED
        </div>
        <div class="flex items-center gap-6 text-[10px] caption-mono tracking-widest text-accents-5">
          <a href="#" class="hover:text-white transition-colors">Privacy</a>
          <a href="#" class="hover:text-white transition-colors">Terms</a>
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-cyan/60 animate-pulse"></span>
            <span class="text-cyan/80">Secure</span>
          </span>
        </div>
      </div>
    </div>
  </footer>

</Layout>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .text-gradient-cyan {
    background: linear-gradient(to bottom, #ffffff 30%, var(--cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>

<script is:inline>
  // ─── Supabase Config ───
  var SUPABASE_URL = 'https://bpgdniisgxzgrrcqlnwp.supabase.co';
  var SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJwZ2RuaWlzZ3h6Z3JyY3FsbndwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE3NjU2ODIsImV4cCI6MjA5NzM0MTY4Mn0.krm-gAAveC4y8bBIwEMFTggXSDzn4Ypj_r5UjoJ5uuk';

  function supabaseFetch(path, options) {
    return fetch(SUPABASE_URL + '/rest/v1/' + path, {
      headers: {
        'apikey': SUPABASE_ANON_KEY,
        'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
        'Content-Type': 'application/json',
        ...(options && options.headers ? options.headers : {})
      },
      ...(options ? { method: options.method, body: options.body } : {})
    });
  }

  var currentCategory = 'All';
  var allProducts = [];

  // ─── Load Products from Supabase ───
  async function loadProducts() {
    try {
      var res = await supabaseFetch('products?order=id.asc');
      var data = await res.json();
      if (Array.isArray(data) && data.length > 0) {
        allProducts = data;
        // Cache in localStorage for offline
        localStorage.setItem('jv_supabase_products', JSON.stringify(data));
      } else {
        allProducts = [];
      }
    } catch(e) {
      // Fallback to cached products
      try {
        var cached = localStorage.getItem('jv_supabase_products');
        if (cached) allProducts = JSON.parse(cached);
      } catch(e2) {}
    }
    renderFilters();
    renderProducts();
  }

  function renderFilters() {
    var container = document.getElementById('categoryFilters');
    if (!container) return;
    var categories = [...new Set(allProducts.map(function(p) { return p.category; }).filter(Boolean))];
    var cats = ['All'].concat(categories);
    
    container.innerHTML = cats.map(function(c) {
      return '<button class="nav-link whitespace-nowrap px-4 py-1.5 transition-all ' + (c === currentCategory ? 'active bg-accents-2 !text-cyan' : '') + '" data-cat="' + c + '">' + c + '</button>';
    }).join('');
    
    container.querySelectorAll('button').forEach(function(btn) {
      btn.onclick = function() {
        currentCategory = btn.getAttribute('data-cat') || 'All';
        renderFilters();
        renderProducts();
        if (window.innerWidth < 640) {
           document.getElementById('products').scrollIntoView({ behavior: 'smooth' });
        }
      };
    });
  }

  function renderProducts() {
    var grid = document.getElementById('productGrid');
    if (!grid) return;
    var filtered = currentCategory === 'All' ? allProducts : allProducts.filter(function(p) { return p.category === currentCategory; });
    
    if (filtered.length === 0) {
      grid.innerHTML = '<div class="col-span-full py-20 text-center text-accents-4 italic">No minifigures found in this sector.</div>';
      return;
    }

    grid.innerHTML = filtered.map(function(p) {
      var pName = (p.name || 'Unknown Unit').replace(/'/g, "&apos;");
      var pPrice = p.price || 'Price TBA';
      var pDiscount = p.discount_price;
      var hasDiscount = pDiscount && pDiscount !== pPrice;
      var displayPrice = hasDiscount ? pDiscount : pPrice;
      var pImage = p.image || 'https://placehold.co/400x533/111/50e3c2?text=Unit&font=inter';

      return '<div class="card group cursor-pointer animate-fade-in flex flex-col h-full">' +
        '<div class="aspect-[3/4] rounded-sm bg-accents-1 overflow-hidden relative mb-3 flex-shrink-0">' +
          (hasDiscount ? '<div class="absolute top-2 left-2 z-10 bg-cyan text-black text-[9px] font-bold px-2 py-0.5 rounded-full uppercase tracking-tighter shadow-lg">Sale</div>' : '') +
          '<img src="' + pImage + '" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-700 ease-out" loading="lazy" />' +
          '<div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>' +
          '<button class="absolute bottom-2.5 right-2.5 w-7 h-7 rounded-full bg-black/70 text-white flex items-center justify-center shadow-lg ring-1 ring-white/10 hover:bg-cyan hover:text-black hover:ring-cyan/50 transition-all duration-200 z-20 backdrop-blur-sm" aria-label="Zoom" onclick="window.openZoom(\'' + pImage + '\'); event.stopPropagation();">' +
            '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /><line x1="11" y1="8" x2="11" y2="14" /><line x1="8" y1="11" x2="14" y2="11" /></svg>' +
          '</button>' +
        '</div>' +
        '<div class="flex flex-col flex-1 justify-between gap-2">' +
          '<div><span class="text-[13px] sm:text-sm text-white font-medium line-clamp-2 leading-tight mb-1 block">' + pName + '</span></div>' +
          '<div class="flex items-center justify-between mt-auto">' +
            '<div class="flex flex-col">' +
              '<span class="text-cyan text-[13px] sm:text-sm font-bold leading-none">' + displayPrice + '</span>' +
              (hasDiscount ? '<span class="text-[9px] text-accents-4 line-through mt-0.5">' + pPrice + '</span>' : '') +
            '</div>' +
          '</div>' +
          '<button class="w-full mt-2 py-2 rounded-full bg-white text-black text-[11px] font-bold uppercase tracking-wider hover:bg-cyan hover:text-black transition-all duration-200" onclick="window.addToCart({name:\'' + pName + '\', price:\'' + displayPrice + '\', image:\'' + pImage + '\'}); event.stopPropagation();">Add to Cart</button>' +
        '</div></div>';
    }).join('');
  }

  // ─── Zoom Lightbox ───
  window.openZoom = function(src) {
    var overlay = document.getElementById('zoomOverlay');
    var img = document.getElementById('zoomImage');
    if (!overlay || !img) return;
    img.src = src;
    overlay.style.removeProperty('display');
    overlay.classList.remove('hidden');
    overlay.classList.remove('opacity-0');
    document.body.classList.add('modal-open');
  };

  document.addEventListener('click', function(e) {
    var overlay = document.getElementById('zoomOverlay');
    var close = document.getElementById('zoomClose');
    if (!overlay || !close) return;
    if (e.target === overlay || e.target === close || close.contains(e.target)) {
      overlay.classList.add('opacity-0');
      setTimeout(function() {
        overlay.classList.add('hidden');
        overlay.style.display = 'none';
        document.body.classList.remove('modal-open');
      }, 300);
    }
  });      // ─── Footer Contact Info & Social Links from Supabase ───
  function applyFooterSettings(s) {
    if (s.bkash) document.getElementById('footerBkash').textContent = s.bkash;
    if (s.nagad) document.getElementById('footerNagad').textContent = s.nagad;
    if (s.contact) document.getElementById('footerContact').textContent = s.contact;
    if (s.facebook) document.getElementById('footerFacebook').href = s.facebook;
    if (s.instagram) document.getElementById('footerInstagram').href = s.instagram;
    // Build WhatsApp link from contact number if available
    if (s.contact) {
      var num = s.contact.replace(/[^0-9]/g, '');
      if (num) document.getElementById('footerWhatsApp').href = 'https://wa.me/' + num;
    }
  }

  async function loadFooterContact() {
    try {
      // Try cached first for instant display
      var cached = localStorage.getItem('jv_settings_cache');
      if (cached) {
        try { applyFooterSettings(JSON.parse(cached)); } catch(e) {}
      }
      // Fetch fresh from Supabase
      var res = await supabaseFetch('settings?select=*&limit=1');
      var data = await res.json();
      if (data && data.length > 0) {
        var s = data[0];
        localStorage.setItem('jv_settings_cache', JSON.stringify(s));
        applyFooterSettings(s);
      }
    } catch(e) {}
  }

  // ─── Initial Render ───
  setTimeout(function() {
    loadProducts();
    loadFooterContact();
  }, 50);
</script>
